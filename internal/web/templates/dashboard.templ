package templates

import (
	"strconv"
	"time"

	"github.com/digitaldrywood/detent/internal/telemetry"
	"github.com/digitaldrywood/detent/internal/web/ui/components/button"
	"github.com/digitaldrywood/detent/internal/web/ui/components/dialog"
	"github.com/digitaldrywood/detent/internal/web/ui/components/icon"
	"github.com/digitaldrywood/detent/internal/web/ui/components/popover"
	"github.com/digitaldrywood/detent/internal/web/ui/components/sheet"
	"github.com/digitaldrywood/detent/internal/web/ui/components/sidebar"
)

templ Dashboard(data DashboardData) {
	@DashboardShell(DashboardShellDataFromDashboard(data)) {
		<div class="mx-auto grid w-full max-w-7xl content-start gap-4 sm:gap-5">
			<header class="dashboard-topbar min-w-0 border-b border-border py-2">
				<div class="flex min-w-0 flex-wrap items-center gap-x-5 gap-y-2">
					@dashboardMobileSidebarTrigger()
					@dashboardPageHeading(dashboardHeading(data))
					<div class="dashboard-topbar-actions ml-auto flex min-w-0 flex-wrap items-center justify-end gap-x-2 gap-y-1 text-xs text-muted-foreground">
						if projectExternalURL(data) != "" {
							<a class="inline-flex size-8 shrink-0 items-center justify-center rounded-md border border-border bg-card text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectExternalURL(data) } target="_blank" rel="noopener noreferrer" title={ projectExternalLinkLabel(data) } aria-label={ projectExternalLinkLabel(data) }>
								@icon.ExternalLink(icon.Props{Class: "size-4"})
							</a>
						}
						if isProjectDashboard(data) {
							<a class="inline-flex min-h-8 items-center gap-1 rounded-md border border-border bg-card px-2 py-1 font-medium text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectKanbanPath(data.ProjectID) }>
								@icon.Kanban(icon.Props{Class: "size-3.5 shrink-0"})
								<span>Board</span>
							</a>
							@dashboardTopbarDivider()
						}
						<span class="truncate font-mono">{ dashboardBuildVersionLabel(data) }</span>
						@dashboardTopbarDivider()
						<span class="truncate">{ connectorName(data) }</span>
						@dashboardTopbarDivider()
						<span id="live-tick" class="sse-tick min-w-0 truncate font-mono" sse-swap="tick" hx-swap="innerHTML settle:120ms">{ generatedAtLabel(data.Snapshot) }</span>
					</div>
				</div>
			</header>
			<div id="snapshot" class="sse-surface grid min-w-0 gap-4 sm:gap-5" sse-swap="snapshot" hx-swap="morph:innerHTML">
				@SnapshotView(data)
			</div>
			@dashboardCharts(data)
		</div>
	}
}

templ ProjectKanbanPage(data DashboardData) {
	@ProjectKanbanShell(DashboardShellDataFromDashboard(data)) {
		<div class="mx-auto grid min-h-screen w-full max-w-[100rem] content-start gap-3 px-3 py-3 sm:px-4 lg:px-6">
			<header class="min-w-0 border-b border-border py-2">
				<div class="flex min-w-0 flex-wrap items-center gap-x-3 gap-y-2">
					<a class="inline-flex min-h-8 min-w-0 items-center gap-2 rounded-md border border-border bg-card px-2.5 py-1 text-sm font-semibold text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectDashboardPath(data.ProjectID) }>
						@icon.LayoutDashboard(icon.Props{Class: "size-4 shrink-0"})
						<span class="truncate">{ projectDisplayName(data) }</span>
					</a>
					<span class="inline-flex min-h-8 items-center gap-1 rounded-full border border-accent-soft bg-accent-soft px-2.5 py-1 text-xs font-semibold text-accent">
						@icon.Kanban(icon.Props{Class: "size-3.5 shrink-0"})
						<span>Kanban</span>
					</span>
					<div class="ml-auto flex min-w-0 flex-wrap items-center justify-end gap-x-2 gap-y-1 text-xs text-muted-foreground">
						<span class="truncate">{ connectorName(data) }</span>
						@dashboardTopbarDivider()
						<span id="live-tick" class="sse-tick min-w-0 truncate font-mono" sse-swap="tick" hx-swap="innerHTML settle:120ms">{ generatedAtLabel(data.Snapshot) }</span>
					</div>
				</div>
			</header>
			<div id="snapshot" class="sse-surface grid min-w-0 gap-3" sse-swap="snapshot" hx-swap="morph:innerHTML">
				@ProjectKanbanSnapshot(data)
			</div>
		</div>
	}
}

templ ProjectKanbanShell(data DashboardShellData) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<meta name="color-scheme" content="light dark"/>
			<meta name="application-name" content={ applicationName(data.ApplicationName) }/>
			<title>{ pageTitle(data) }</title>
			<script>
				document.documentElement.classList.toggle("dark", Boolean(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches))
			</script>
			@helpScript()
			<link rel="icon" type="image/svg+xml" href={ faviconPath(data.Assets) }/>
			<link rel="stylesheet" href={ stylesheetPath(data.Assets) }/>
			<script src="https://unpkg.com/htmx.org@2.0.4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx-ext-sse@2.2.4"></script>
			<script src="https://cdn.jsdelivr.net/npm/idiomorph@0.7.3/dist/idiomorph-ext.min.js"></script>
		</head>
		<body class="min-h-screen overflow-x-hidden bg-background text-foreground antialiased">
			@helpTooltipHost()
			<main class="min-h-screen bg-background" hx-ext="sse, morph" sse-connect={ projectKanbanEventsPath(data) }>
				{ children... }
			</main>
		</body>
	</html>
}

templ ProjectKanbanSnapshot(data DashboardData) {
	@projectKanbanSection(data, projectKanbanBoardView(data))
}

templ DashboardShell(data DashboardShellData) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<meta name="color-scheme" content="light dark"/>
			<meta name="application-name" content={ applicationName(data.ApplicationName) }/>
			<title>{ pageTitle(data) }</title>
			<script>
				document.documentElement.classList.toggle("dark", Boolean(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches))
			</script>
			@helpScript()
			<link rel="icon" type="image/svg+xml" href={ faviconPath(data.Assets) }/>
			<link rel="stylesheet" href={ stylesheetPath(data.Assets) }/>
			<script src="https://unpkg.com/htmx.org@2.0.4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx-ext-sse@2.2.4"></script>
			<script src="https://cdn.jsdelivr.net/npm/idiomorph@0.7.3/dist/idiomorph-ext.min.js"></script>
			if data.IncludeDashboardCharts {
				<script src={ chartJSPath(data.Assets) } defer></script>
				<script src={ dashboardChartsScriptPath(data.Assets) } defer></script>
			}
			@sidebar.Script()
			@popover.Script()
			@dialog.Script()
		</head>
		<body class="min-h-screen overflow-x-hidden bg-background text-foreground antialiased">
			@helpTooltipHost()
			@kanbanDialogHost()
			@sidebar.Layout(sidebar.LayoutProps{
				Class: "dashboard-shell min-h-screen w-full bg-background",
				Attributes: templ.Attributes{
					"hx-ext":      "sse, morph",
					"sse-connect": eventsPath(data),
				},
			}) {
				@dashboardSidebar(data)
				@sidebar.Inset(sidebar.InsetProps{Class: "dashboard-main min-w-0 px-3 py-3 sm:px-6 lg:px-8"}) {
					{ children... }
				}
			}
		</body>
	</html>
}

templ dashboardPageHeading(title string) {
	<h1 class="sr-only">{ title }</h1>
}

templ dashboardTopbarDivider() {
	<span aria-hidden="true">/</span>
}

templ kanbanDialogHost() {
	<div id="kanban-dialog-host">
		@dialog.Dialog(dialog.Props{ID: kanbanActionDialogID}) {
			@dialog.Content(dialog.ContentProps{Class: "max-w-lg"}) {
				<div id={ kanbanDialogContentID } class="grid gap-4"></div>
			}
		}
	</div>
}

templ dashboardMobileSidebarTrigger() {
	@sheet.Trigger(sheet.TriggerProps{For: "dashboard-sidebar-mobile", Class: "md:hidden shrink-0"}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 text-foreground hover:bg-muted focus-visible:ring-accent",
		}) {
			@icon.PanelLeft(icon.Props{Class: "size-4"})
			<span class="sr-only">Toggle Sidebar</span>
		}
	}
}

templ dashboardSidebarFilterScript() {
	<script>
		(function() {
			document.addEventListener("input", function(event) {
				const input = event.target.closest("[data-dashboard-project-filter]");
				if (!input) {
					return;
				}
				const query = input.value.trim().toLowerCase();
				document.querySelectorAll("[data-dashboard-project-entry]").forEach(function(entry) {
					const name = (entry.dataset.projectName || "").toLowerCase();
					entry.hidden = query !== "" && !name.includes(query);
				});
			});
		})();
	</script>
}

templ dashboardSidebarProjectOrderScript() {
	<script>
		(function() {
			const storageKey = "detent.ui.projectOrder";
			const storageVersion = 1;
			let draggingProjectID = "";
			let pendingApplyFrame = 0;
			let observedSidebar = null;
			let sidebarObserver = null;

			function projectOrderStorage() {
				try {
					return window.localStorage;
				} catch (error) {
					return null;
				}
			}

			function projectList() {
				return document.querySelector("[data-dashboard-project-order-list]");
			}

			function projectEntries() {
				const list = projectList();
				if (!list) {
					return [];
				}
				return Array.from(list.children).filter(function(child) {
					return child instanceof HTMLElement && child.hasAttribute("data-dashboard-project-entry");
				});
			}

			function projectEntryFor(target) {
				if (!(target instanceof Element)) {
					return null;
				}
				return target.closest("[data-dashboard-project-entry]");
			}

			function sidebarWrapper() {
				return document.querySelector("[data-tui-sidebar-wrapper][data-tui-sidebar-id='dashboard-sidebar']");
			}

			function sidebarCollapsed() {
				const wrapper = sidebarWrapper();
				return Boolean(wrapper && wrapper.dataset.tuiSidebarState === "collapsed");
			}

			function projectFilterActive() {
				const input = document.querySelector("[data-dashboard-project-filter]");
				return input instanceof HTMLInputElement && input.value.trim() !== "";
			}

			function savedProjectOrder() {
				const store = projectOrderStorage();
				if (!store) {
					return [];
				}
				let parsed = null;
				try {
					parsed = JSON.parse(store.getItem(storageKey) || "");
				} catch (error) {
					return [];
				}
				if (!parsed || parsed.v !== storageVersion || !Array.isArray(parsed.order)) {
					return [];
				}
				const seen = new Set();
				return parsed.order.filter(function(id) {
					if (typeof id !== "string" || id.trim() === "" || seen.has(id)) {
						return false;
					}
					seen.add(id);
					return true;
				});
			}

			function currentProjectOrder() {
				return projectEntries().map(function(entry) {
					return entry.dataset.projectId || "";
				}).filter(Boolean);
			}

			function setManualOrderState(manual) {
				const list = projectList();
				if (list) {
					list.dataset.projectOrderManual = manual ? "true" : "false";
				}
				const reset = document.querySelector("[data-dashboard-project-order-reset]");
				if (reset instanceof HTMLButtonElement) {
					reset.disabled = !manual;
				}
			}

			function saveProjectOrder(order) {
				const store = projectOrderStorage();
				if (!store) {
					return;
				}
				store.setItem(storageKey, JSON.stringify({ v: storageVersion, order: order }));
				setManualOrderState(true);
			}

			function clearProjectOrder() {
				const store = projectOrderStorage();
				if (store) {
					store.removeItem(storageKey);
				}
				setManualOrderState(false);
			}

			function defaultProjectIndex(entry, fallback) {
				const index = Number(entry.dataset.projectDefaultIndex);
				return Number.isFinite(index) ? index : fallback;
			}

			function restoreDefaultOrder() {
				const list = projectList();
				if (!list) {
					return;
				}
				projectEntries().map(function(entry, index) {
					return { entry: entry, index: index, rank: defaultProjectIndex(entry, index) };
				}).sort(function(left, right) {
					return left.rank - right.rank || left.index - right.index;
				}).forEach(function(item) {
					list.appendChild(item.entry);
				});
			}

			function orderProjectNodes(order) {
				const list = projectList();
				if (!list || order.length === 0) {
					return;
				}
				const entries = projectEntries();
				const nodesByID = new Map();
				entries.forEach(function(entry) {
					const id = entry.dataset.projectId || "";
					if (id && !nodesByID.has(id)) {
						nodesByID.set(id, entry);
					}
				});
				const ordered = [];
				const orderedIDs = new Set();
				order.forEach(function(id) {
					const entry = nodesByID.get(id);
					if (!entry) {
						return;
					}
					ordered.push(entry);
					orderedIDs.add(id);
				});
				entries.forEach(function(entry) {
					const id = entry.dataset.projectId || "";
					if (!orderedIDs.has(id)) {
						ordered.push(entry);
					}
				});
				ordered.forEach(function(entry) {
					list.appendChild(entry);
				});
			}

			function reorderAvailable() {
				return projectEntries().length > 1 && !sidebarCollapsed() && !projectFilterActive();
			}

			function setButtonDisabled(button, disabled) {
				if (!(button instanceof HTMLButtonElement)) {
					return;
				}
				button.disabled = disabled;
				button.setAttribute("aria-disabled", disabled ? "true" : "false");
			}

			function updateProjectControls() {
				const list = projectList();
				const entries = projectEntries();
				const available = reorderAvailable();
				if (list) {
					list.dataset.projectOrderEnabled = available ? "true" : "false";
				}
				entries.forEach(function(entry, index) {
					entry.draggable = available;
					entry.setAttribute("aria-grabbed", draggingProjectID === entry.dataset.projectId ? "true" : "false");
					entry.dataset.projectOrderReady = available ? "true" : "false";
					setButtonDisabled(entry.querySelector("[data-dashboard-project-move='up']"), !available || index === 0);
					setButtonDisabled(entry.querySelector("[data-dashboard-project-move='down']"), !available || index === entries.length - 1);
				});
				setManualOrderState(savedProjectOrder().length > 0);
			}

			function observeSidebarState() {
				const wrapper = sidebarWrapper();
				if (wrapper === observedSidebar) {
					return;
				}
				if (sidebarObserver) {
					sidebarObserver.disconnect();
					sidebarObserver = null;
				}
				observedSidebar = wrapper;
				if (!wrapper || !("MutationObserver" in window)) {
					return;
				}
				sidebarObserver = new MutationObserver(function() {
					updateProjectControls();
				});
				sidebarObserver.observe(wrapper, { attributes: true, attributeFilter: ["data-tui-sidebar-state"] });
			}

			function applySavedProjectOrder() {
				if (draggingProjectID) {
					updateProjectControls();
					return;
				}
				const order = savedProjectOrder();
				if (order.length > 0) {
					orderProjectNodes(order);
				}
				updateProjectControls();
				observeSidebarState();
			}

			function scheduleApplySavedProjectOrder() {
				if (pendingApplyFrame) {
					return;
				}
				pendingApplyFrame = window.requestAnimationFrame(function() {
					pendingApplyFrame = 0;
					applySavedProjectOrder();
				});
			}

			function rowBeforePointer(clientY) {
				let candidate = null;
				let candidateOffset = Number.NEGATIVE_INFINITY;
				projectEntries().forEach(function(entry) {
					if (entry.dataset.projectId === draggingProjectID) {
						return;
					}
					const rect = entry.getBoundingClientRect();
					const offset = clientY - rect.top - rect.height / 2;
					if (offset < 0 && offset > candidateOffset) {
						candidateOffset = offset;
						candidate = entry;
					}
				});
				return candidate;
			}

			function clearDragState() {
				projectEntries().forEach(function(entry) {
					entry.classList.remove("dashboard-project-entry-dragging");
					entry.setAttribute("aria-grabbed", "false");
				});
				draggingProjectID = "";
				updateProjectControls();
			}

			function sidebarSwapTarget(event) {
				const detailTarget = event.detail && event.detail.target;
				const target = detailTarget instanceof Element ? detailTarget : event.target;
				if (!(target instanceof Element)) {
					return null;
				}
				if (target.id === "dashboard-sidebar-live") {
					return target;
				}
				return target.closest("#dashboard-sidebar-live");
			}

			function moveProject(entry, direction) {
				const list = projectList();
				const entries = projectEntries();
				const index = entries.indexOf(entry);
				if (!list || index < 0) {
					return;
				}
				if (direction === "up" && index > 0) {
					list.insertBefore(entry, entries[index - 1]);
				}
				if (direction === "down" && index < entries.length - 1) {
					list.insertBefore(entry, entries[index + 2] || null);
				}
				saveProjectOrder(currentProjectOrder());
				updateProjectControls();
				const button = entry.querySelector("[data-dashboard-project-move='" + direction + "']");
				if (button instanceof HTMLButtonElement) {
					button.focus();
				}
			}

			document.addEventListener("dragstart", function(event) {
				const target = event.target instanceof Element ? event.target : null;
				const entry = projectEntryFor(target);
				if (!entry) {
					return;
				}
				if (!reorderAvailable() || (target && target.closest("[data-dashboard-project-order-controls]"))) {
					event.preventDefault();
					return;
				}
				draggingProjectID = entry.dataset.projectId || "";
				if (!draggingProjectID) {
					event.preventDefault();
					return;
				}
				entry.classList.add("dashboard-project-entry-dragging");
				entry.setAttribute("aria-grabbed", "true");
				if (event.dataTransfer) {
					event.dataTransfer.effectAllowed = "move";
					event.dataTransfer.setData("text/plain", draggingProjectID);
				}
			});

			document.addEventListener("dragover", function(event) {
				if (!draggingProjectID || !reorderAvailable()) {
					return;
				}
				const list = projectList();
				const target = event.target instanceof Element ? event.target : null;
				if (!list || !target || (target !== list && !list.contains(target))) {
					return;
				}
				const dragged = projectEntries().find(function(entry) {
					return entry.dataset.projectId === draggingProjectID;
				});
				if (!dragged) {
					return;
				}
				event.preventDefault();
				const before = rowBeforePointer(event.clientY);
				if (before) {
					list.insertBefore(dragged, before);
				} else {
					list.appendChild(dragged);
				}
				updateProjectControls();
			});

			document.addEventListener("drop", function(event) {
				if (!draggingProjectID) {
					return;
				}
				event.preventDefault();
				saveProjectOrder(currentProjectOrder());
				clearDragState();
			});

			document.addEventListener("dragend", function() {
				if (draggingProjectID) {
					clearDragState();
				}
			});

			document.addEventListener("click", function(event) {
				const reset = event.target instanceof Element ? event.target.closest("[data-dashboard-project-order-reset]") : null;
				if (reset) {
					event.preventDefault();
					clearProjectOrder();
					restoreDefaultOrder();
					updateProjectControls();
					return;
				}
				const button = event.target instanceof Element ? event.target.closest("[data-dashboard-project-move]") : null;
				if (button instanceof HTMLButtonElement) {
					event.preventDefault();
					if (!reorderAvailable() || button.disabled) {
						return;
					}
					const entry = projectEntryFor(button);
					if (entry) {
						moveProject(entry, button.dataset.dashboardProjectMove || "");
					}
				}
			});

			document.addEventListener("input", function(event) {
				const input = event.target instanceof Element ? event.target.closest("[data-dashboard-project-filter]") : null;
				if (input) {
					updateProjectControls();
				}
			});

			document.addEventListener("htmx:beforeSwap", function(event) {
				if (draggingProjectID && sidebarSwapTarget(event)) {
					event.preventDefault();
				}
			});

			document.addEventListener("htmx:afterSettle", function() {
				scheduleApplySavedProjectOrder();
			});

			window.addEventListener("storage", function(event) {
				if (event.key === storageKey) {
					scheduleApplySavedProjectOrder();
				}
			});

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", applySavedProjectOrder);
			} else {
				applySavedProjectOrder();
			}
		})();
	</script>
}

templ dashboardSidebar(data DashboardShellData) {
	@sidebar.Sidebar(sidebar.Props{
		ID:          "dashboard-sidebar",
		Collapsible: sidebar.CollapsibleIcon,
		Collapsed:   data.SidebarCollapsed,
		Class:       "dashboard-sidebar text-sidebar-foreground",
	}) {
		@sidebar.Header(sidebar.HeaderProps{Class: "flex-row items-center justify-between border-b border-sidebar-border group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:justify-center"}) {
			<a class="inline-flex min-h-8 min-w-0 shrink-0 items-center gap-2 text-sidebar-foreground hover:text-sidebar-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sidebar-ring group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden" href="/" aria-label="Detent dashboard">
				<span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded bg-sidebar-accent font-semibold text-sidebar-accent-foreground">D</span>
				<span class="truncate text-sm font-semibold">Detent</span>
				if data.InstanceName != "" {
					<span class="max-w-[8rem] truncate rounded-full border border-sidebar-border bg-sidebar-accent px-2 py-0.5 font-mono text-xs font-medium text-sidebar-accent-foreground" aria-label="Instance name">{ data.InstanceName }</span>
				}
			</a>
			@sidebar.Trigger(sidebar.TriggerProps{
				Target: "dashboard-sidebar",
				Class:  "text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			})
		}
		@sidebar.Content(sidebar.ContentProps{
			ID:    "dashboard-sidebar-live",
			Class: "dashboard-sidebar-content",
			Attributes: templ.Attributes{
				"sse-swap": "sidebar",
				"hx-swap":  "morph:innerHTML",
			},
		}) {
			@DashboardSidebarContent(data)
		}
		@dashboardProjectOrderFooter()
	}
	@dashboardSidebarFilterScript()
	@dashboardSidebarProjectOrderScript()
}

templ dashboardProjectOrderFooter() {
	@sidebar.Footer(sidebar.FooterProps{Class: "border-t border-sidebar-border group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden"}) {
		@button.Button(button.Props{
			Variant:   button.VariantGhost,
			Size:      button.SizeSm,
			FullWidth: true,
			Class:     "justify-start px-2 text-xs text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			Attributes: templ.Attributes{
				"data-dashboard-project-order-reset": true,
				"aria-label":                         "Reset project order",
			},
		}) {
			@icon.RotateCcw(icon.Props{Class: "size-3.5 shrink-0"})
			<span>Reset order</span>
		}
	}
}

templ DashboardSidebarContent(data DashboardShellData) {
	@sidebar.Group() {
		@sidebar.Menu() {
			@sidebar.MenuItem() {
				@sidebar.MenuButton(sidebar.MenuButtonProps{
					Href:       "/",
					IsActive:   sidebarFleetActive(data),
					Tooltip:    sidebarFleetTooltip(data),
					Attributes: sidebarAriaCurrent(sidebarFleetActive(data)),
				}) {
					@icon.LayoutDashboard(icon.Props{Class: "size-4 shrink-0"})
					<span>Fleet</span>
				}
			}
		}
		if sidebarFilterVisible(data) {
			<label class="grid gap-1 px-2 group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden">
				<span class="sr-only">{ sidebarProjectSearchLabel(data) }</span>
				<input id="dashboard-project-filter" name="project_filter" type="search" class="min-h-9 rounded-md border border-sidebar-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-sidebar-ring focus:outline-none focus:ring-2 focus:ring-sidebar-ring" placeholder="Filter projects" data-dashboard-project-filter/>
			</label>
		}
		@sidebar.Menu(sidebar.MenuProps{
			Class: "dashboard-sidebar-projects",
			Attributes: templ.Attributes{
				"data-dashboard-project-order-list": true,
			},
		}) {
			for _, item := range sidebarProjectItems(data) {
				@sidebar.MenuItem(sidebar.MenuItemProps{
					Class:      "dashboard-project-entry",
					Attributes: sidebarProjectItemAttributes(item),
				}) {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       item.Href,
						IsActive:   item.Active,
						Tooltip:    sidebarProjectTooltip(item),
						Class:      "dashboard-project-menu-button",
						Attributes: sidebarProjectButtonAttributes(item),
					}) {
						if sidebarProjectOrderAvailable(data) {
							<span class="dashboard-project-drag-handle group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden" data-dashboard-project-drag-handle aria-hidden="true">
								@icon.GripVertical(icon.Props{Class: "size-3.5"})
							</span>
						}
						<span class={ "inline-flex size-2.5 shrink-0 rounded-full " + item.DotClass }></span>
						<span>{ item.Name }</span>
						@sidebar.MenuBadge(sidebar.MenuBadgeProps{Class: "font-mono " + item.BadgeClass}) {
							{ item.CountLabel }
						}
					}
					if sidebarProjectOrderAvailable(data) {
						@dashboardProjectOrderControls(item)
					}
				}
			}
		}
	}
	if projectSidebarNavVisible(data) {
		@sidebar.Separator()
		@sidebar.Group(sidebar.GroupProps{
			Attributes: templ.Attributes{
				"aria-label": "Project views",
			},
		}) {
			@sidebar.GroupLabel() {
				<span>Project views</span>
			}
			@sidebar.Menu() {
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarOverviewPath(data),
						IsActive:   projectSidebarOverviewActive(data),
						Tooltip:    "Project overview",
						Attributes: projectSidebarViewAttributes(data, "overview"),
					}) {
						@icon.LayoutDashboard(icon.Props{Class: "size-4 shrink-0"})
						<span>Overview</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarSectionPath(data, "project-kanban"),
						Tooltip:    "Project Kanban",
						Attributes: projectSidebarViewAttributes(data, "kanban"),
					}) {
						@icon.Kanban(icon.Props{Class: "size-4 shrink-0"})
						<span>Kanban</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarSectionPath(data, "running-issues"),
						Tooltip:    "Project runs",
						Attributes: projectSidebarViewAttributes(data, "runs"),
					}) {
						@icon.Activity(icon.Props{Class: "size-4 shrink-0"})
						<span>Runs</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       "/settings#settings-projects",
						Tooltip:    "Project configuration",
						Attributes: projectSidebarViewAttributes(data, "configuration"),
					}) {
						@icon.SlidersHorizontal(icon.Props{Class: "size-4 shrink-0"})
						<span>Configuration</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarSectionPath(data, "dashboard-diagnostics"),
						Tooltip:    "Project diagnostics",
						Attributes: projectSidebarViewAttributes(data, "diagnostics"),
					}) {
						@icon.Gauge(icon.Props{Class: "size-4 shrink-0"})
						<span>Diagnostics</span>
					}
				}
			}
		}
	}
	@sidebar.Separator()
	@sidebar.Group() {
		@sidebar.Menu() {
			@sidebar.MenuItem() {
				@sidebar.MenuButton(sidebar.MenuButtonProps{
					Href:       "/reports",
					IsActive:   sidebarStaticNavActive(data, "reports"),
					Tooltip:    "Reports",
					Attributes: sidebarAriaCurrent(sidebarStaticNavActive(data, "reports")),
				}) {
					@icon.ChartNoAxesCombined(icon.Props{Class: "size-4 shrink-0"})
					<span>Reports</span>
				}
			}
			@sidebar.MenuItem() {
				@sidebar.MenuButton(sidebar.MenuButtonProps{
					Href:       "/settings",
					IsActive:   sidebarStaticNavActive(data, "settings"),
					Tooltip:    "Settings",
					Attributes: sidebarAriaCurrent(sidebarStaticNavActive(data, "settings")),
				}) {
					@icon.Settings(icon.Props{Class: "size-4 shrink-0"})
					<span>Settings</span>
				}
			}
		}
	}
}

templ dashboardProjectOrderControls(item sidebarProjectItem) {
	<div class="dashboard-project-order-controls group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden" data-dashboard-project-order-controls>
		@button.Button(button.Props{
			Variant: button.VariantGhost,
			Size:    button.SizeIcon,
			Class:   "size-6 text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			Attributes: templ.Attributes{
				"data-dashboard-project-move": "up",
				"data-project-id":             item.ID,
				"aria-label":                  "Move " + item.Name + " up",
			},
		}) {
			@icon.ArrowUp(icon.Props{Class: "size-3.5"})
		}
		@button.Button(button.Props{
			Variant: button.VariantGhost,
			Size:    button.SizeIcon,
			Class:   "size-6 text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			Attributes: templ.Attributes{
				"data-dashboard-project-move": "down",
				"data-project-id":             item.ID,
				"aria-label":                  "Move " + item.Name + " down",
			},
		}) {
			@icon.ArrowDown(icon.Props{Class: "size-3.5"})
		}
	</div>
}

templ dashboardCharts(data DashboardData) {
	<section id="dashboard-charts" class="dashboard-chart-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label={ chartPanelTitle(data) } hx-preserve data-detent-charts data-chart-endpoint={ chartEndpoint(data) }>
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				<h2 class="text-base font-semibold text-foreground">{ chartPanelTitle(data) }</h2>
				<p class="text-sm text-muted-foreground">{ chartPanelDescription(data) }</p>
			</div>
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground">Chart.js</span>
		</div>
		<div class="mt-4 grid min-w-0 gap-3 lg:grid-cols-3">
			<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
				<div class="mb-2 flex items-center justify-between gap-3">
					<h3 class="truncate text-sm font-medium text-foreground">Running agents</h3>
				</div>
				<div class="h-56 min-w-0">
					<canvas id="running-agents-chart" data-chart="running-agents" aria-label="Running agents over time"></canvas>
				</div>
			</div>
			if isProjectDashboard(data) {
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Token spend</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="token-spend-chart" data-chart="token-spend" aria-label="Token spend trend"></canvas>
					</div>
				</div>
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Board flow</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="board-flow-chart" data-chart="board-flow" aria-label="Board state flow over time"></canvas>
					</div>
				</div>
			} else {
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Tokens/sec</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="tokens-per-second-chart" data-chart="tokens-per-second" aria-label="Tokens per second trend"></canvas>
					</div>
				</div>
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Completions</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="completions-chart" data-chart="completions" aria-label="Completions per project"></canvas>
					</div>
				</div>
			}
		</div>
	</section>
}

templ SnapshotView(data DashboardData) {
	@dashboardHealth(data)
	if isProjectDashboard(data) && data.ProjectPaused {
		<section class="rounded-md border border-warning bg-warning-soft p-4 text-warning shadow-sm" aria-label="Paused project">
			<div class="flex items-start gap-3">
				<span class="mt-1 h-2.5 w-2.5 rounded-full bg-warning"></span>
				<div class="min-w-0">
					<h2 class="text-sm font-semibold">{ projectDisplayName(data) } is paused.</h2>
					<p class="mt-1 text-sm text-warning">Detent will keep showing telemetry, but this project is not dispatching new work.</p>
				</div>
			</div>
		</section>
	}
	if data.Snapshot.GeneratedAt.IsZero() {
		@snapshotLoading()
	}
	@agentActivityTimeline(data.Snapshot)
	@statStrip(data.Snapshot)
	if !isProjectDashboard(data) {
		@projectSmallMultiplesSection(data)
	}
	if isProjectDashboard(data) {
		@projectKanbanSection(data, projectKanbanBoardView(data))
	}
	@prPipelineSection(data.Snapshot)
	<section class="dashboard-body-grid grid min-w-0 items-start gap-4 lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
		<div class="dashboard-primary-column grid min-w-0 content-start gap-4 lg:gap-5">
			<section id="running-issues" class="dashboard-panel scroll-mt-3 min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" tabindex="-1">
				<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
					<div class="min-w-0">
						@helpHeading2("Running issues", helpRunning, "running-issues")
						<p class="text-sm text-muted-foreground">Active Codex sessions and their latest known activity.</p>
					</div>
					<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ formatCount(runningCount(data.Snapshot)) }</span>
				</div>
				if len(data.Snapshot.Running) == 0 {
					<div class="mt-4">
						if runningCount(data.Snapshot) > 0 {
							@dashboardEmptyState("Running session details are unavailable.", "The summary count is live, but detailed agent rows have not arrived in this snapshot.", "bg-accent")
						} else {
							@dashboardEmptyState("No active issue sessions.", "New agent sessions will appear as Detent dispatches work.", "bg-accent")
						}
					</div>
				} else {
					<div class="mt-4 grid gap-3 sm:hidden">
						for i, row := range data.Snapshot.Running {
							@runningIssueMobileCard(row, i, data.Snapshot.GeneratedAt)
						}
					</div>
					<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
						<div class="overflow-x-auto" data-preserve-scroll="running-issues">
							<table class="dashboard-table w-full min-w-[76rem] table-fixed border-collapse text-sm">
								<thead class="bg-muted/70">
									<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
										<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
										<th class="w-[9rem] px-3 py-3 font-medium">State</th>
										<th class="w-[10rem] px-3 py-3 font-medium">
											@helpInlineLabel("Runtime / turns", helpAgeTurn, "running-table", "")
										</th>
										<th class="px-3 py-3 font-medium">
											@helpInlineLabel("Codex update", helpEvent, "running-table", "")
										</th>
										<th class="w-[8rem] px-3 py-3 font-medium">
											@helpInlineLabel("Diff", helpDiff, "running-table", "")
										</th>
										<th class="w-[10rem] px-3 py-3 font-medium">
											@helpInlineLabel("Tokens", helpTokens, "running-table", "")
										</th>
										<th class="w-[9rem] px-3 py-3 font-medium">
											@helpInlineLabel("Session", helpSession, "running-table", "")
										</th>
									</tr>
								</thead>
								<tbody>
									for i, row := range data.Snapshot.Running {
										<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
											<td class="px-3 py-4 align-top">
												@issueCell(row.Issue, "running", i, true)
											</td>
											<td class="px-3 py-4 align-top">
												<span class="inline-flex rounded-full bg-accent-soft px-2 py-1 font-medium text-accent">{ issueState(row.Issue, "Running") }</span>
											</td>
											<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ runningRuntime(row, data.Snapshot.GeneratedAt) }</td>
											<td class="px-3 py-4 align-top">
												@runningActivityCell(row, "running", i, data.Snapshot.GeneratedAt)
											</td>
											<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ formatDiffStat(row) }</td>
											<td class="px-3 py-4 align-top">
												<div class="grid gap-1 font-mono">
													<span class="font-medium text-foreground">{ formatTokens(row.Tokens) }</span>
													<span class="text-xs text-muted-foreground">{ formatTokenBreakdown(row.Tokens) }</span>
												</div>
											</td>
											<td class="px-3 py-4 align-top">
												@sessionCopyButton(row.SessionID)
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					</div>
				}
			</section>
			<section class="dashboard-section-grid grid min-w-0 gap-4 xl:grid-cols-2">
				@retryQueueSection(data.Snapshot)
				@blockedSessionsSection(data.Snapshot)
			</section>
			@recentSessionsSection(data.Snapshot)
		</div>
		<aside class="dashboard-aside-column grid min-w-0 content-start gap-4 lg:gap-5">
			@throughputCard(data)
			@rateLimitsCard(data.Snapshot.RateLimits)
			@graphQLBudgetCard(data)
			@tokenCard(data)
			@lifetimeCard(data.Snapshot.LifetimeTotals)
		</aside>
	</section>
	<section class="dashboard-analytics grid min-w-0 gap-4 lg:gap-5" aria-label="Dashboard analytics">
		@boardHealthSection(data.Snapshot)
		@cycleTimeSection(data.Snapshot.CycleTime)
		@budgetCard(data.Snapshot)
	</section>
}

templ projectSmallMultiplesSection(data DashboardData) {
	if len(projectSmallMultipleCards(data)) > 0 {
		<section class="min-w-0" aria-label="Fleet grid">
			<div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
				<div class="min-w-0">
					@helpHeading2("Fleet grid", helpProjectMultiples, "project-small-multiples")
					<p class="text-sm text-muted-foreground">Live running, queue, blocked, and token signals across configured projects.</p>
				</div>
				<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-muted px-2 py-1 text-sm font-medium text-muted-foreground">{ formatCount(len(projectSmallMultipleCards(data))) }</span>
			</div>
			<div class={ projectSmallMultiplesGridClass(projectSmallMultipleCards(data)) }>
				for _, card := range projectSmallMultipleCards(data) {
					@projectSmallMultipleCardView(card)
				}
			</div>
		</section>
	}
}

templ projectSmallMultipleCardView(card projectSmallMultipleCard) {
	<article class="dashboard-card min-w-0 rounded-md border border-border bg-card p-3 shadow-sm transition-colors hover:border-accent" aria-label={ card.Name + " project" }>
		<div class="flex min-w-0 items-start justify-between gap-3">
			<div class="min-w-0">
				<a class="block truncate text-sm font-semibold text-foreground hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.Href }>{ card.Name }</a>
				<p class="mt-1 truncate font-mono text-xs text-muted-foreground">{ card.ActivityLabel }</p>
			</div>
			<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 font-mono text-xs font-medium text-accent">{ card.ThroughputLabel }</span>
		</div>
		if card.ExternalURL != "" {
			<a class="mt-2 block truncate text-xs text-muted-foreground underline-offset-4 hover:text-accent hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.ExternalURL } target="_blank" rel="noopener noreferrer">{ card.ExternalURL }</a>
		}
		<div class="mt-3 grid grid-cols-4 gap-2 text-xs">
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Run</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.RunningLabel }</strong>
			</span>
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Queue</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.QueueLabel }</strong>
			</span>
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Blocked</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.BlockedLabel }</strong>
			</span>
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Sessions</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.CompletedLabel }</strong>
			</span>
		</div>
		<div class="mt-3 grid min-w-0 gap-3 sm:grid-cols-3">
			<div class="grid min-w-0 gap-1">
				<div class="flex items-center justify-between gap-2 text-xs">
					<span class="text-muted-foreground">Throughput</span>
					<span class="font-mono text-muted-foreground">{ card.ThroughputLabel }</span>
				</div>
				@SparklineChart(card.ThroughputChart)
			</div>
			<div class="grid min-w-0 gap-1">
				<div class="flex items-center justify-between gap-2 text-xs">
					<span class="text-muted-foreground">Spend</span>
					<span class="font-mono text-muted-foreground">{ card.SpendLabel }</span>
				</div>
				@SparklineChart(card.SpendChart)
			</div>
			<div class="grid min-w-0 gap-1">
				<div class="flex items-center justify-between gap-2 text-xs">
					<span class="text-muted-foreground">Queue</span>
					<span class="font-mono text-muted-foreground">{ card.QueueLabel }</span>
				</div>
				@SparklineChart(card.QueueChart)
			</div>
		</div>
	</article>
}

templ projectKanbanSection(data DashboardData, board projectKanbanBoard) {
	if len(board.AllLanes) > 0 {
		<section id="project-kanban" class="dashboard-panel project-kanban scroll-mt-3 min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Project Kanban" tabindex="-1">
			<div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
				<div class="min-w-0">
					<div class="inline-flex min-w-0 items-center gap-2">
						@icon.Kanban(icon.Props{Class: "size-5 shrink-0 text-accent"})
						@helpHeading2("Project Kanban", helpProjectKanban, "project-kanban")
					</div>
					if kanbanIntegrationEnabled(data) {
						<p class="text-sm text-muted-foreground">Workflow lanes grouped by configured Detent states with operator actions enabled.</p>
					} else {
						<p class="text-sm text-muted-foreground">Read-only workflow lanes grouped by configured Detent states.</p>
					}
				</div>
				<div class="flex shrink-0 flex-wrap items-center gap-2">
					if kanbanIntegrationEnabled(data) {
						<span class="inline-flex min-h-8 items-center rounded-full border border-success bg-success-soft px-2.5 py-1 text-xs font-semibold text-success">Integration</span>
					} else {
						<span class="inline-flex min-h-8 items-center rounded-full border border-accent-soft bg-accent-soft px-2.5 py-1 text-xs font-semibold text-accent">Read-only</span>
					}
					<span class="inline-flex min-h-8 items-center rounded-full bg-muted px-2.5 py-1 font-mono text-xs font-medium text-muted-foreground">{ board.TotalLabel } cards</span>
					if len(board.EmptyLanes) > 0 {
						<label for="project-kanban-show-empty" class="inline-flex min-h-8 cursor-pointer items-center gap-1.5 rounded-md border border-border bg-card px-2.5 py-1 text-xs font-medium text-muted-foreground hover:border-accent hover:text-accent focus-within:ring-2 focus-within:ring-accent">
							@icon.Eye(icon.Props{Class: "size-3.5 shrink-0"})
							<span>{ projectKanbanEmptyToggleLabel(board) }</span>
						</label>
					}
				</div>
			</div>
			if len(board.EmptyLanes) > 0 {
				<input id="project-kanban-show-empty" class="project-kanban-show-empty sr-only" type="checkbox" autocomplete="off" aria-label="Show empty Kanban lanes"/>
			}
			if kanbanIntegrationEnabled(data) {
				<div id="kanban-feedback" role="status" aria-live="polite" class="mt-3 rounded-md border border-border bg-muted/60 px-3 py-2 text-sm text-muted-foreground">Ready.</div>
			}
			<div class="project-kanban-lanes mt-4 grid min-w-0 gap-3 md:grid-cols-2 xl:grid-cols-4">
				for _, lane := range board.AllLanes {
					@projectKanbanLaneView(data, lane)
				}
			</div>
			if kanbanIntegrationEnabled(data) {
				@kanbanScript()
			}
		</section>
	}
}

templ projectKanbanLaneView(data DashboardData, lane projectKanbanLane) {
	<section class={ projectKanbanLaneClass(lane) } aria-label={ lane.Title + " lane" } data-project-kanban-lane={ lane.ID } { projectKanbanLaneAttributesForData(data, lane)... }>
		<div class="flex min-h-9 items-center justify-between gap-3">
			<div class="inline-flex min-w-0 items-center gap-2">
				<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
				<h3 class="truncate text-sm font-semibold text-foreground">{ lane.Title }</h3>
			</div>
			<span class="shrink-0 rounded-full bg-card px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ lane.CountLabel }</span>
		</div>
		if len(lane.Cards) == 0 {
			<div class="mt-3">
				@dashboardEmptyState("No issues in this state.", "This configured state is hidden until empty lanes are shown.", lane.DotClass)
			</div>
		} else {
			<div class="project-kanban-lane-scroll mt-3 grid max-h-[32rem] gap-2 overflow-y-auto pr-1" data-preserve-scroll={ "project-kanban-" + lane.ID }>
				for _, card := range lane.Cards {
					@projectKanbanCardView(data, card)
				}
			</div>
		}
	</section>
}

templ projectKanbanCardView(data DashboardData, card projectKanbanCard) {
	<article class="project-kanban-card project-kanban-card-compact min-w-0 rounded-md border border-border bg-card p-2 shadow-sm transition-colors hover:border-accent" aria-label={ "Kanban card " + card.IssueNumber + " " + card.Title } { projectKanbanCardAttributes(data, card)... }>
		<div class="flex min-w-0 items-center gap-2">
			<div class="min-w-0 flex-1">
				if card.URL != "" {
					<a class="flex min-w-0 items-baseline gap-1.5 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer" aria-label={ "Open issue " + card.IssueNumber + ": " + card.Title }>
						<span class="shrink-0 font-mono text-xs font-semibold text-accent">{ card.IssueNumber }</span>
						<span class="min-w-0 flex-1 truncate text-sm font-medium text-foreground" title={ card.Title }>{ card.Title }</span>
					</a>
				} else {
					<div class="flex min-w-0 items-baseline gap-1.5">
						<span class="shrink-0 font-mono text-xs font-semibold text-accent">{ card.IssueNumber }</span>
						<span class="min-w-0 flex-1 truncate text-sm font-medium text-foreground" title={ card.Title }>{ card.Title }</span>
					</div>
				}
			</div>
			<div class="flex max-w-[52%] shrink-0 items-center justify-end gap-1">
				<span class="inline-flex h-6 max-w-[7rem] items-center truncate rounded-full bg-muted px-1.5 py-0.5 font-mono text-xs text-muted-foreground" title={ card.Identifier }>{ card.Stage }</span>
				@projectKanbanPullRequestSignal(card)
			</div>
		</div>
		<div class="mt-1.5 flex min-w-0 flex-wrap items-center gap-1 text-[11px]">
			for _, chip := range projectKanbanCompactChips(card) {
				@projectKanbanCompactChipView(chip)
			}
		</div>
		if kanbanIntegrationEnabled(data) {
			@projectKanbanActionButtons(data, card)
		}
		@projectKanbanCardDetails(data, card)
	</article>
}

templ projectKanbanPullRequestSignal(card projectKanbanCard) {
	if card.HasPullRequest {
		if card.PRURL != "" {
			<a class="inline-flex h-6 max-w-[6rem] items-center truncate rounded-full bg-accent-soft px-1.5 py-0.5 font-mono text-xs font-medium text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.PRURL } target="_blank" rel="noopener noreferrer" aria-label={ "Open " + card.PullRequestLabel }>{ card.PullRequestLabel }</a>
		} else {
			<span class="inline-flex h-6 max-w-[6rem] items-center truncate rounded-full bg-accent-soft px-1.5 py-0.5 font-mono text-xs font-medium text-accent">{ card.PullRequestLabel }</span>
		}
	} else {
		<span class="inline-flex h-6 items-center rounded-full border border-border bg-muted px-1.5 py-0.5 text-xs font-medium text-muted-foreground">No PR</span>
	}
}

templ projectKanbanCompactChipView(chip projectKanbanCompactChip) {
	<span class={ "inline-flex h-5 max-w-full items-center truncate rounded-full border px-1.5 py-0.5 font-medium " + chip.Class } title={ chip.Title }>{ chip.Label }</span>
}

templ projectKanbanCardDetails(data DashboardData, card projectKanbanCard) {
	<details class="group mt-1.5 border-t border-border pt-1.5" data-kanban-card-details data-preserve-details={ projectKanbanControlID("project-kanban-details", card) }>
		<summary class="flex min-h-7 cursor-pointer list-none items-center justify-between gap-2 rounded-md px-1.5 py-1 text-xs font-medium text-muted-foreground hover:bg-muted/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" aria-label={ "Show details for " + card.IssueNumber }>
			<span class="inline-flex min-w-0 items-center gap-1.5">
				@icon.ListPlus(icon.Props{Class: "size-3.5 shrink-0"})
				<span class="truncate">Details</span>
			</span>
			@icon.ChevronDown(icon.Props{Class: "size-3.5 shrink-0"})
		</summary>
		<div class="mt-2 grid gap-2 text-xs" data-kanban-card-expanded>
			<div class="grid gap-1.5 rounded-md bg-muted/40 p-2">
				@projectKanbanDetailRow("Status", card.Stage, card.Identifier)
				@projectKanbanDetailRow("Time in stage", card.TimeInStage, card.TimeInStageTitle)
				if card.ProjectID != "" {
					@projectKanbanDetailRow("Project", card.ProjectID, card.ProjectID)
				}
				@projectKanbanDetailLink("Issue", card.Identifier, card.URL)
				if card.HasPullRequest {
					@projectKanbanDetailLink("Pull request", card.PullRequestLabel, card.PRURL)
					@projectKanbanDetailRow("CI", card.CIStatus, "Continuous integration status")
					@projectKanbanDetailRow("Codex review", card.CodexReviewState, "Codex review state")
				} else {
					@projectKanbanDetailRow("Pull request", card.PullRequestLabel, "")
				}
				if card.WaitDetail != "" {
					@projectKanbanDetailRow("Waits", card.WaitDetail, card.WaitDetail)
				}
			</div>
			if len(card.Labels) > 0 || len(card.Assignees) > 0 || len(card.Blockers) > 0 {
				<div class="grid gap-2">
					if len(card.Labels) > 0 {
						@projectKanbanPillRow("Labels", card.Labels)
					}
					if len(card.Assignees) > 0 {
						@projectKanbanPillRow("Assignees", card.Assignees)
					}
					if len(card.Blockers) > 0 {
						@projectKanbanPillRow("Blockers", card.Blockers)
					}
				</div>
			}
			if projectKanbanMoveDisabledText(data, card) != "" && kanbanIntegrationEnabled(data) {
				<div class="rounded-md border border-border bg-muted/60 px-3 py-2 text-sm text-muted-foreground">{ projectKanbanMoveDisabledText(data, card) }</div>
			}
		</div>
	</details>
}

templ projectKanbanDetailRow(label string, value string, title string) {
	if value != "" {
		<div class="flex min-w-0 items-center justify-between gap-2">
			<span class="shrink-0 text-muted-foreground">{ label }</span>
			<span class="min-w-0 truncate font-mono font-medium text-foreground" title={ title }>{ value }</span>
		</div>
	}
}

templ projectKanbanDetailLink(label string, value string, href string) {
	if value != "" {
		<div class="flex min-w-0 items-center justify-between gap-2">
			<span class="shrink-0 text-muted-foreground">{ label }</span>
			if href != "" {
				<a class="min-w-0 truncate font-mono font-medium text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ href } target="_blank" rel="noopener noreferrer">{ value }</a>
			} else {
				<span class="min-w-0 truncate font-mono font-medium text-foreground">{ value }</span>
			}
		</div>
	}
}

templ projectKanbanPillRow(label string, values []string) {
	<div class="grid gap-1">
		<span class="text-xs font-medium text-muted-foreground">{ label }</span>
		<div class="flex min-w-0 flex-wrap gap-1.5">
			for _, value := range values {
				<span class="inline-flex min-w-0 max-w-full truncate rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ value }>{ value }</span>
			}
		</div>
	</div>
}

templ projectKanbanActionButtons(data DashboardData, card projectKanbanCard) {
	<div class="mt-3 flex flex-wrap items-center gap-1.5" aria-label="Kanban actions">
		if projectKanbanCardCanMove(data, card) {
			@projectKanbanMoveDialogTrigger(data, card)
			@projectKanbanDragMoveForm(data, card)
		}
		@projectKanbanCommentDialogTriggers(data, card)
	</div>
}

templ projectKanbanMoveDialogTrigger(data DashboardData, card projectKanbanCard) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     projectKanbanMoveDialogPath(data, card),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": "Move " + card.IssueNumber,
				"title":      "Move card",
			},
		}) {
			@icon.MoveRight(icon.Props{Class: "size-4"})
			<span class="sr-only">Move</span>
		}
	}
}

templ projectKanbanDragMoveForm(data DashboardData, card projectKanbanCard) {
	<form class="hidden" hx-get="/api/v1/kanban/move" hx-target={ kanbanDialogTargetSelector() } hx-swap="innerHTML" data-kanban-drag-move-form>
		<input type="hidden" name="project_id" value={ kanbanProjectID(data) }/>
		<input type="hidden" name="issue_id" value={ card.IssueID }/>
		<input type="hidden" name="identifier" value={ card.Identifier }/>
		<input type="hidden" name="title" value={ card.Title }/>
		<input type="hidden" name="current_state" value={ card.Stage }/>
		<input type="hidden" name="target_state" value="" data-kanban-drag-target-state/>
		if card.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(card.PRNumber) }/>
		}
	</form>
}

templ projectKanbanCommentDialogTriggers(data DashboardData, card projectKanbanCard) {
	if card.IssueID != "" {
		@projectKanbanCommentDialogTrigger(data, card, "issue", "Comment on issue", "Issue comment")
	}
	if card.PRNumber > 0 && card.PRRepository != "" {
		@projectKanbanCommentDialogTrigger(data, card, "pr", "Comment on PR", "PR comment")
	}
}

templ projectKanbanCommentDialogTrigger(data DashboardData, card projectKanbanCard, target string, title string, label string) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     projectKanbanCommentDialogPath(data, card, target),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": title + " " + card.IssueNumber,
				"title":      label,
			},
		}) {
			if target == "pr" {
				@icon.GitPullRequest(icon.Props{Class: "size-4"})
			} else {
				@icon.MessageSquarePlus(icon.Props{Class: "size-4"})
			}
			<span class="sr-only">{ label }</span>
		}
	}
}

templ throughputCard(data DashboardData) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Token throughput", helpThroughput, "throughput-card")
			<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 font-mono text-xs font-medium text-accent">{ throughputRate(data.Snapshot) }</span>
		</div>
		<div class="mt-5 grid gap-2">
			<div class="break-all font-mono text-2xl font-semibold text-foreground sm:text-3xl">{ throughputRate(data.Snapshot) }</div>
			<div class="text-sm text-muted-foreground">{ throughputWindowLabel(data.Snapshot) }</div>
		</div>
		<div class="mt-5">
			if len(throughputTrendPoints(data.Snapshot)) == 0 {
				@dashboardEmptyState("No throughput data yet.", "Rolling token samples will appear after activity is recorded.", "bg-accent")
			} else {
				@LineAreaChart(throughputTrendChart(data))
			}
		</div>
	</section>
}

templ lifetimeCard(totals telemetry.LifetimeTotals) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Lifetime totals", helpLifetimeTotals, "lifetime-card")
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ lifetimeStatus(totals) }</span>
		</div>
		if !totals.Available {
			<div class="mt-4">
				@dashboardEmptyState("Lifetime totals unavailable.", lifetimeDegradedReason(totals), "bg-muted-foreground")
			</div>
		} else {
			<div class="mt-5 grid gap-3 text-sm">
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Tokens</span>
					<strong class="font-mono font-medium text-foreground">{ formatInt(totals.TotalTokens) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Input / output</span>
					<strong class="font-mono font-medium text-foreground">{ formatInt(totals.InputTokens) } / { formatInt(totals.OutputTokens) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Sessions</span>
					<strong class="font-mono font-medium text-foreground">{ lifetimeSessions(totals) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Runtime</span>
					<strong class="font-mono font-medium text-foreground">{ lifetimeRuntime(totals) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Runs</span>
					<strong class="font-mono font-medium text-foreground">{ lifetimeRuns(totals) }</strong>
				</div>
			</div>
		}
	</section>
}

templ LiveTick(timestamp time.Time) {
	<span class="font-mono">Updated { timestamp.UTC().Format("15:04:05 UTC") }</span>
}

templ dashboardHealth(data DashboardData) {
	<section id="dashboard-diagnostics" class="scroll-mt-3 flex flex-wrap items-center gap-2 rounded-md border border-border bg-card p-3 shadow-sm" aria-label="Dashboard health" tabindex="-1">
		<span class={ "inline-flex min-h-8 items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold " + runtimeStatusClass(data.Snapshot) } aria-label="Runtime status">
			<span class="h-2 w-2 rounded-full bg-current"></span>
			<span>{ runtimeStatusLabel(data.Snapshot) }</span>
		</span>
		<span class={ "inline-flex min-h-8 items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold " + statsStatusClass(data.Snapshot) } aria-label="Stats status" title={ statsStatusTitle(data.Snapshot) }>
			<span class="h-2 w-2 rounded-full bg-current"></span>
			<span>{ statsStatusLabel(data.Snapshot) }</span>
		</span>
		<span class="inline-flex min-h-8 max-w-full items-center gap-2 rounded-full border border-border bg-muted px-3 py-1 text-xs font-semibold text-muted-foreground sm:max-w-[24rem]" aria-label="Instance identity" title={ instanceLabel(data.Snapshot) }>
			<span>Instance</span>
			<span class="truncate font-medium text-foreground">{ instanceLabel(data.Snapshot) }</span>
		</span>
		<span class={ "inline-flex min-h-8 max-w-full items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold sm:max-w-[32rem] " + dashboardScopeClass(data) } aria-label="Dashboard scope" title={ dashboardScopeLabel(data) }>
			<span>Scope</span>
			<span class="truncate">{ dashboardScopeLabel(data) }</span>
		</span>
	</section>
}

templ snapshotLoading() {
	<section class="rounded-md border border-warning bg-warning-soft p-4 text-warning shadow-sm">
		<div class="flex items-start gap-3">
			<span class="mt-1 h-2.5 w-2.5 rounded-full bg-warning"></span>
			<div>
				<h2 class="text-sm font-semibold">Waiting for first telemetry snapshot.</h2>
				<p class="mt-1 text-sm text-warning">Live updates will fill this dashboard when Detent publishes the next snapshot.</p>
			</div>
		</div>
	</section>
}

templ metricCard(label string, term helpTerm, value string, detail string, borderClass string, dotClass string) {
	<article class={ "dashboard-metric-card min-w-0 rounded-md border border-border border-t-2 bg-card p-3 shadow-sm transition-colors hover:bg-muted/40 sm:p-4 " + borderClass }>
		<div class="flex items-start justify-between gap-3">
			<div class="grid min-w-0 gap-1">
				@helpInlineLabel(label, term, "dashboard", "text-sm font-medium text-muted-foreground")
				<span class="text-xs text-muted-foreground">{ detail }</span>
			</div>
			<span class={ "h-2.5 w-2.5 shrink-0 rounded-full " + dotClass }></span>
		</div>
		<div class="mt-4 break-all font-mono text-2xl font-semibold text-foreground sm:text-3xl">{ value }</div>
	</article>
}

templ statStrip(snapshot telemetry.Snapshot) {
	<section class="dashboard-stat-strip grid min-w-0 gap-2 rounded-md border border-border bg-card p-2 shadow-sm sm:grid-cols-2 lg:grid-cols-6" aria-label="Dashboard statistics">
		@statStripItem("Running", helpRunning, formatCount(runningCount(snapshot)), "Active issue sessions", "bg-accent")
		@statStripItem("Queue", helpQueue, formatCount(queueCount(snapshot)), "Waiting or retrying", "bg-warning")
		@statStripItem("Blocked", helpBlocked, formatCount(blockedCount(snapshot)), "Needs operator action", "bg-danger")
		@statStripItem("Completed", helpCompleted, formatCount(completedCount(snapshot)), "Finished sessions", "bg-success")
		@statStripItem("tps", helpThroughput, throughputRate(snapshot), "Rolling tokens/sec", "bg-accent")
		@statStripItem("Uptime", helpRuntime, runtimeLabel(snapshot), "Aggregate agent uptime", "bg-success")
	</section>
}

templ statStripItem(label string, term helpTerm, value string, detail string, dotClass string) {
	<div class="min-w-0 rounded-md bg-muted/60 px-3 py-2">
		<div class="flex min-w-0 items-center justify-between gap-2">
			@helpInlineLabel(label, term, "dashboard-stat-strip", "truncate text-xs font-medium uppercase text-muted-foreground")
			<span class={ "h-2 w-2 shrink-0 rounded-full " + dotClass }></span>
		</div>
		<div class="mt-1 truncate font-mono text-lg font-semibold text-foreground">{ value }</div>
		<div class="truncate text-xs text-muted-foreground">{ detail }</div>
	</div>
}

templ dashboardEmptyState(title string, detail string, dotClass string) {
	<div class="dashboard-empty-state rounded-md border border-dashed border-border bg-muted/60 px-3 py-3 text-left">
		<div class="flex items-start gap-3">
			<span class={ "mt-1.5 h-2 w-2 shrink-0 rounded-full " + dotClass }></span>
			<div class="min-w-0">
				<p class="text-sm font-medium text-foreground">{ title }</p>
				if detail != "" {
					<p class="mt-1 text-sm text-muted-foreground">{ detail }</p>
				}
			</div>
		</div>
	</div>
}

templ prPipelineSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Pull request pipeline">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("PR pipeline", helpPRPipeline, "pr-pipeline")
				<p class="text-sm text-muted-foreground">Live merge-train lanes for pull requests moving from review to integration.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ prPipelineTotalLabel(snapshot) }</span>
		</div>
		<div class="dashboard-section-grid mt-4 grid min-w-0 gap-3 lg:grid-cols-3">
			for _, lane := range prPipelineLanes(snapshot) {
				@prPipelineLaneView(lane)
			}
		</div>
	</section>
}

templ prPipelineLaneView(lane prPipelineLane) {
	<section class="pr-pipeline-lane min-w-0 rounded-md border border-border bg-muted/60 p-3" aria-label={ lane.Title + " lane" }>
		<div class="flex min-h-9 items-center justify-between gap-3">
			<div class="inline-flex min-w-0 items-center gap-2">
				<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
				<h3 class="truncate text-sm font-semibold text-foreground">{ lane.Title }</h3>
			</div>
			<span class="shrink-0 rounded-full bg-card px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ lane.CountLabel }</span>
		</div>
		if len(lane.Cards) == 0 {
			<div class="mt-3">
				@dashboardEmptyState(lane.EmptyTitle, lane.EmptyDetail, lane.DotClass)
			</div>
		} else {
			<div class="pr-pipeline-lane-scroll mt-3 grid max-h-[24rem] gap-2 overflow-y-auto pr-1" data-preserve-scroll={ "pr-pipeline-" + lane.ID }>
				for _, card := range lane.Cards {
					@prPipelineCardView(card)
				}
			</div>
		}
	</section>
}

templ prPipelineCardView(card prPipelineCard) {
	<article class="pr-pipeline-card min-w-0 rounded-md border border-border bg-card p-3 shadow-sm">
		<div class="flex min-w-0 items-start justify-between gap-3">
			<div class="min-w-0">
				if card.URL != "" {
					<a class="block min-w-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer">
						<span class="font-mono text-xs font-semibold text-accent">{ card.IssueNumber }</span>
						<span class="mt-1 line-clamp-2 text-sm font-medium text-foreground">{ card.Title }</span>
					</a>
				} else {
					<span class="font-mono text-xs font-semibold text-accent">{ card.IssueNumber }</span>
					<span class="mt-1 line-clamp-2 text-sm font-medium text-foreground">{ card.Title }</span>
				}
				if card.ProjectID != "" {
					<span class="mt-2 inline-flex max-w-full rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground">{ card.ProjectID }</span>
				}
			</div>
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ card.Identifier }>{ card.Stage }</span>
		</div>
		<div class="mt-3 grid gap-2 text-xs">
			<div class="flex flex-wrap gap-2">
				<span class={ "inline-flex min-h-7 items-center rounded-full border px-2 py-1 font-medium " + card.CIClass }>CI { card.CIStatus }</span>
				<span class={ "inline-flex min-h-7 items-center rounded-full border px-2 py-1 font-medium " + card.CodexReviewClass }>Codex { card.CodexReviewState }</span>
			</div>
			<div class="flex min-h-7 items-center justify-between gap-3 rounded-md bg-muted/60 px-2 py-1">
				<span class="text-muted-foreground">Time in stage</span>
				<span class="font-mono font-medium text-foreground" title={ card.TimeInStageTitle }>{ card.TimeInStage }</span>
			</div>
			if card.WaitDetail != "" {
				<div class="flex min-h-7 items-center justify-between gap-3 rounded-md bg-muted/60 px-2 py-1">
					<span class="text-muted-foreground">Waits</span>
					<span class="min-w-0 truncate font-mono font-medium text-foreground" title={ card.WaitDetail }>{ card.WaitDetail }</span>
				</div>
			}
		</div>
	</article>
}

templ kanbanBoardSection(data DashboardData) {
	if len(kanbanLanes(data)) > 0 {
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Kanban board" data-kanban-board>
			<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
				<div class="min-w-0">
					<h2 class="text-base font-semibold text-foreground">Kanban board</h2>
				</div>
				<span class="inline-flex min-h-9 shrink-0 items-center justify-center rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ data.Kanban.Mode }</span>
			</div>
			if kanbanIntegrationEnabled(data) {
				<div id="kanban-feedback" role="status" aria-live="polite" class="mt-3 rounded-md border border-border bg-muted/60 px-3 py-2 text-sm text-muted-foreground">Ready.</div>
			}
			<div class="mt-4 grid min-w-0 gap-3 lg:grid-cols-3">
				for _, lane := range kanbanLanes(data) {
					@kanbanLaneView(data, lane)
				}
			</div>
			if kanbanIntegrationEnabled(data) {
				@kanbanScript()
			}
		</section>
	}
}

templ kanbanLaneView(data DashboardData, lane kanbanLane) {
	<section class="min-w-0 rounded-md border border-border bg-muted/60 p-3" aria-label={ lane.State + " Kanban lane" } { kanbanLaneAttributes(data, lane)... }>
		<div class="flex min-h-9 items-center justify-between gap-3">
			<div class="inline-flex min-w-0 items-center gap-2">
				<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
				<h3 class="truncate text-sm font-semibold text-foreground">{ lane.State }</h3>
			</div>
			<span class="shrink-0 rounded-full bg-card px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ lane.CountLabel }</span>
		</div>
		if len(lane.Cards) == 0 {
			<div class="mt-3">
				@dashboardEmptyState("No cards in this state.", "", lane.DotClass)
			</div>
		} else {
			<div class="mt-3 grid max-h-[28rem] gap-2 overflow-y-auto pr-1" data-preserve-scroll={ "kanban-" + lane.State }>
				for _, card := range lane.Cards {
					@kanbanCardView(data, card)
				}
			</div>
		}
	</section>
}

templ kanbanCardView(data DashboardData, card kanbanCard) {
	<article class="min-w-0 rounded-md border border-border bg-card p-3 shadow-sm" { kanbanCardAttributes(data, card)... }>
		<div class="flex min-w-0 items-start justify-between gap-3">
			<div class="min-w-0">
				if card.URL != "" {
					<a class="block min-w-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer">
						<span class="font-mono text-xs font-semibold text-accent">{ card.Identifier }</span>
						<span class="mt-1 line-clamp-2 text-sm font-medium text-foreground">{ card.Title }</span>
					</a>
				} else {
					<span class="font-mono text-xs font-semibold text-accent">{ card.Identifier }</span>
					<span class="mt-1 line-clamp-2 text-sm font-medium text-foreground">{ card.Title }</span>
				}
			</div>
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ card.State }</span>
		</div>
		if card.ProjectID != "" || card.PRNumber > 0 {
			<div class="mt-2 flex flex-wrap gap-2">
				if card.ProjectID != "" {
					<span class="inline-flex max-w-full rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground">{ card.ProjectID }</span>
				}
				if card.PRNumber > 0 {
					if card.PRURL != "" {
						<a class="inline-flex max-w-full rounded-full bg-accent-soft px-2 py-1 font-mono text-xs text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.PRURL } target="_blank" rel="noopener noreferrer">PR #{ strconv.Itoa(card.PRNumber) }</a>
					} else {
						<span class="inline-flex max-w-full rounded-full bg-accent-soft px-2 py-1 font-mono text-xs text-accent">PR #{ strconv.Itoa(card.PRNumber) }</span>
					}
				}
			</div>
		}
		if kanbanMoveDisabledText(data, card) != "" {
			<div class="mt-3 rounded-md border border-border bg-muted/60 px-3 py-2 text-sm text-muted-foreground">{ kanbanMoveDisabledText(data, card) }</div>
		}
		if kanbanIntegrationEnabled(data) {
			@kanbanActionButtons(data, card)
		}
	</article>
}

templ kanbanActionButtons(data DashboardData, card kanbanCard) {
	<div class="mt-3 flex flex-wrap items-center gap-1.5" aria-label="Kanban actions">
		if kanbanCardCanMove(data, card) {
			@kanbanMoveDialogTrigger(data, card)
			@kanbanDragMoveForm(data, card)
		}
		@kanbanCommentDialogTriggers(data, card)
	</div>
}

templ kanbanMoveDialogTrigger(data DashboardData, card kanbanCard) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     kanbanMoveDialogPath(data, card),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": "Move " + card.Identifier,
				"title":      "Move card",
			},
		}) {
			@icon.MoveRight(icon.Props{Class: "size-4"})
			<span class="sr-only">Move</span>
		}
	}
}

templ kanbanDragMoveForm(data DashboardData, card kanbanCard) {
	<form class="hidden" hx-get="/api/v1/kanban/move" hx-target={ kanbanDialogTargetSelector() } hx-swap="innerHTML" data-kanban-drag-move-form>
		<input type="hidden" name="project_id" value={ kanbanProjectID(data) }/>
		<input type="hidden" name="issue_id" value={ card.IssueID }/>
		<input type="hidden" name="identifier" value={ card.Identifier }/>
		<input type="hidden" name="title" value={ card.Title }/>
		<input type="hidden" name="current_state" value={ card.State }/>
		<input type="hidden" name="target_state" value="" data-kanban-drag-target-state/>
		if card.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(card.PRNumber) }/>
		}
	</form>
}

templ kanbanCommentDialogTriggers(data DashboardData, card kanbanCard) {
	if card.IssueID != "" {
		@kanbanCommentDialogTrigger(data, card, "issue", "Comment on issue", "Issue comment")
	}
	if card.PRNumber > 0 && card.PRRepository != "" {
		@kanbanCommentDialogTrigger(data, card, "pr", "Comment on PR", "PR comment")
	}
}

templ kanbanCommentDialogTrigger(data DashboardData, card kanbanCard, target string, title string, label string) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     kanbanCommentDialogPath(data, card, target),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": title + " " + card.Identifier,
				"title":      label,
			},
		}) {
			if target == "pr" {
				@icon.GitPullRequest(icon.Props{Class: "size-4"})
			} else {
				@icon.MessageSquarePlus(icon.Props{Class: "size-4"})
			}
			<span class="sr-only">{ label }</span>
		}
	}
}

templ KanbanMoveDialogContent(data KanbanMoveDialogData) {
	@dialog.Header() {
		@dialog.Title() {
			Move card
		}
		@dialog.Description() {
			{ kanbanDialogCardLabel(data.Identifier, data.Title) }
		}
	}
	@kanbanDialogError(data.Error)
	<form class="grid gap-4" hx-post="/api/v1/kanban/move" hx-target="#kanban-feedback" hx-swap="outerHTML">
		<input type="hidden" name="kanban_dialog" value="true"/>
		<input type="hidden" name="project_id" value={ data.ProjectID }/>
		<input type="hidden" name="issue_id" value={ data.IssueID }/>
		<input type="hidden" name="current_state" value={ data.CurrentState }/>
		<input type="hidden" name="identifier" value={ data.Identifier }/>
		<input type="hidden" name="title" value={ data.Title }/>
		if data.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(data.PRNumber) }/>
		}
		<div class="grid gap-2">
			<label class="text-sm font-medium text-foreground" for="kanban-dialog-target-state">Target state</label>
			<select id="kanban-dialog-target-state" name="target_state" class="min-h-10 w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent" data-kanban-status-menu>
				for _, state := range data.States {
					<option value={ state } selected?={ normalizeDashboardState(state) == normalizeDashboardState(kanbanMoveDialogTargetState(data)) }>{ state }</option>
				}
			</select>
		</div>
		@dialog.Footer() {
			@dialog.Close() {
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Type:    button.TypeButton,
				}) {
					Cancel
				}
			}
			@button.Button(button.Props{Type: button.TypeSubmit}) {
				@icon.MoveRight(icon.Props{Class: "size-4"})
				Move
			}
		}
	</form>
}

templ KanbanCommentDialogContent(data KanbanCommentDialogData) {
	@dialog.Header() {
		@dialog.Title() {
			Comment on { kanbanCommentTargetLabel(data.Target) }
		}
		@dialog.Description() {
			{ kanbanDialogCardLabel(data.Identifier, data.Title) }
		}
	}
	@kanbanDialogError(data.Error)
	<form class="grid gap-4" hx-post="/api/v1/kanban/comment" hx-target="#kanban-feedback" hx-swap="outerHTML">
		<input type="hidden" name="kanban_dialog" value="true"/>
		<input type="hidden" name="project_id" value={ data.ProjectID }/>
		<input type="hidden" name="target" value={ data.Target }/>
		<input type="hidden" name="identifier" value={ data.Identifier }/>
		<input type="hidden" name="title" value={ data.Title }/>
		if data.Target == "issue" {
			<input type="hidden" name="issue_id" value={ data.IssueID }/>
		}
		if data.Target == "pr" {
			<input type="hidden" name="pr_repository" value={ data.PRRepository }/>
			<input type="hidden" name="pr_number" value={ strconv.Itoa(data.PRNumber) }/>
		}
		<div class="grid gap-2">
			<label class="text-sm font-medium text-foreground" for="kanban-dialog-comment-body">Comment</label>
			<textarea id="kanban-dialog-comment-body" name="body" rows="5" class="min-h-32 w-full resize-y rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent" placeholder={ kanbanCommentTargetLabel(data.Target) + " comment" }>{ data.Body }</textarea>
		</div>
		@dialog.Footer() {
			@dialog.Close() {
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Type:    button.TypeButton,
				}) {
					Cancel
				}
			}
			@button.Button(button.Props{Type: button.TypeSubmit}) {
				@icon.MessageSquarePlus(icon.Props{Class: "size-4"})
				Comment
			}
		}
	</form>
}

templ KanbanDialogErrorContent(message string) {
	@dialog.Header() {
		@dialog.Title() {
			Kanban action unavailable
		}
	}
	@kanbanDialogError(message)
	@dialog.Footer() {
		@dialog.Close() {
			@button.Button(button.Props{Variant: button.VariantOutline}) {
				Close
			}
		}
	}
}

templ kanbanDialogError(message string) {
	if message != "" {
		<div role="alert" class="rounded-md border border-danger bg-danger-soft px-3 py-2 text-sm text-danger">{ message }</div>
	}
}

templ kanbanScript() {
	<script>
		(function() {
			if (window.__detentKanbanDragHandlersRegistered) {
				return;
			}
			window.__detentKanbanDragHandlersRegistered = true;

			let draggedIssueID = "";
			let dropped = false;

			function feedback(message) {
				const target = document.getElementById("kanban-feedback");
				if (target) {
					target.textContent = message;
				}
			}

			function draggedCard() {
				if (!draggedIssueID || !window.CSS || typeof CSS.escape !== "function") {
					return null;
				}
				return document.querySelector("[data-kanban-card][data-kanban-issue-id='" + CSS.escape(draggedIssueID) + "']");
			}

			function allowedTargetKeys(card) {
				if (!(card instanceof HTMLElement)) {
					return [];
				}
				return (card.dataset.kanbanAllowedTargets || "").split(/\s+/).filter(Boolean);
			}

			function laneAllowed(card, lane) {
				if (!(lane instanceof HTMLElement)) {
					return false;
				}
				const key = lane.dataset.kanbanDropKey || "";
				return key !== "" && allowedTargetKeys(card).includes(key);
			}

			function setDropTargetState(card) {
				document.querySelectorAll("[data-kanban-drop-state]").forEach(function(lane) {
					if (!(lane instanceof HTMLElement)) {
						return;
					}
					const allowed = laneAllowed(card, lane);
					lane.dataset.kanbanDropAllowed = allowed ? "true" : "false";
					lane.setAttribute("aria-disabled", allowed ? "false" : "true");
				});
			}

			function clearDropTargetState() {
				document.querySelectorAll("[data-kanban-drop-state]").forEach(function(lane) {
					if (!(lane instanceof HTMLElement)) {
						return;
					}
					delete lane.dataset.kanbanDropAllowed;
					lane.removeAttribute("aria-disabled");
				});
			}

			function openActionDialog() {
				if (window.tui && window.tui.dialog) {
					window.tui.dialog.open("kanban-action-dialog");
				}
			}

			function closeActionDialog() {
				if (window.tui && window.tui.dialog) {
					window.tui.dialog.close("kanban-action-dialog");
				}
				const content = document.getElementById("kanban-dialog-content");
				if (content) {
					content.replaceChildren();
				}
			}

			document.addEventListener("dragstart", function(event) {
				const card = event.target instanceof Element ? event.target.closest("[data-kanban-card]") : null;
				if (!card || card.getAttribute("draggable") !== "true") {
					return;
				}
				draggedIssueID = card.dataset.kanbanIssueId || "";
				dropped = false;
				if (!draggedIssueID) {
					event.preventDefault();
					return;
				}
				if (event.dataTransfer) {
					event.dataTransfer.effectAllowed = "move";
					event.dataTransfer.setData("text/plain", draggedIssueID);
				}
				setDropTargetState(card);
				feedback("Moving " + (card.dataset.kanbanCurrentState || "card") + ".");
			});

			document.addEventListener("dragover", function(event) {
				if (!draggedIssueID) {
					return;
				}
				const lane = event.target instanceof Element ? event.target.closest("[data-kanban-drop-state]") : null;
				if (lane && laneAllowed(draggedCard(), lane)) {
					event.preventDefault();
				}
			});

			document.addEventListener("drop", function(event) {
				if (!draggedIssueID) {
					return;
				}
				const lane = event.target instanceof Element ? event.target.closest("[data-kanban-drop-state]") : null;
				if (!lane) {
					return;
				}
				event.preventDefault();
				const card = draggedCard();
				if (!laneAllowed(card, lane)) {
					feedback("Move blocked by transition policy.");
					dropped = true;
					return;
				}
				const form = card ? card.querySelector("[data-kanban-drag-move-form]") : null;
				const targetState = form ? form.querySelector("[data-kanban-drag-target-state]") : null;
				if (!(form instanceof HTMLFormElement) || !(targetState instanceof HTMLInputElement)) {
					feedback("Move cancelled.");
					return;
				}
				targetState.value = lane.dataset.kanbanDropState || "";
				dropped = true;
				openActionDialog();
				form.requestSubmit();
			});

			document.addEventListener("dragend", function() {
				if (draggedIssueID && !dropped) {
					feedback("Move cancelled.");
				}
				draggedIssueID = "";
				dropped = false;
				clearDropTargetState();
			});

			document.body.addEventListener("kanbanActionSucceeded", closeActionDialog);
		})();
	</script>
}

templ runningIssueMobileCard(row telemetry.Running, rowIndex int, generatedAt time.Time) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "running-mobile", rowIndex, true)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">State</span>
				<span class="rounded-full bg-accent-soft px-2 py-1 font-medium text-accent">{ issueState(row.Issue, "Running") }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Runtime / turns", helpAgeTurn, "running-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ runningRuntime(row, generatedAt) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Diff", helpDiff, "running-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ formatDiffStat(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Tokens", helpTokens, "running-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ formatTokens(row.Tokens) }</span>
			</div>
		</div>
		<div class="mt-3">
			@runningActivityCell(row, "running-mobile", rowIndex, generatedAt)
		</div>
		<div class="mt-3">
			@sessionCopyButton(row.SessionID)
		</div>
	</article>
}

templ runningActivityCell(row telemetry.Running, prefix string, rowIndex int, generatedAt time.Time) {
	<div
		class="running-activity relative"
		data-popover
		data-running-activity
	>
		<button
			type="button"
			class="running-activity-trigger -m-2 grid w-full gap-1 rounded-md p-2 text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
			aria-describedby={ runningActivityID(prefix, rowIndex) }
			aria-expanded="false"
			data-popover-trigger
			data-running-activity-trigger
		>
			<span class="line-clamp-2 text-foreground">{ lastCodexUpdate(row) }</span>
			<span class="font-mono text-xs text-muted-foreground">{ lastCodexMeta(row) }</span>
		</button>
		@runningActivityPanel(row, prefix, rowIndex, generatedAt)
	</div>
}

templ runningActivityPanel(row telemetry.Running, prefix string, rowIndex int, generatedAt time.Time) {
	<div
		id={ runningActivityID(prefix, rowIndex) }
		class="popover-panel running-activity-panel"
		aria-hidden="true"
		data-popover-interactive="true"
		data-popover-panel
		data-popover-width="448"
		data-running-activity-panel
		role="tooltip"
	>
		<div class="grid gap-4">
			<div class="grid gap-1">
				<span class="text-xs font-medium uppercase text-muted-foreground">Latest message</span>
				<p class="whitespace-pre-wrap break-words text-sm text-foreground">{ lastCodexUpdate(row) }</p>
				<p class="font-mono text-xs text-muted-foreground">{ lastCodexMeta(row) }</p>
			</div>
			<div class="grid gap-2">
				<span class="text-xs font-medium uppercase text-muted-foreground">Recent activity</span>
				if len(runningActivityRows(row)) == 0 {
					<p class="rounded-md border border-dashed border-border bg-muted/60 px-3 py-3 text-sm text-muted-foreground">No activity recorded.</p>
				} else {
					<ol class="grid gap-2">
						for _, activity := range runningActivityRows(row) {
							<li class="rounded-md bg-muted/60 px-3 py-2">
								<div class="flex flex-wrap items-center justify-between gap-2">
									<span class="font-mono text-xs text-muted-foreground">{ activity.At }</span>
									<span class="font-mono text-xs font-medium text-accent">{ activity.Event }</span>
								</div>
								<p class="mt-1 whitespace-pre-wrap break-words text-sm text-foreground">{ activity.Message }</p>
							</li>
						}
					</ol>
				}
			</div>
			<div class="grid gap-2 border-t border-border pt-3">
				<span class="text-xs font-medium uppercase text-muted-foreground">Turn / tokens / runtime</span>
				<div class="grid gap-2 sm:grid-cols-3">
					<div class="rounded-md bg-muted/60 px-3 py-2">
						<span class="block text-xs text-muted-foreground">Turn</span>
						<strong class="font-mono text-sm font-medium text-foreground">{ runningTurnLabel(row) }</strong>
					</div>
					<div class="rounded-md bg-muted/60 px-3 py-2">
						<span class="block text-xs text-muted-foreground">Tokens</span>
						<strong class="font-mono text-sm font-medium text-foreground">{ formatTokens(row.Tokens) }</strong>
						<span class="block font-mono text-xs text-muted-foreground">{ formatTokenBreakdown(row.Tokens) }</span>
					</div>
					<div class="rounded-md bg-muted/60 px-3 py-2">
						<span class="block text-xs text-muted-foreground">Runtime</span>
						<strong class="font-mono text-sm font-medium text-foreground">{ runningRuntimeOnly(row, generatedAt) }</strong>
					</div>
				</div>
			</div>
		</div>
	</div>
}

templ boardHealthSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Board health">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Board health", helpBoardHealth, "board-health")
				<p class="text-sm text-muted-foreground">Current issue state distribution and completed session history from the latest snapshot.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ boardStateTotalLabel(snapshot) }</span>
		</div>
		<div class="mt-5 grid min-w-0 gap-5 lg:grid-cols-[minmax(0,1fr)_20rem]">
			<div class="min-w-0">
				<div class="flex items-center justify-between gap-3">
					@helpHeading3("Current issue states", helpStateDistribution, "board-health")
					<span class="font-mono text-xs text-muted-foreground">{ boardStateTotalLabel(snapshot) } issues</span>
				</div>
				if len(boardStateRows(snapshot)) == 0 {
					<div class="mt-3">
						@dashboardEmptyState("No board states recorded.", "Project state distribution will appear after the next tracker snapshot.", "bg-accent")
					</div>
				} else {
					<div class="mt-3">
						@TimelineChart(boardDistributionChart(snapshot))
					</div>
					<div class="mt-4 grid gap-2 sm:grid-cols-2">
						for _, row := range boardStateRows(snapshot) {
							<div class="flex min-w-0 items-center justify-between gap-3 rounded-md bg-muted/60 px-3 py-2">
								<span class="inline-flex min-w-0 items-center gap-2">
									<span class={ "h-2 w-2 shrink-0 rounded-full " + row.DotClass }></span>
									<span class="truncate text-sm font-medium text-foreground">{ row.State }</span>
								</span>
								<span class="shrink-0 font-mono text-sm text-muted-foreground">{ row.CountLabel } / { row.Percent }</span>
							</div>
						}
					</div>
				}
			</div>
			<div class="min-w-0">
				<div class="flex items-center justify-between gap-3">
					@helpHeading3("Session completions", helpCumulativeFlow, "board-health")
					<span class="font-mono text-xs text-muted-foreground">{ boardProgressCount(snapshot) } sessions</span>
				</div>
				if len(telemetry.BoardProgressPoints(snapshot)) == 0 {
					<div class="mt-3">
						@dashboardEmptyState("No completed session history yet.", "Session completion progress appears after completed session samples arrive.", "bg-success")
					</div>
				} else {
					<div class="mt-3">
						@LineAreaChart(boardProgressChart(snapshot))
					</div>
				}
			</div>
		</div>
	</section>
}

templ cycleTimeSection(report telemetry.CycleTimeReport) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Cycle time">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Cycle time", helpCycleTime, "cycle-time")
				<p class="text-sm text-muted-foreground">Completed issue durations from local run history.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-success-soft px-2 py-1 text-sm font-medium text-success">{ cycleTimeCountLabel(report) }</span>
		</div>
		if !report.Available && report.DegradedReason != "" {
			<div class="mt-4">
				@dashboardEmptyState("Cycle-time data unavailable.", cycleTimeUnavailableDetail(report), "bg-muted-foreground")
			</div>
		} else if len(report.Buckets) == 0 {
			<div class="mt-4">
				@dashboardEmptyState("No completed issues yet.", "Cycle-time histogram appears after completed issue history is recorded.", "bg-success")
			</div>
		} else {
			<div class="mt-5 grid min-w-0 gap-5 lg:grid-cols-[minmax(0,1fr)_18rem]">
				<div class="min-w-0">
					<div class="flex items-center justify-between gap-3">
						@helpHeading3("Histogram", helpCycleTime, "cycle-time")
						<span class="font-mono text-xs text-muted-foreground">{ cycleTimeCountLabel(report) }</span>
					</div>
					<div class="mt-3">
						@MiniBarChart(cycleTimeHistogramChart(report))
					</div>
				</div>
				<div class="grid min-w-0 content-start gap-3">
					<div class="rounded-md bg-muted/60 px-3 py-2">
						<span class="block text-xs font-medium uppercase text-muted-foreground">Average</span>
						<strong class="font-mono text-lg font-semibold text-foreground">{ cycleTimeAverageLabel(report) }</strong>
					</div>
					<div class="grid gap-2">
						for _, row := range cycleTimeBucketRows(report) {
							<div class="flex min-w-0 items-center justify-between gap-3 rounded-md bg-muted/60 px-3 py-2 text-sm">
								<span class="truncate font-medium text-foreground">{ row.Label }</span>
								<span class="shrink-0 font-mono text-muted-foreground">{ row.Count }</span>
							</div>
						}
					</div>
				</div>
			</div>
		}
	</section>
}

templ agentActivityTimeline(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Agent activity timeline">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Agent activity", helpAgentActivity, "agent-activity")
				<p class="text-sm text-muted-foreground">Live timeline of running and recently completed Codex sessions.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ formatCount(len(agentTimelineRows(snapshot))) }</span>
		</div>
		if len(agentTimelineRows(snapshot)) == 0 {
			if runningCount(snapshot)+completedCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Agent timeline details are unavailable.", "Summary counts are live, but session timing rows have not arrived in this snapshot.", "bg-accent")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No agent activity recorded.", "Running and completed session timelines will appear here.", "bg-accent")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for _, row := range agentTimelineRows(snapshot) {
					@agentActivityMobileCard(row)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="dashboard-agent-scroll max-h-[32rem] overflow-x-auto overflow-y-auto" data-preserve-scroll="agent-activity">
					<div class="min-w-[68rem]">
						<div class="grid grid-cols-[18rem_minmax(0,1fr)_12rem] gap-3 border-b border-border bg-muted/70 px-3 py-3 text-xs font-medium uppercase text-muted-foreground">
							<span>Agent</span>
							<span>Lifespan</span>
							<span class="text-right">State / runtime</span>
						</div>
						for _, row := range agentTimelineRows(snapshot) {
							<div class="agent-activity-table-row grid min-h-14 grid-cols-[18rem_minmax(0,1fr)_12rem] items-center gap-3 border-b border-border px-3 py-3 last:border-b-0">
								<div class="min-w-0">
									<span class="block truncate font-medium text-foreground">{ row.Identifier }</span>
									<span class="line-clamp-1 text-sm text-muted-foreground">{ row.Title }</span>
								</div>
								<div class="grid gap-1">
									<div class="flex items-center justify-between gap-3 font-mono text-xs text-muted-foreground">
										<span>{ row.StartedAt }</span>
										<span>{ row.EndedAt }</span>
									</div>
									<div class="relative h-9 overflow-hidden rounded-md bg-muted" role="group" aria-label={ row.Identifier + " lifespan" }>
										for _, segment := range row.Segments {
											<span class={ "absolute bottom-1 top-1 min-w-1.5 rounded " + segment.Class } style={ segment.Style } title={ segment.Title } aria-label={ segment.Title }>
												<span class="sr-only">{ segment.Title }</span>
											</span>
										}
									</div>
								</div>
								<div class="grid justify-items-end gap-1">
									<span class="rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ row.State }</span>
									<span class="font-mono text-xs text-muted-foreground">{ row.Duration }</span>
								</div>
							</div>
						}
					</div>
				</div>
			</div>
		}
	</section>
}

templ agentActivityMobileCard(row agentTimelineRow) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0">
				<span class="block truncate font-medium text-foreground">{ row.Identifier }</span>
				<span class="line-clamp-2 text-sm text-muted-foreground">{ row.Title }</span>
			</div>
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ row.State }</span>
		</div>
		<div class="mt-3 grid gap-1">
			<div class="flex items-center justify-between gap-3 font-mono text-xs text-muted-foreground">
				<span>{ row.StartedAt }</span>
				<span>{ row.EndedAt }</span>
			</div>
			<div class="relative h-9 overflow-hidden rounded-md bg-muted" role="group" aria-label={ row.Identifier + " lifespan" }>
				for _, segment := range row.Segments {
					<span class={ "absolute bottom-1 top-1 min-w-1.5 rounded " + segment.Class } style={ segment.Style } title={ segment.Title } aria-label={ segment.Title }>
						<span class="sr-only">{ segment.Title }</span>
					</span>
				}
			</div>
		</div>
		<div class="mt-3 font-mono text-xs text-muted-foreground">{ row.Duration }</div>
	</article>
}

templ retryQueueSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Retry queue", helpBackoffQueue, "retry-queue")
				<p class="text-sm text-muted-foreground">Issues waiting for the next retry window.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-warning-soft px-2 py-1 text-sm font-medium text-warning">{ formatCount(queueCount(snapshot)) }</span>
		</div>
		if len(snapshot.Queue) == 0 {
			if queueCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Retry queue details are unavailable.", "The queue count is live, but retry rows have not arrived in this snapshot.", "bg-warning")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No issues are currently backing off.", "Retrying work will appear here with its next due time.", "bg-warning")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range snapshot.Queue {
					@retryQueueMobileCard(row, i)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="retry-queue">
					<table class="dashboard-table w-full min-w-[54rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[7rem] px-3 py-3 font-medium">Attempt</th>
								<th class="w-[13rem] px-3 py-3 font-medium">Due time</th>
								<th class="px-3 py-3 font-medium">
									@helpInlineLabel("Error", helpEvent, "retry-table", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range snapshot.Queue {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top">
										@issueCell(row.Issue, "retry", i, true)
									</td>
									<td class="px-3 py-4 align-top font-mono text-foreground">{ formatInt(int64(row.Attempt)) }</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ queuedDueLabel(row) }</td>
									<td class="px-3 py-4 align-top text-muted-foreground">
										<span class="line-clamp-3">{ rowError(row.Error) }</span>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ retryQueueMobileCard(row telemetry.Queued, rowIndex int) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "retry-mobile", rowIndex, true)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Attempt</span>
				<span class="font-mono text-foreground">{ formatInt(int64(row.Attempt)) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Due time</span>
				<span class="font-mono text-foreground">{ queuedDueLabel(row) }</span>
			</div>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 p-3 text-sm text-muted-foreground">
			<span class="line-clamp-4">{ rowError(row.Error) }</span>
		</div>
	</article>
}

templ blockedSessionsSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Blocked sessions", helpBlocked, "blocked-sessions")
				<p class="text-sm text-muted-foreground">Issues paused because Codex requested operator input or approval.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-danger-soft px-2 py-1 text-sm font-medium text-danger">{ formatCount(blockedCount(snapshot)) }</span>
		</div>
		if len(snapshot.Blocked) == 0 {
			if blockedCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Blocked session details are unavailable.", "The blocked count is live, but detailed rows have not arrived in this snapshot.", "bg-danger")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No blocked sessions.", "Operator requests and approval waits will appear here.", "bg-danger")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range snapshot.Blocked {
					@blockedSessionMobileCard(row, i)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="blocked-sessions">
					<table class="dashboard-table w-full min-w-[68rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[9rem] px-3 py-3 font-medium">State</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Session", helpSession, "blocked-table", "")
								</th>
								<th class="w-[13rem] px-3 py-3 font-medium">Blocked time</th>
								<th class="px-3 py-3 font-medium">
									@helpInlineLabel("Last update", helpEvent, "blocked-table", "")
								</th>
								<th class="w-[14rem] px-3 py-3 font-medium">
									@helpInlineLabel("Error", helpEvent, "blocked-table-error", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range snapshot.Blocked {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top">
										@issueCell(row.Issue, "blocked", i, true)
									</td>
									<td class="px-3 py-4 align-top">
										<span class="inline-flex rounded-full bg-danger-soft px-2 py-1 font-medium text-danger">{ issueState(row.Issue, "Blocked") }</span>
									</td>
									<td class="px-3 py-4 align-top">
										@sessionCopyButton(row.SessionID)
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ blockedAtLabel(row) }</td>
									<td class="px-3 py-4 align-top">
										<div class="grid gap-1">
											<span class="line-clamp-2 text-foreground">{ blockedLastUpdate(row) }</span>
											<span class="font-mono text-xs text-muted-foreground">{ blockedLastUpdateMeta(row) }</span>
										</div>
									</td>
									<td class="px-3 py-4 align-top text-muted-foreground">
										<span class="line-clamp-3">{ rowError(row.Error) }</span>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ blockedSessionMobileCard(row telemetry.Blocked, rowIndex int) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "blocked-mobile", rowIndex, true)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">State</span>
				<span class="rounded-full bg-danger-soft px-2 py-1 font-medium text-danger">{ issueState(row.Issue, "Blocked") }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Blocked time</span>
				<span class="font-mono text-foreground">{ blockedAtLabel(row) }</span>
			</div>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 p-3">
			<span class="line-clamp-3 text-sm text-foreground">{ blockedLastUpdate(row) }</span>
			<span class="mt-1 block font-mono text-xs text-muted-foreground">{ blockedLastUpdateMeta(row) }</span>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 p-3 text-sm text-muted-foreground">
			<span class="line-clamp-4">{ rowError(row.Error) }</span>
		</div>
		<div class="mt-3">
			@sessionCopyButton(row.SessionID)
		</div>
	</article>
}

templ recentSessionsSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Recent sessions", helpRecentSessions, "recent-sessions")
				<p class="text-sm text-muted-foreground">Last completed Codex sessions across Detent runs.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-success-soft px-2 py-1 text-sm font-medium text-success">{ formatCount(completedCount(snapshot)) }</span>
		</div>
		if len(snapshot.Completed) == 0 {
			if completedCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Completed session details are unavailable.", "The completed count is live, but session rows have not arrived in this snapshot.", "bg-success")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No completed sessions recorded.", "Finished Codex sessions will appear here after work completes.", "bg-success")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range snapshot.Completed {
					@recentSessionMobileCard(row, i)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="recent-sessions">
					<table class="dashboard-table w-full min-w-[74rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[13rem] px-3 py-3 font-medium">Completed</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Runtime / turns", helpAgeTurn, "recent-table", "")
								</th>
								<th class="w-[10rem] px-3 py-3 font-medium">
									@helpInlineLabel("Tokens", helpTokens, "recent-table", "")
								</th>
								<th class="w-[10rem] px-3 py-3 font-medium">Final state</th>
								<th class="w-[11rem] px-3 py-3 font-medium">Model</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Session", helpSession, "recent-table", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range snapshot.Completed {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top">
										@issueCell(row.Issue, "recent", i, false)
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ completedAtLabel(row) }</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ completedRuntime(row) }</td>
									<td class="px-3 py-4 align-top">
										<div class="grid gap-1 font-mono">
											<span class="font-medium text-foreground">{ formatTokens(row.Tokens) }</span>
											<span class="text-xs text-muted-foreground">{ formatTokenBreakdown(row.Tokens) }</span>
										</div>
									</td>
									<td class="px-3 py-4 align-top">
										<span class="inline-flex rounded-full bg-success-soft px-2 py-1 font-medium text-success">{ completedState(row) }</span>
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ completedModel(row) }</td>
									<td class="px-3 py-4 align-top">
										@sessionCopyButton(row.SessionID)
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ recentSessionMobileCard(row telemetry.Completed, rowIndex int) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "recent-mobile", rowIndex, false)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Completed</span>
				<span class="font-mono text-foreground">{ completedAtLabel(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Runtime / turns", helpAgeTurn, "recent-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ completedRuntime(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Tokens", helpTokens, "recent-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ formatTokens(row.Tokens) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Final state</span>
				<span class="rounded-full bg-success-soft px-2 py-1 font-medium text-success">{ completedState(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Model</span>
				<span class="font-mono text-foreground">{ completedModel(row) }</span>
			</div>
		</div>
		<div class="mt-3">
			@sessionCopyButton(row.SessionID)
		</div>
	</article>
}

templ issueCell(issue telemetry.Issue, prefix string, rowIndex int, jsonDetails bool) {
	<div class="grid gap-2" data-popover>
		<div class="flex min-w-0 items-start gap-2">
			<button
				type="button"
				class="min-w-0 flex-1 text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
				aria-describedby={ issuePopoverID(prefix, rowIndex) }
				aria-expanded="false"
				data-popover-trigger
			>
				<span class="block truncate font-medium text-foreground">{ issueIdentifier(issue) }</span>
				<span class="line-clamp-1 text-muted-foreground">{ issueTitle(issue) }</span>
			</button>
			if issueProjectLabel(issue) != "" {
				<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ "Project " + issueProjectLabel(issue) }>{ issueProjectLabel(issue) }</span>
			}
			if issue.URL != "" {
				@issueCopyButton(issue.URL)
				<a class="issue-external inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-border bg-card text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ issue.URL } target="_blank" rel="noopener noreferrer" title={ "Open " + issue.URL }>
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
						<polyline points="15 3 21 3 21 9"></polyline>
						<line x1="10" y1="14" x2="21" y2="3"></line>
					</svg>
					<span class="sr-only">Open issue in new tab</span>
				</a>
			}
		</div>
		if issueDescriptionPreview(issue) != "" {
			<p class="line-clamp-2 text-xs text-muted-foreground">{ issueDescriptionPreview(issue) }</p>
		}
		if issueClaimSummary(issue) != "" {
			<p class="line-clamp-2 font-mono text-xs text-muted-foreground">{ issueClaimSummary(issue) }</p>
		}
		if jsonDetails && issueDetailURL(issue) != "" {
			<a class="w-fit text-xs font-medium text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ issueDetailURL(issue) }>JSON details</a>
		}
		<div
			id={ issuePopoverID(prefix, rowIndex) }
			class="popover-panel issue-popover-panel max-w-sm text-foreground"
			role="tooltip"
			aria-hidden="true"
			data-popover-panel
			data-popover-width="320"
		>
			<p class="font-medium text-foreground">{ issueTitle(issue) }</p>
			if issueDescriptionPreview(issue) != "" {
				<p class="mt-1 text-muted-foreground">{ issueDescriptionPreview(issue) }</p>
			}
		</div>
	</div>
}

templ issueCopyButton(value string) {
	<button
		type="button"
		class="issue-copy issue-external inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-border bg-card text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
		data-label="Copy issue URL"
		data-copy={ value }
		title={ "Copy " + value }
		onclick="navigator.clipboard.writeText(this.dataset.copy); const label = this.querySelector('[data-copy-label]'); label.textContent = 'Copied'; clearTimeout(this._copyTimer); this._copyTimer = setTimeout(() => { label.textContent = this.dataset.label }, 1200);"
	>
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
		</svg>
		<span class="sr-only" data-copy-label>Copy issue URL</span>
	</button>
}

templ sessionCopyButton(sessionID string) {
	if sessionID == "" {
		<span class="font-mono text-muted-foreground">n/a</span>
	} else {
		<button
			type="button"
			class="inline-flex min-h-10 max-w-full items-center gap-2 rounded-md border border-border bg-muted px-3 py-2 font-mono text-xs text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
			data-label={ sessionLabel(sessionID) }
			data-copy={ sessionID }
			title={ "Copy " + sessionID }
			onclick="navigator.clipboard.writeText(this.dataset.copy); const label = this.querySelector('[data-copy-label]'); label.textContent = 'Copied'; clearTimeout(this._copyTimer); this._copyTimer = setTimeout(() => { label.textContent = this.dataset.label }, 1200);"
		>
			<span class="truncate" data-copy-label>{ sessionLabel(sessionID) }</span>
			<svg class="shrink-0" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
				<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
			</svg>
		</button>
	}
}

templ budgetCard(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Budget", helpBudget, "budget-card")
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ budgetStatus(snapshot.Budget) }</span>
		</div>
		<div class="mt-5 grid gap-4 text-sm">
			<div class="grid gap-2">
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Spend today", helpCurrentSpend, "budget-current-spend", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ budgetSpendTodayLabel(snapshot.Budget) }</strong>
				</div>
				<div class="h-2 overflow-hidden rounded-full bg-muted" aria-label="Daily budget usage">
					<div class="h-full rounded-full bg-accent transition-all" style={ budgetDailyUsageStyle(snapshot.Budget) }></div>
				</div>
			</div>
			if !budgetBurnDownView(snapshot).Available {
				@dashboardEmptyState(budgetBurnDownView(snapshot).EmptyTitle, budgetBurnDownView(snapshot).EmptyDetail, "bg-accent")
			} else {
				<div class="grid gap-3">
					<div class="flex items-center justify-between gap-4">
						@helpInlineLabel("Cost burn-down", helpProjectedSpend, "budget-burn-down", "font-medium text-muted-foreground")
						<span class="font-mono text-xs text-muted-foreground">{ budgetBurnDownView(snapshot).PeriodLabel }</span>
					</div>
					@BudgetProjectionChart(budgetBurnDownView(snapshot).Chart)
					<div class="grid grid-cols-3 gap-2 font-mono text-xs text-muted-foreground">
						<span>Spend { budgetBurnDownView(snapshot).CurrentLabel }</span>
						<span>Cap { budgetBurnDownView(snapshot).CapLabel }</span>
						<span>Projected { budgetBurnDownView(snapshot).ProjectionLabel }</span>
					</div>
				</div>
			}
			if len(budgetHistoryBars(snapshot.Budget)) == 0 {
				@dashboardEmptyState("No budget history yet.", "Spend bars will appear after daily budget samples are recorded.", "bg-accent")
			} else {
				<div class="grid gap-2">
					<div class="flex items-center justify-between gap-4">
						@helpInlineLabel("Budget history", helpBudgetHistory, "budget-history", "font-medium text-muted-foreground")
						<span class="font-mono text-xs text-muted-foreground">{ budgetHistoryCount(snapshot.Budget) }</span>
					</div>
					<div class="grid h-12 grid-cols-7 items-end gap-1 rounded-md border border-border bg-muted px-2 py-2" aria-label="Spend over the last seven days">
						for _, bar := range budgetHistoryBars(snapshot.Budget) {
							<span class="block min-h-1 rounded-t bg-accent opacity-80" style={ bar.Style } title={ bar.Title }>
								<span class="sr-only">{ bar.Title }</span>
							</span>
						}
					</div>
				</div>
			}
			<div class="grid gap-3 border-t border-border pt-3">
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Projected", helpProjectedSpend, "budget-projected", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ budgetBurnDownView(snapshot).ProjectionLabel }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Daily cap", helpDailyCap, "budget-daily-cap", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ optionalUSD(snapshot.Budget.PerDayMaxUSD) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Issue cap", helpIssueCap, "budget-issue-cap", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ optionalUSD(snapshot.Budget.PerIssueMaxUSD) }</strong>
				</div>
			</div>
		</div>
	</section>
}

templ rateLimitsCard(limits *RateLimits) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Rate limits", helpRateLimits, "rate-limits-card")
			<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 text-xs font-medium text-accent">{ rateLimitName(limits) }</span>
		</div>
		if len(rateLimitRows(limits)) == 0 {
			<div class="mt-4">
				@dashboardEmptyState("No rate-limit snapshot.", "Limits will appear after Codex or the tracker reports quota data.", "bg-accent")
			</div>
		} else {
			<div class="mt-5 grid gap-4">
				for _, row := range rateLimitRows(limits) {
					<div class="grid gap-2">
						<div class="flex items-center justify-between gap-3">
							@helpInlineLabel(row.Name, rateLimitHelpTerm(row.Name), "rate-limit-"+helpIDPart(row.Name), "font-medium text-foreground")
							<span class="font-mono text-sm text-muted-foreground">{ row.Reset }</span>
						</div>
						<div class="h-2 overflow-hidden rounded-full bg-muted">
							<div class="h-full rounded-full bg-accent transition-all" style={ percentStyle(row.UsedPercent) }></div>
						</div>
						<div class="grid grid-cols-3 gap-2 font-mono text-xs text-muted-foreground">
							<span>{ row.Remaining }</span>
							<span>{ row.Used }</span>
							<span>{ row.Limit }</span>
						</div>
					</div>
				}
			</div>
		}
	</section>
}

templ graphQLBudgetCard(data DashboardData) {
	if hasGraphQLBudget(data.Snapshot.RateLimits) {
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="GraphQL budget">
			<div class="flex items-start justify-between gap-3">
				@helpHeading2("GraphQL budget", helpRateLimits, "graphql-budget-card")
				<span class="shrink-0 rounded-full bg-warning-soft px-2 py-1 font-mono text-xs font-medium text-warning">{ graphQLBudgetCycleCost(data.Snapshot.RateLimits) }</span>
			</div>
			<div class="mt-5 grid gap-3">
				<div class="grid grid-cols-2 gap-3 text-sm">
					<div class="grid gap-1">
						<span class="text-muted-foreground">Remaining</span>
						<strong class="break-all font-mono text-base font-semibold text-foreground">{ graphQLBudgetRemaining(data.Snapshot.RateLimits) }</strong>
					</div>
					<div class="grid gap-1">
						<span class="text-muted-foreground">Reset</span>
						<strong class="font-mono text-base font-semibold text-foreground">{ graphQLBudgetReset(data.Snapshot.RateLimits, data.Snapshot.GeneratedAt) }</strong>
						<span class="font-mono text-xs text-muted-foreground">{ graphQLBudgetResetAt(data.Snapshot.RateLimits) }</span>
					</div>
				</div>
				<div class="flex items-center justify-between gap-3 border-t border-border pt-3 text-sm">
					<span class="text-muted-foreground">Cycle queries</span>
					<strong class="font-mono font-medium text-foreground">{ graphQLBudgetQueryCount(data.Snapshot.RateLimits) }</strong>
				</div>
				if len(graphQLBudgetContributorRows(data.Snapshot.RateLimits)) == 0 {
					@dashboardEmptyState("No GraphQL query costs this cycle.", "Query contributors will appear after the GitHub connector reports rateLimit cost.", "bg-warning")
				} else {
					<div class="grid gap-2 border-t border-border pt-3">
						for _, row := range graphQLBudgetContributorRows(data.Snapshot.RateLimits) {
							<div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-1 text-sm">
								<span class="truncate font-mono font-medium text-foreground">{ row.QueryType }</span>
								<span class="font-mono text-muted-foreground">{ row.Cost }</span>
								<span class="font-mono text-xs text-muted-foreground">{ row.Count }</span>
								<span class="text-right font-mono text-xs text-muted-foreground">{ row.Percent }</span>
							</div>
						}
					</div>
				}
			</div>
		</section>
	}
}

templ tokenCard(data DashboardData) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Tokens", helpTokens, "tokens-card")
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ tokenRate(data.Snapshot) }</span>
		</div>
		<div class="mt-5 grid gap-2">
			<div class="break-all font-mono text-2xl font-semibold text-foreground sm:text-3xl">{ formatTokens(data.Snapshot.Tokens) }</div>
			<div class="font-mono text-sm text-muted-foreground">{ formatTokenBreakdown(data.Snapshot.Tokens) }</div>
		</div>
		<div class="mt-5">
			<div class="mb-2 flex items-center justify-between gap-3 text-sm">
				@helpInlineLabel("Token trend", helpTokenTrend, "tokens-card", "font-medium text-muted-foreground")
				<span class="font-mono text-xs text-muted-foreground">{ formatDuration(data.Snapshot.Tokens.RuntimeSeconds) }</span>
			</div>
			if len(tokenTrendPoints(data.Snapshot)) == 0 {
				@dashboardEmptyState("No token trend yet.", "Input and output token samples will appear after active sessions report usage.", "bg-accent")
			} else {
				@SplitSeriesChart(tokenTrendChart(data.Snapshot))
				<div class="mt-3 flex flex-wrap items-center gap-4 text-xs font-medium text-muted-foreground">
					<span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-accent"></span>Input</span>
					<span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-success"></span>Output</span>
				</div>
			}
		</div>
	</section>
}
