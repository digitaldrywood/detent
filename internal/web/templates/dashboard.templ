package templates

import (
	"strconv"
	"time"

	"github.com/digitaldrywood/detent/internal/telemetry"
	"github.com/digitaldrywood/detent/internal/web/ui/components/button"
	"github.com/digitaldrywood/detent/internal/web/ui/components/dialog"
	"github.com/digitaldrywood/detent/internal/web/ui/components/icon"
	"github.com/digitaldrywood/detent/internal/web/ui/components/popover"
	"github.com/digitaldrywood/detent/internal/web/ui/components/sheet"
	"github.com/digitaldrywood/detent/internal/web/ui/components/sidebar"
)

templ Dashboard(data DashboardData) {
	@DashboardShell(DashboardShellDataFromDashboard(data)) {
		<div class="mx-auto grid w-full max-w-7xl content-start gap-4 sm:gap-5">
			<header class="dashboard-topbar min-w-0 border-b border-border py-2">
				<div class="flex min-w-0 flex-wrap items-center gap-x-5 gap-y-2">
					@dashboardMobileSidebarTrigger()
					@dashboardPageHeading(dashboardHeading(data))
					<div class="dashboard-topbar-actions ml-auto flex min-w-0 flex-wrap items-center justify-end gap-x-2 gap-y-1 text-xs text-muted-foreground">
						if projectExternalURL(data) != "" {
							<a class="inline-flex size-8 shrink-0 items-center justify-center rounded-md border border-border bg-card text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectExternalURL(data) } target="_blank" rel="noopener noreferrer" title={ projectExternalLinkLabel(data) } aria-label={ projectExternalLinkLabel(data) }>
								@icon.ExternalLink(icon.Props{Class: "size-4"})
							</a>
						}
						if isProjectDashboard(data) {
							<a class="inline-flex min-h-8 items-center gap-1 rounded-md border border-border bg-card px-2 py-1 font-medium text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectKanbanPath(data.ProjectID) }>
								@icon.Kanban(icon.Props{Class: "size-3.5 shrink-0"})
								<span>Board</span>
							</a>
							@dashboardTopbarDivider()
						}
						<span class="truncate font-mono">{ dashboardBuildVersionLabel(data) }</span>
						@dashboardTopbarDivider()
						<span class="truncate">{ connectorName(data) }</span>
						@dashboardTopbarDivider()
						<span id="live-tick" class="sse-tick min-w-0 truncate font-mono" sse-swap="tick" hx-swap="innerHTML settle:120ms">{ generatedAtLabel(data.Snapshot) }</span>
					</div>
				</div>
			</header>
			<div id="snapshot" class="sse-surface grid min-w-0 gap-4 sm:gap-5" sse-swap="snapshot" hx-swap="morph:innerHTML">
				@SnapshotView(data)
			</div>
			if !isProjectDashboard(data) {
				@dashboardCharts(data)
			}
		</div>
	}
}

templ HealthPage(data DashboardData) {
	@DashboardShell(HealthShellDataFromDashboard(data)) {
		<div class="mx-auto grid w-full max-w-7xl content-start gap-4 sm:gap-5">
			<header class="dashboard-topbar min-w-0 border-b border-border py-2">
				<div class="flex min-w-0 flex-wrap items-center gap-x-5 gap-y-2">
					@dashboardMobileSidebarTrigger()
					<div class="min-w-0">
						<h1 class="truncate text-sm font-semibold text-foreground">Health</h1>
					</div>
					<div class="dashboard-topbar-actions ml-auto flex min-w-0 flex-wrap items-center justify-end gap-x-2 gap-y-1 text-xs text-muted-foreground">
						<span class="truncate font-mono">{ dashboardBuildVersionLabel(data) }</span>
						@dashboardTopbarDivider()
						<span class="truncate">{ connectorName(data) }</span>
						@dashboardTopbarDivider()
						<span id="live-tick" class="sse-tick min-w-0 truncate font-mono" sse-swap="tick" hx-swap="innerHTML settle:120ms">{ generatedAtLabel(data.Snapshot) }</span>
					</div>
				</div>
			</header>
			<div id="snapshot" class="sse-surface grid min-w-0 gap-4 sm:gap-5" sse-swap="snapshot" hx-swap="morph:innerHTML">
				@HealthSnapshot(data)
			</div>
		</div>
	}
}

templ ProjectKanbanPage(data DashboardData) {
	@DashboardShell(ProjectKanbanShellDataFromDashboard(data)) {
		<div id="snapshot" class="sse-surface grid min-w-0 content-start" sse-swap="snapshot" hx-swap="morph:innerHTML">
			@ProjectKanbanSnapshot(data)
		</div>
	}
}

templ ProjectKanbanSnapshot(data DashboardData) {
	@projectKanbanSection(data, projectKanbanBoardView(data))
}

templ ProjectRunsPage(data DashboardData) {
	@DashboardShell(ProjectRunsShellDataFromDashboard(data)) {
		<div class="mx-auto grid w-full max-w-7xl content-start gap-4 sm:gap-5">
			@projectDetailHeader(data, "Runs")
			<div id="snapshot" class="sse-surface grid min-w-0 gap-4 sm:gap-5" sse-swap="snapshot" hx-swap="morph:innerHTML">
				@ProjectRunsSnapshot(data)
			</div>
		</div>
	}
}

templ ProjectDiagnosticsPage(data DashboardData) {
	@DashboardShell(ProjectDiagnosticsShellDataFromDashboard(data)) {
		<div class="mx-auto grid w-full max-w-7xl content-start gap-4 sm:gap-5">
			@projectDetailHeader(data, "Diagnostics")
			<div id="snapshot" class="sse-surface grid min-w-0 gap-4 sm:gap-5" sse-swap="snapshot" hx-swap="morph:innerHTML">
				@ProjectDiagnosticsSnapshot(data)
			</div>
			@diagnosticsTabsScript()
			@dashboardCharts(data)
		</div>
	}
}

templ projectDetailHeader(data DashboardData, title string) {
	<header class="dashboard-topbar min-w-0 border-b border-border py-2">
		<div class="flex min-w-0 flex-wrap items-center gap-x-5 gap-y-2">
			@dashboardMobileSidebarTrigger()
			<div class="min-w-0">
				<h1 class="truncate text-sm font-semibold text-foreground">{ projectDisplayName(data) } / { title }</h1>
			</div>
			<div class="dashboard-topbar-actions ml-auto flex min-w-0 flex-wrap items-center justify-end gap-x-2 gap-y-1 text-xs text-muted-foreground">
				if projectExternalURL(data) != "" {
					<a class="inline-flex size-8 shrink-0 items-center justify-center rounded-md border border-border bg-card text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectExternalURL(data) } target="_blank" rel="noopener noreferrer" title={ projectExternalLinkLabel(data) } aria-label={ projectExternalLinkLabel(data) }>
						@icon.ExternalLink(icon.Props{Class: "size-4"})
					</a>
				}
				<span class="truncate font-mono">{ dashboardBuildVersionLabel(data) }</span>
				@dashboardTopbarDivider()
				<span class="truncate">{ connectorName(data) }</span>
				@dashboardTopbarDivider()
				<span id="live-tick" class="sse-tick min-w-0 truncate font-mono" sse-swap="tick" hx-swap="innerHTML settle:120ms">{ generatedAtLabel(data.Snapshot) }</span>
			</div>
		</div>
	</header>
}

templ DashboardShell(data DashboardShellData) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<meta name="color-scheme" content="light dark"/>
			<meta name="application-name" content={ applicationName(data.ApplicationName) }/>
			<title>{ pageTitle(data) }</title>
			<script>
				document.documentElement.classList.toggle("dark", Boolean(window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches))
			</script>
			@helpScript()
			<link rel="icon" type="image/svg+xml" href={ faviconPath(data.Assets) }/>
			<link rel="stylesheet" href={ stylesheetPath(data.Assets) }/>
			<script src="https://unpkg.com/htmx.org@2.0.4"></script>
			<script src="https://cdn.jsdelivr.net/npm/htmx-ext-sse@2.2.4"></script>
			<script src="https://cdn.jsdelivr.net/npm/idiomorph@0.7.3/dist/idiomorph-ext.min.js"></script>
			@dashboardSSEMetricsScript()
			if data.IncludeDashboardCharts {
				<script src={ chartJSPath(data.Assets) } defer></script>
				<script src={ dashboardChartsScriptPath(data.Assets) } defer></script>
			}
			@sidebar.Script()
			@popover.Script()
			@dialog.Script()
		</head>
		<body class="min-h-screen overflow-x-hidden bg-background text-foreground antialiased">
			@helpTooltipHost()
			@kanbanDialogHost()
			@sidebar.Layout(sidebar.LayoutProps{
				Class: "dashboard-shell min-h-screen w-full bg-background",
				Attributes: templ.Attributes{
					"hx-ext":      "sse, morph",
					"sse-connect": eventsPath(data),
				},
			}) {
				@dashboardSidebar(data)
				@sidebar.Inset(sidebar.InsetProps{Class: "dashboard-main min-w-0 px-3 py-3 sm:px-6 lg:px-8"}) {
					@dashboardLiveUpdateWarning()
					{ children... }
				}
			}
			@projectKanbanVisibilityScript()
		</body>
	</html>
}

templ dashboardLiveUpdateWarning() {
	<div id="detent-sse-warning" class="mb-3 hidden rounded-md border border-warning-soft bg-warning-soft/70 px-3 py-2 text-sm text-warning shadow-sm" role="status" aria-live="polite" data-detent-sse-warning hidden>
		<div class="flex min-w-0 items-start gap-3">
			@icon.CircleAlert(icon.Props{Class: "mt-0.5 size-4 shrink-0 text-warning"})
			<div class="grid min-w-0 gap-1">
				<p class="font-medium text-warning">Live updates delayed</p>
				<p class="text-xs text-warning" data-detent-sse-warning-message>Snapshot events are queued but the page has not settled.</p>
				<p class="break-words font-mono text-[11px] text-warning" data-detent-sse-warning-metrics></p>
			</div>
		</div>
	</div>
}

templ dashboardPageHeading(title string) {
	<h1 class="sr-only">{ title }</h1>
}

templ dashboardTopbarDivider() {
	<span aria-hidden="true">/</span>
}

templ GitHubAPIHealthSidebarItem(data DashboardShellData) {
	<div class="min-w-0" { gitHubAPIHealthSidebarTargetAttributes(data)... }>
		@sidebar.MenuButton(sidebar.MenuButtonProps{
			Href:       sidebarHealthPath(data),
			IsActive:   sidebarStaticNavActive(data, "health"),
			Tooltip:    "Health",
			Class:      "relative",
			Attributes: gitHubAPIHealthSidebarLinkAttributes(data),
		}) {
			@icon.Activity(icon.Props{Class: "size-4 shrink-0"})
			<span class={ "size-2.5 shrink-0 rounded-full group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:absolute group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:right-1 group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:top-1 group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:size-2 group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:ring-2 group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:ring-sidebar-border " + gitHubAPIHealthDotClass(data.Snapshot) } aria-hidden="true"></span>
			<span class="min-w-0 flex-1 truncate group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden">Health</span>
			@sidebar.MenuBadge(sidebar.MenuBadgeProps{
				Class: "border " + gitHubAPIHealthBadgeClass(data.Snapshot),
			}) {
				{ gitHubAPIHealthStateLabel(data.Snapshot) }
			}
		}
	</div>
}

templ HealthSnapshot(data DashboardData) {
	<section id="health-dashboard" class="grid min-w-0 gap-4 sm:gap-5" aria-label="Health dashboard">
		@dashboardHealth(data)
		@GitHubAPIHealthDetails(data.Snapshot)
	</section>
}

templ GitHubAPIHealthDetails(snapshot telemetry.Snapshot) {
	<section class="grid min-w-0 gap-4" aria-label="GitHub API health details">
		<div class="flex flex-col gap-3 border-b border-border pb-3 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				<div class="flex min-w-0 items-center gap-2">
					<span class={ "h-2.5 w-2.5 shrink-0 rounded-full " + gitHubAPIHealthDotClass(snapshot) } aria-hidden="true"></span>
					<h2 class="truncate text-base font-semibold text-foreground">{ gitHubAPIHealth(snapshot).Label }</h2>
				</div>
				<p class="mt-1 max-w-3xl text-sm text-muted-foreground">{ gitHubAPIHealth(snapshot).Detail }</p>
			</div>
			<span class={ "inline-flex min-h-8 shrink-0 items-center rounded-md border px-2.5 py-1 text-xs font-medium " + gitHubAPIHealthBadgeClass(snapshot) }>
				{ gitHubAPIHealthStateLabel(snapshot) }
			</span>
		</div>
		<div class="grid min-w-0 gap-3 md:grid-cols-2 xl:grid-cols-4">
			@healthFactCard("Aggregate status", gitHubAPIHealth(snapshot).Label, gitHubAPIHealth(snapshot).Summary, gitHubAPIHealthDotClass(snapshot))
			@healthFactCard("Backoff state", gitHubAPIHealthBackoffLabel(snapshot), gitHubAPIHealthBackoffDetail(snapshot), gitHubAPIHealthDotClass(snapshot))
			@healthFactCard("Primary quota", gitHubAPIHealthPrimaryQuotaLabel(snapshot), gitHubAPIHealthPrimaryQuotaDetail(snapshot), "bg-accent")
			@healthFactCard("Retry timing", gitHubAPIHealthRetryLabel(snapshot), gitHubAPIHealthRetryDetail(snapshot), "bg-warning")
		</div>
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="GitHub primary quota details">
			<div class="flex min-w-0 items-start justify-between gap-3">
				<div class="min-w-0">
					<h3 class="text-sm font-semibold text-foreground">Primary quota</h3>
					<p class="text-sm text-muted-foreground">REST and GraphQL primary buckets, including quota usage and reset timing.</p>
				</div>
				<span class="shrink-0 rounded-md bg-muted px-2 py-1 font-mono text-xs text-muted-foreground">{ formatInt(int64(len(gitHubAPIHealth(snapshot).Buckets))) }</span>
			</div>
			if len(gitHubAPIHealth(snapshot).Buckets) == 0 {
				<div class="mt-4">
					@dashboardEmptyState("No GitHub primary budget snapshot.", "REST and GraphQL primary buckets will appear after the tracker reports them.", "bg-muted-foreground")
				</div>
			} else {
				<div class="mt-4 grid min-w-0 gap-3 md:grid-cols-2">
					for _, bucket := range gitHubAPIHealth(snapshot).Buckets {
						<div class="grid min-w-0 gap-3 rounded-md border border-border bg-muted/40 p-3">
							<div class="flex min-w-0 items-center justify-between gap-3">
								<span class="truncate text-sm font-medium text-foreground">{ bucket.Name }</span>
								<span class="shrink-0 font-mono text-xs text-muted-foreground">{ bucket.Reset }</span>
							</div>
							<div class="grid min-w-0 gap-2 text-xs text-muted-foreground sm:grid-cols-3">
								<span class="min-w-0 truncate font-mono" title={ bucket.Remaining }>{ bucket.Remaining }</span>
								<span class="min-w-0 truncate font-mono" title={ bucket.Used }>{ bucket.Used }</span>
								<span class="min-w-0 truncate font-mono" title={ bucket.Limit }>{ bucket.Limit }</span>
							</div>
						</div>
					}
				</div>
			}
		</section>
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="GitHub endpoint backoff details">
			<div class="flex min-w-0 items-start justify-between gap-3">
				<div class="min-w-0">
					<h3 class="text-sm font-semibold text-foreground">Affected endpoints</h3>
					<p class="text-sm text-muted-foreground">Endpoint families currently paused by secondary REST throttling.</p>
				</div>
				<span class="shrink-0 rounded-md bg-muted px-2 py-1 font-mono text-xs text-muted-foreground">{ formatInt(int64(len(gitHubAPIHealth(snapshot).Endpoints))) }</span>
			</div>
			if len(gitHubAPIHealth(snapshot).Endpoints) == 0 {
				<div class="mt-4">
					@dashboardEmptyState("No endpoint backoff active.", "Secondary REST throttling will list paused endpoint families here.", "bg-success")
				</div>
			} else {
				<div class="mt-4 overflow-x-auto" data-preserve-scroll="github-api-endpoints">
					<table class="dashboard-table w-full min-w-[46rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[14rem] px-3 py-3 font-medium">Endpoint</th>
								<th class="w-[7rem] px-3 py-3 font-medium">Status</th>
								<th class="w-[9rem] px-3 py-3 font-medium">Count</th>
								<th class="w-[10rem] px-3 py-3 font-medium">Remaining</th>
								<th class="w-[9rem] px-3 py-3 font-medium">Retry-after</th>
								<th class="px-3 py-3 font-medium">Retry</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-border">
							for _, endpoint := range gitHubAPIHealth(snapshot).Endpoints {
								<tr>
									<td class="truncate px-3 py-3 font-medium text-foreground" title={ endpoint.EndpointFamily }>{ endpoint.EndpointFamily }</td>
									<td class="px-3 py-3 font-mono text-muted-foreground">{ endpoint.Status }</td>
									<td class="px-3 py-3 font-mono text-muted-foreground">{ endpoint.Count }</td>
									<td class="px-3 py-3 font-mono text-muted-foreground">{ endpoint.Remaining }</td>
									<td class="px-3 py-3 font-mono text-muted-foreground">{ endpoint.RetryAfter }</td>
									<td class="px-3 py-3 font-mono text-muted-foreground">{ endpoint.Retry }</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			}
		</section>
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="GitHub refresh timing">
			<div class="flex min-w-0 items-start justify-between gap-3">
				<div class="min-w-0">
					<h3 class="text-sm font-semibold text-foreground">Refresh timing</h3>
					<p class="text-sm text-muted-foreground">Tracker refresh state and manual refresh feedback.</p>
				</div>
				if manualRefreshVisible(snapshot) {
					<form class="shrink-0" hx-post="/api/v1/refresh" hx-target="#github-api-manual-refresh-status" hx-swap="outerHTML">
						<input type="hidden" name="manual_refresh_status_id" value="github-api-manual-refresh-status"/>
						@button.Button(button.Props{
							Type:    button.TypeSubmit,
							Variant: button.VariantOutline,
							Size:    button.SizeSm,
							Class:   "border-warning bg-card text-warning hover:border-accent hover:text-accent",
							Attributes: templ.Attributes{
								"aria-label": "Force tracker refresh",
							},
						}) {
							@icon.RefreshCw(icon.Props{Class: "size-3.5 shrink-0"})
							<span>Force refresh</span>
						}
					</form>
				}
			</div>
			<div class="mt-4 grid min-w-0 gap-3 md:grid-cols-2">
				for _, row := range gitHubAPIHealth(snapshot).Refreshes {
					<div class="grid min-w-0 gap-1 rounded-md border border-border bg-muted/40 p-3">
						<span class="truncate text-xs font-medium uppercase text-muted-foreground">{ row.Label }</span>
						<span class="min-w-0 break-words font-mono text-sm text-foreground">{ row.Value }</span>
					</div>
				}
			</div>
			if manualRefreshVisible(snapshot) {
				<div class="mt-3">
					@ManualRefreshFeedbackWithID("github-api-manual-refresh-status", snapshot.Refresh.Manual)
				</div>
			}
		</section>
	</section>
}

templ healthFactCard(label string, value string, detail string, dotClass string) {
	<article class="min-w-0 rounded-md border border-border bg-card p-4 shadow-sm">
		<div class="flex min-w-0 items-center justify-between gap-3">
			<span class="truncate text-xs font-medium uppercase text-muted-foreground">{ label }</span>
			<span class={ "h-2.5 w-2.5 shrink-0 rounded-full " + dotClass } aria-hidden="true"></span>
		</div>
		<div class="mt-2 min-w-0 break-words text-sm font-semibold text-foreground">{ value }</div>
		<p class="mt-1 line-clamp-3 text-xs text-muted-foreground">{ detail }</p>
	</article>
}
templ kanbanDialogHost() {
	<div id="kanban-dialog-host">
		@dialog.Dialog(dialog.Props{ID: kanbanActionDialogID}) {
			@dialog.Content(dialog.ContentProps{Class: "max-w-lg"}) {
				<div id={ kanbanDialogContentID } class="grid gap-4"></div>
			}
		}
	</div>
}

templ dashboardMobileSidebarTrigger() {
	@sheet.Trigger(sheet.TriggerProps{For: "dashboard-sidebar-mobile", Class: "md:hidden shrink-0"}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 text-foreground hover:bg-muted focus-visible:ring-accent",
		}) {
			@icon.PanelLeft(icon.Props{Class: "size-4"})
			<span class="sr-only">Toggle Sidebar</span>
		}
	}
}

templ dashboardSSEMetricsScript() {
	<script>
			(function() {
				const reportEvery = 60000;
				const processingTimeout = 2500;
				const stallWarningAfter = 1200;
				const state = {
					events: {},
					pending: {},
					processing: {},
					reportTimer: 0,
					warningKey: "",
				};
				const encoder = window.TextEncoder ? new TextEncoder() : null;

				function metricsFor(name) {
					if (!state.events[name]) {
						state.events[name] = {
							received: 0,
							bytes: 0,
							swaps: 0,
							totalMs: 0,
							maxMs: 0,
							skipped: 0,
							queued: 0,
							replayed: 0,
							timeouts: 0,
							prevented: 0,
							swapErrors: 0,
							lastReceivedAt: "",
							lastQueuedAt: "",
							lastReplayAt: "",
							lastSwapAt: "",
						};
					}
					return state.events[name];
				}

				function timestamp() {
					return new Date().toISOString();
				}

				function byteLength(value) {
					const text = String(value || "");
					if (!text) {
						return 0;
					}
					return encoder ? encoder.encode(text).length : text.length;
				}

				function eventName(event) {
					const detail = event.detail || {};
					const message = detail.message || detail.event || {};
					return String(detail.type || detail.name || message.type || "message");
				}

				function eventPayload(event) {
					const detail = event.detail || {};
					const message = detail.message || detail.event || {};
					return message.data || detail.data || "";
				}

				function pendingKey(target, name) {
					if (target && target.id) {
						return target.id;
					}
					if (target && target.getAttribute) {
						return target.getAttribute("sse-swap") || name || "message";
					}
					return name || "message";
				}

				function pendingCount(name) {
					let count = 0;
					Object.keys(state.pending).forEach(function(key) {
						if (state.pending[key].name === name) {
							count += 1;
						}
					});
					return count;
				}

				function processingCount(name) {
					let count = 0;
					Object.keys(state.processing).forEach(function(key) {
						if (state.processing[key].name === name) {
							count += 1;
						}
					});
					return count;
				}

				function parseDelay(value) {
					if (window.htmx && typeof window.htmx.parseInterval === "function") {
						return window.htmx.parseInterval(value);
					}
					if (value.slice(-2) === "ms") {
						return Number(value.slice(0, -2)) || 0;
					}
					if (value.slice(-1) === "s") {
						return (Number(value.slice(0, -1)) || 0) * 1000;
					}
					return Number(value) || 0;
				}

				function swapSpecFor(target) {
					const spec = { swapStyle: "innerHTML" };
					const raw = String(target.getAttribute("hx-swap") || "").trim();
					if (!raw) {
						return spec;
					}
					const modifierNames = {
						swap: true,
						settle: true,
						transition: true,
						ignoreTitle: true,
						scroll: true,
						show: true,
						focusScroll: true,
						"focus-scroll": true,
					};
					raw.split(/\s+/).forEach(function(token, index) {
						const separator = token.indexOf(":");
						const name = separator >= 0 ? token.slice(0, separator) : token;
						const value = separator >= 0 ? token.slice(separator + 1) : "";
						if (index === 0 && !modifierNames[name]) {
							spec.swapStyle = token;
							return;
						}
						if (name === "swap") {
							spec.swapDelay = parseDelay(value);
						} else if (name === "settle") {
							spec.settleDelay = parseDelay(value);
						} else if (name === "transition") {
							spec.transition = value === "true";
						} else if (name === "ignoreTitle") {
							spec.ignoreTitle = value === "true";
						}
					});
					return spec;
				}

				function targetForEventName(name) {
					const targets = document.querySelectorAll("[sse-swap]");
					for (const target of targets) {
						if (target.getAttribute("sse-swap") === name) {
							return target;
						}
					}
					return null;
				}

				function swapTarget(event) {
					const detailTarget = event.detail && event.detail.target;
					const target = detailTarget instanceof Element ? detailTarget : event.target;
					if (!(target instanceof Element)) {
						return null;
					}
					if (target.hasAttribute("sse-swap")) {
						return target;
					}
					return target.closest("[sse-swap]");
				}

				function targetForProcessing(processing) {
					if (!processing) {
						return null;
					}
					if (processing.targetID) {
						const target = document.getElementById(processing.targetID);
						if (target) {
							return target;
						}
					}
					return targetForEventName(processing.sseSwap || processing.name);
				}

				function clearTargetProcessingDataset(target, key) {
					if (!(target instanceof HTMLElement)) {
						return;
					}
					if (key && target.dataset.detentSseKey && target.dataset.detentSseKey !== key) {
						return;
					}
					delete target.dataset.detentSseProcessing;
					delete target.dataset.detentSseEvent;
					delete target.dataset.detentSseStarted;
					delete target.dataset.detentSseTimer;
					delete target.dataset.detentSseKey;
				}

				function clearProcessingKey(key) {
					const processing = state.processing[key];
					if (!processing) {
						return;
					}
					if (processing.timer) {
						window.clearTimeout(processing.timer);
					}
					if (processing.warningTimer) {
						window.clearTimeout(processing.warningTimer);
					}
					clearTargetProcessingDataset(targetForProcessing(processing), key);
					delete state.processing[key];
					if (state.warningKey === key && !state.pending[key]) {
						state.warningKey = "";
					}
					updateWarning();
				}

				function markProcessing(target, name) {
					if (!(target instanceof Element)) {
						return "";
					}
					const key = pendingKey(target, name);
					clearProcessingKey(key);
					const started = performance.now();
					const processing = {
						name: name,
						targetID: target.id || "",
						sseSwap: target.getAttribute("sse-swap") || name,
						started: started,
						timer: 0,
						warningTimer: 0,
					};
					processing.warningTimer = window.setTimeout(function() {
						if (state.processing[key]) {
							state.warningKey = key;
							updateWarning();
							scheduleReport();
						}
					}, stallWarningAfter);
					processing.timer = window.setTimeout(function() {
						if (!state.processing[key]) {
							return;
						}
						metricsFor(processing.name).timeouts += 1;
						state.warningKey = key;
						clearProcessingKey(key);
						replayPendingKey(key);
						scheduleReport();
					}, processingTimeout);
					state.processing[key] = processing;
					if (target instanceof HTMLElement) {
						target.dataset.detentSseProcessing = "true";
						target.dataset.detentSseEvent = name;
						target.dataset.detentSseStarted = String(started);
						target.dataset.detentSseTimer = String(processing.timer);
						target.dataset.detentSseKey = key;
					}
					updateWarning();
					return key;
				}

				function rememberPending(target, name, payload) {
					const key = pendingKey(target, name);
					state.pending[key] = {
						name: name,
						payload: payload,
						targetID: target.id || "",
						sseSwap: target.getAttribute("sse-swap") || name,
						swapSpec: swapSpecFor(target),
						queuedAt: performance.now(),
					};
					const metrics = metricsFor(name);
					metrics.queued += 1;
					metrics.lastQueuedAt = timestamp();
				}

				function targetForPending(pending) {
					if (pending.targetID) {
						const target = document.getElementById(pending.targetID);
						if (target) {
							return target;
						}
					}
					return targetForEventName(pending.sseSwap || pending.name);
				}

				function replayPending(target, name) {
					const key = pendingKey(target, name);
					replayPendingKey(key);
				}

				function replayPendingKey(key) {
					const pending = state.pending[key];
					if (!pending) {
						return;
					}
					delete state.pending[key];
					const nextTarget = targetForPending(pending);
					if (!(nextTarget instanceof Element) || !nextTarget.isConnected) {
						metricsFor(pending.name).swapErrors += 1;
						updateWarning();
						return;
					}
					const metrics = metricsFor(pending.name);
					metrics.replayed += 1;
					metrics.lastReplayAt = timestamp();
					markProcessing(nextTarget, pending.name);
					window.setTimeout(function() {
						if (!(nextTarget instanceof Element) || !nextTarget.isConnected) {
							metricsFor(pending.name).swapErrors += 1;
							clearProcessingKey(key);
							scheduleReport();
							return;
						}
						if (window.htmx && typeof window.htmx.swap === "function") {
							try {
								window.htmx.swap(nextTarget, pending.payload, pending.swapSpec, {
									contextElement: nextTarget,
									eventInfo: { target: nextTarget, source: nextTarget },
									afterSettleCallback: function() {
										const settledTarget = targetForPending(pending) || nextTarget;
										settleProcessing(settledTarget, pending.name);
									},
								});
								return;
							} catch (error) {
								metricsFor(pending.name).swapErrors += 1;
								if (window.console && console.warn) {
									console.warn("[detent] SSE replay swap failed", error);
								}
							}
						}
						nextTarget.innerHTML = pending.payload;
						settleProcessing(nextTarget, pending.name);
						scheduleReport();
					}, 0);
				}

				function settleProcessing(target, name) {
					if (!(target instanceof Element)) {
						return;
					}
					const key = pendingKey(target, name);
					const processing = state.processing[key];
					if (processing) {
						const duration = performance.now() - processing.started;
						const metrics = metricsFor(processing.name);
						metrics.swaps += 1;
						metrics.totalMs += duration;
						metrics.maxMs = Math.max(metrics.maxMs, duration);
						metrics.lastSwapAt = timestamp();
					}
					clearProcessingKey(key);
					replayPendingKey(key);
					scheduleReport();
				}

				function metricsSnapshot() {
					const snapshot = {};
					Object.keys(state.events).sort().forEach(function(name) {
						const metrics = state.events[name];
						const averageMs = metrics.swaps > 0 ? metrics.totalMs / metrics.swaps : 0;
						snapshot[name] = {
							received: metrics.received,
							bytes: metrics.bytes,
							swaps: metrics.swaps,
							averageMs: Math.round(averageMs * 10) / 10,
							maxMs: Math.round(metrics.maxMs * 10) / 10,
							skipped: metrics.skipped,
							queued: metrics.queued,
							replayed: metrics.replayed,
							timeouts: metrics.timeouts,
							prevented: metrics.prevented,
							swapErrors: metrics.swapErrors,
							pending: pendingCount(name),
							processing: processingCount(name),
							lastReceivedAt: metrics.lastReceivedAt,
							lastQueuedAt: metrics.lastQueuedAt,
							lastReplayAt: metrics.lastReplayAt,
							lastSwapAt: metrics.lastSwapAt,
						};
					});
					return snapshot;
				}

				function diagnosticsFor(name) {
					const metrics = metricsSnapshot()[name] || {};
					const status = document.documentElement.dataset.detentSseStatus || "unknown";
					return [
						"stream=" + status,
						"event=" + name,
						"received=" + (metrics.received || 0),
						"swaps=" + (metrics.swaps || 0),
						"queued=" + (metrics.queued || 0),
						"pending=" + (metrics.pending || 0),
						"processing=" + (metrics.processing || 0),
						"replayed=" + (metrics.replayed || 0),
						"timeouts=" + (metrics.timeouts || 0),
						"errors=" + (metrics.swapErrors || 0),
					].join(" ");
				}

				function updateWarning() {
					const warning = document.querySelector("[data-detent-sse-warning]");
					if (!(warning instanceof HTMLElement)) {
						return;
					}
					let key = state.warningKey;
					if (!key || (!state.processing[key] && !state.pending[key])) {
						key = "";
						const now = performance.now();
						Object.keys(state.processing).some(function(candidate) {
							const processing = state.processing[candidate];
							if (processing && now - processing.started >= stallWarningAfter) {
								key = candidate;
								return true;
							}
							return false;
						});
					}
					if (!key) {
						warning.hidden = true;
						warning.classList.add("hidden");
						state.warningKey = "";
						return;
					}
					state.warningKey = key;
					const pending = state.pending[key];
					const processing = state.processing[key];
					const name = (pending && pending.name) || (processing && processing.name) || "snapshot";
					const message = warning.querySelector("[data-detent-sse-warning-message]");
					const metrics = warning.querySelector("[data-detent-sse-warning-metrics]");
					if (message) {
						message.textContent = name + " events are queued or replaying, but the page has not settled yet.";
					}
					if (metrics) {
						metrics.textContent = diagnosticsFor(name);
					}
					warning.hidden = false;
					warning.classList.remove("hidden");
				}

				function scheduleReport() {
					if (state.reportTimer) {
						return;
					}
					state.reportTimer = window.setTimeout(report, reportEvery);
				}

				function report() {
					state.reportTimer = 0;
					const snapshot = metricsSnapshot();
					if (window.console && console.info) {
						console.info("[detent] SSE metrics", snapshot);
					}
					scheduleReport();
				}

				document.addEventListener("htmx:sseBeforeMessage", function(event) {
					const name = eventName(event);
					const metrics = metricsFor(name);
					const payload = eventPayload(event);
					metrics.received += 1;
					metrics.bytes += byteLength(payload);
					metrics.lastReceivedAt = timestamp();
					const target = swapTarget(event) || targetForEventName(name);
					if (!target) {
						scheduleReport();
						return;
					}
					const key = pendingKey(target, name);
					if (state.processing[key] && name !== "tick") {
						metrics.skipped += 1;
						rememberPending(target, name, payload);
						event.preventDefault();
						scheduleReport();
						updateWarning();
						return;
					}
					const processingKey = markProcessing(target, name);
					window.setTimeout(function() {
						if (event.defaultPrevented && state.processing[processingKey]) {
							metrics.prevented += 1;
							clearProcessingKey(processingKey);
							scheduleReport();
						}
					}, 0);
					scheduleReport();
				});

				document.addEventListener("htmx:beforeSwap", function(event) {
					const target = swapTarget(event);
					if (!target) {
						return;
					}
					markProcessing(target, target.dataset.detentSseEvent || target.getAttribute("sse-swap") || "message");
				});

				document.addEventListener("htmx:afterSettle", function(event) {
					const target = swapTarget(event);
					if (!target) {
						return;
					}
					const name = target.dataset.detentSseEvent || target.getAttribute("sse-swap") || "message";
					settleProcessing(target, name);
				});

				document.addEventListener("htmx:sseOpen", function() {
					document.documentElement.dataset.detentSseStatus = "open";
				});
				document.addEventListener("htmx:sseError", function() {
					document.documentElement.dataset.detentSseStatus = "error";
				});
				document.addEventListener("htmx:sseClose", function() {
					document.documentElement.dataset.detentSseStatus = "closed";
				});

				window.__detentSSEMetrics = {
					events: state.events,
					pending: state.pending,
					processing: state.processing,
					snapshot: metricsSnapshot,
					diagnostics: diagnosticsFor,
					report: report,
				};
			})();
		</script>
}

templ dashboardSidebarFilterScript() {
	<script>
			(function() {
			document.addEventListener("input", function(event) {
				const input = event.target.closest("[data-dashboard-project-filter]");
				if (!input) {
					return;
				}
				const query = input.value.trim().toLowerCase();
				document.querySelectorAll("[data-dashboard-project-entry]").forEach(function(entry) {
					const name = (entry.dataset.projectName || "").toLowerCase();
					entry.hidden = query !== "" && !name.includes(query);
				});
			});
		})();
	</script>
}

templ dashboardSidebarActiveScript() {
	<script>
		(function() {
			function sidebarContent() {
				return document.getElementById("dashboard-sidebar-live");
			}

			function staticNavForLocation() {
				const path = window.location.pathname;
				if (path === "/kanban") {
					return "kanban";
				}
				if (path === "/health/ui") {
					return "health";
				}
				return "";
			}

			function projectViewForLocation() {
				const path = window.location.pathname;
				if (path === "/settings" && new URLSearchParams(window.location.search).get("project")) {
					return "configuration";
				}
				if (!path.startsWith("/projects/")) {
					return "";
				}
				if (path.endsWith("/kanban")) {
					return "kanban";
				}
				if (path.endsWith("/runs")) {
					return "runs";
				}
				if (path.endsWith("/diagnostics")) {
					return "diagnostics";
				}
				if (path.endsWith("/configuration")) {
					return "configuration";
				}
				if (window.location.hash === "#running-issues") {
					return "runs";
				}
				if (window.location.hash === "#dashboard-diagnostics") {
					return "diagnostics";
				}
				return "overview";
			}

			function setActive(link, active) {
				if (!(link instanceof HTMLElement)) {
					return;
				}
				if (active) {
					link.dataset.tuiSidebarActive = "true";
					link.setAttribute("aria-current", "page");
					return;
				}
				link.removeAttribute("data-tui-sidebar-active");
				link.removeAttribute("aria-current");
			}

			function applyProjectSidebarActiveState() {
				const staticNav = staticNavForLocation();
				const view = projectViewForLocation();
				if (!staticNav && !view) {
					return;
				}
				const root = sidebarContent();
				if (!root) {
					return;
				}
				root.querySelectorAll("[data-dashboard-view-nav], [data-dashboard-static-nav]").forEach(function(link) {
					setActive(link, false);
				});
				if (staticNav) {
					setActive(root.querySelector("[data-dashboard-static-nav='" + staticNav + "']"), true);
					return;
				}
				setActive(root.querySelector("[data-dashboard-view='" + view + "']"), true);
			}

			document.addEventListener("click", function(event) {
				const link = event.target instanceof Element ? event.target.closest("[data-dashboard-view-nav]") : null;
				if (link) {
					window.requestAnimationFrame(applyProjectSidebarActiveState);
				}
			});
			window.addEventListener("hashchange", applyProjectSidebarActiveState);
			document.addEventListener("htmx:afterSettle", applyProjectSidebarActiveState);
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", applyProjectSidebarActiveState);
			} else {
				applyProjectSidebarActiveState();
			}
		})();
	</script>
}

templ diagnosticsTabsScript() {
	<script>
		(function() {
			if (window.__detentDiagnosticsTabsRegistered) {
				return;
			}
			window.__detentDiagnosticsTabsRegistered = true;

			function tabStorage() {
				try {
					return window.localStorage;
				} catch (error) {
					return null;
				}
			}

			function tabRoots() {
				return Array.from(document.querySelectorAll("[data-diagnostics-tabs]"));
			}

			function tabs(root) {
				return Array.from(root.querySelectorAll("[data-diagnostics-tab]"));
			}

			function panels(root) {
				return Array.from(root.querySelectorAll("[data-diagnostics-panel]"));
			}

			function storageName(root) {
				return root.dataset.diagnosticsStorageName || "detent.ui.diagnostics.selectedTab.fleet";
			}

			function hasTab(root, id) {
				return tabs(root).some(function(tab) {
					return tab.dataset.diagnosticsTab === id;
				});
			}

			function activeTabID(root) {
				const active = tabs(root).find(function(tab) {
					return tab.getAttribute("aria-selected") === "true";
				});
				return active ? active.dataset.diagnosticsTab : "overview";
			}

			function setActiveTab(root, id, persist) {
				if (!hasTab(root, id)) {
					id = "overview";
				}
				tabs(root).forEach(function(tab) {
					const active = tab.dataset.diagnosticsTab === id;
					tab.setAttribute("aria-selected", active ? "true" : "false");
					tab.setAttribute("tabindex", active ? "0" : "-1");
					tab.dataset.diagnosticsActive = active ? "true" : "false";
				});
				panels(root).forEach(function(panel) {
					panel.hidden = panel.dataset.diagnosticsPanel !== id;
				});
				if (persist) {
					const store = tabStorage();
					if (store) {
						store.setItem(storageName(root), id);
					}
				}
			}

			function restoreTabs(root) {
				const store = tabStorage();
				const saved = store ? store.getItem(storageName(root)) : "";
				setActiveTab(root, saved || activeTabID(root), false);
			}

			function moveFocus(tab, offset) {
				const root = tab.closest("[data-diagnostics-tabs]");
				if (!root) {
					return;
				}
				const list = tabs(root);
				const index = list.indexOf(tab);
				if (index < 0) {
					return;
				}
				const next = list[(index + offset + list.length) % list.length];
				next.focus();
				setActiveTab(root, next.dataset.diagnosticsTab || "overview", true);
			}

			document.addEventListener("click", function(event) {
				const tab = event.target instanceof Element ? event.target.closest("[data-diagnostics-tab]") : null;
				if (!tab) {
					return;
				}
				const root = tab.closest("[data-diagnostics-tabs]");
				if (!root) {
					return;
				}
				setActiveTab(root, tab.dataset.diagnosticsTab || "overview", true);
			});

			document.addEventListener("keydown", function(event) {
				const tab = event.target instanceof Element ? event.target.closest("[data-diagnostics-tab]") : null;
				if (!tab) {
					return;
				}
				const root = tab.closest("[data-diagnostics-tabs]");
				if (!root) {
					return;
				}
				if (event.key === "ArrowRight") {
					event.preventDefault();
					moveFocus(tab, 1);
				} else if (event.key === "ArrowLeft") {
					event.preventDefault();
					moveFocus(tab, -1);
				} else if (event.key === "Home") {
					event.preventDefault();
					const first = tabs(root)[0];
					if (first) {
						first.focus();
						setActiveTab(root, first.dataset.diagnosticsTab || "overview", true);
					}
				} else if (event.key === "End") {
					event.preventDefault();
					const list = tabs(root);
					const last = list[list.length - 1];
					if (last) {
						last.focus();
						setActiveTab(root, last.dataset.diagnosticsTab || "overview", true);
					}
				}
			});

			document.addEventListener("htmx:afterSettle", function() {
				tabRoots().forEach(restoreTabs);
			});

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", function() {
					tabRoots().forEach(restoreTabs);
				});
			} else {
				tabRoots().forEach(restoreTabs);
			}
		})();
	</script>
}

templ dashboardSidebarProjectOrderScript() {
	<script>
		(function() {
			const storageKey = "detent.ui.projectOrder";
			const storageVersion = 1;
			let draggingProjectID = "";
			let pendingApplyFrame = 0;
			let observedSidebar = null;
			let sidebarObserver = null;

			function projectOrderStorage() {
				try {
					return window.localStorage;
				} catch (error) {
					return null;
				}
			}

			function projectList() {
				return document.querySelector("[data-dashboard-project-order-list]");
			}

			function projectEntries() {
				const list = projectList();
				if (!list) {
					return [];
				}
				return Array.from(list.children).filter(function(child) {
					return child instanceof HTMLElement && child.hasAttribute("data-dashboard-project-entry");
				});
			}

			function projectEntryFor(target) {
				if (!(target instanceof Element)) {
					return null;
				}
				return target.closest("[data-dashboard-project-entry]");
			}

			function sidebarWrapper() {
				return document.querySelector("[data-tui-sidebar-wrapper][data-tui-sidebar-id='dashboard-sidebar']");
			}

			function sidebarCollapsed() {
				const wrapper = sidebarWrapper();
				return Boolean(wrapper && wrapper.dataset.tuiSidebarState === "collapsed");
			}

			function projectFilterActive() {
				const input = document.querySelector("[data-dashboard-project-filter]");
				return input instanceof HTMLInputElement && input.value.trim() !== "";
			}

			function savedProjectOrder() {
				const store = projectOrderStorage();
				if (!store) {
					return [];
				}
				let parsed = null;
				try {
					parsed = JSON.parse(store.getItem(storageKey) || "");
				} catch (error) {
					return [];
				}
				if (!parsed || parsed.v !== storageVersion || !Array.isArray(parsed.order)) {
					return [];
				}
				const seen = new Set();
				return parsed.order.filter(function(id) {
					if (typeof id !== "string" || id.trim() === "" || seen.has(id)) {
						return false;
					}
					seen.add(id);
					return true;
				});
			}

			function currentProjectOrder() {
				return projectEntries().map(function(entry) {
					return entry.dataset.projectId || "";
				}).filter(Boolean);
			}

			function setManualOrderState(manual) {
				const list = projectList();
				if (list) {
					list.dataset.projectOrderManual = manual ? "true" : "false";
				}
				const reset = document.querySelector("[data-dashboard-project-order-reset]");
				if (reset instanceof HTMLButtonElement) {
					reset.disabled = !manual;
				}
			}

			function saveProjectOrder(order) {
				const store = projectOrderStorage();
				if (!store) {
					return;
				}
				store.setItem(storageKey, JSON.stringify({ v: storageVersion, order: order }));
				setManualOrderState(true);
			}

			function clearProjectOrder() {
				const store = projectOrderStorage();
				if (store) {
					store.removeItem(storageKey);
				}
				setManualOrderState(false);
			}

			function defaultProjectIndex(entry, fallback) {
				const index = Number(entry.dataset.projectDefaultIndex);
				return Number.isFinite(index) ? index : fallback;
			}

			function restoreDefaultOrder() {
				const list = projectList();
				if (!list) {
					return;
				}
				projectEntries().map(function(entry, index) {
					return { entry: entry, index: index, rank: defaultProjectIndex(entry, index) };
				}).sort(function(left, right) {
					return left.rank - right.rank || left.index - right.index;
				}).forEach(function(item) {
					list.appendChild(item.entry);
				});
			}

			function orderProjectNodes(order) {
				const list = projectList();
				if (!list || order.length === 0) {
					return;
				}
				const entries = projectEntries();
				const nodesByID = new Map();
				entries.forEach(function(entry) {
					const id = entry.dataset.projectId || "";
					if (id && !nodesByID.has(id)) {
						nodesByID.set(id, entry);
					}
				});
				const ordered = [];
				const orderedIDs = new Set();
				order.forEach(function(id) {
					const entry = nodesByID.get(id);
					if (!entry) {
						return;
					}
					ordered.push(entry);
					orderedIDs.add(id);
				});
				entries.forEach(function(entry) {
					const id = entry.dataset.projectId || "";
					if (!orderedIDs.has(id)) {
						ordered.push(entry);
					}
				});
				ordered.forEach(function(entry) {
					list.appendChild(entry);
				});
			}

			function reorderAvailable() {
				return projectEntries().length > 1 && !sidebarCollapsed() && !projectFilterActive();
			}

			function setButtonDisabled(button, disabled) {
				if (!(button instanceof HTMLButtonElement)) {
					return;
				}
				button.disabled = disabled;
				button.setAttribute("aria-disabled", disabled ? "true" : "false");
			}

			function updateProjectControls() {
				const list = projectList();
				const entries = projectEntries();
				const available = reorderAvailable();
				if (list) {
					list.dataset.projectOrderEnabled = available ? "true" : "false";
				}
				entries.forEach(function(entry, index) {
					entry.draggable = available;
					entry.setAttribute("aria-grabbed", draggingProjectID === entry.dataset.projectId ? "true" : "false");
					entry.dataset.projectOrderReady = available ? "true" : "false";
					setButtonDisabled(entry.querySelector("[data-dashboard-project-move='up']"), !available || index === 0);
					setButtonDisabled(entry.querySelector("[data-dashboard-project-move='down']"), !available || index === entries.length - 1);
				});
				setManualOrderState(savedProjectOrder().length > 0);
			}

			function observeSidebarState() {
				const wrapper = sidebarWrapper();
				if (wrapper === observedSidebar) {
					return;
				}
				if (sidebarObserver) {
					sidebarObserver.disconnect();
					sidebarObserver = null;
				}
				observedSidebar = wrapper;
				if (!wrapper || !("MutationObserver" in window)) {
					return;
				}
				sidebarObserver = new MutationObserver(function() {
					updateProjectControls();
				});
				sidebarObserver.observe(wrapper, { attributes: true, attributeFilter: ["data-tui-sidebar-state"] });
			}

			function applySavedProjectOrder() {
				if (draggingProjectID) {
					updateProjectControls();
					return;
				}
				const order = savedProjectOrder();
				if (order.length > 0) {
					orderProjectNodes(order);
				}
				updateProjectControls();
				observeSidebarState();
			}

			function scheduleApplySavedProjectOrder() {
				if (pendingApplyFrame) {
					return;
				}
				pendingApplyFrame = window.requestAnimationFrame(function() {
					pendingApplyFrame = 0;
					applySavedProjectOrder();
				});
			}

			function rowBeforePointer(clientY) {
				let candidate = null;
				let candidateOffset = Number.NEGATIVE_INFINITY;
				projectEntries().forEach(function(entry) {
					if (entry.dataset.projectId === draggingProjectID) {
						return;
					}
					const rect = entry.getBoundingClientRect();
					const offset = clientY - rect.top - rect.height / 2;
					if (offset < 0 && offset > candidateOffset) {
						candidateOffset = offset;
						candidate = entry;
					}
				});
				return candidate;
			}

			function clearDragState() {
				projectEntries().forEach(function(entry) {
					entry.classList.remove("dashboard-project-entry-dragging");
					entry.setAttribute("aria-grabbed", "false");
				});
				draggingProjectID = "";
				updateProjectControls();
			}

			function sidebarSwapTarget(event) {
				const detailTarget = event.detail && event.detail.target;
				const target = detailTarget instanceof Element ? detailTarget : event.target;
				if (!(target instanceof Element)) {
					return null;
				}
				if (target.id === "dashboard-sidebar-live") {
					return target;
				}
				return target.closest("#dashboard-sidebar-live");
			}

			function moveProject(entry, direction) {
				const list = projectList();
				const entries = projectEntries();
				const index = entries.indexOf(entry);
				if (!list || index < 0) {
					return;
				}
				if (direction === "up" && index > 0) {
					list.insertBefore(entry, entries[index - 1]);
				}
				if (direction === "down" && index < entries.length - 1) {
					list.insertBefore(entry, entries[index + 2] || null);
				}
				saveProjectOrder(currentProjectOrder());
				updateProjectControls();
				const button = entry.querySelector("[data-dashboard-project-move='" + direction + "']");
				if (button instanceof HTMLButtonElement) {
					button.focus();
				}
			}

			document.addEventListener("dragstart", function(event) {
				const target = event.target instanceof Element ? event.target : null;
				const entry = projectEntryFor(target);
				if (!entry) {
					return;
				}
				if (!reorderAvailable() || (target && target.closest("[data-dashboard-project-order-controls]"))) {
					event.preventDefault();
					return;
				}
				draggingProjectID = entry.dataset.projectId || "";
				if (!draggingProjectID) {
					event.preventDefault();
					return;
				}
				entry.classList.add("dashboard-project-entry-dragging");
				entry.setAttribute("aria-grabbed", "true");
				if (event.dataTransfer) {
					event.dataTransfer.effectAllowed = "move";
					event.dataTransfer.setData("text/plain", draggingProjectID);
				}
			});

			document.addEventListener("dragover", function(event) {
				if (!draggingProjectID || !reorderAvailable()) {
					return;
				}
				const list = projectList();
				const target = event.target instanceof Element ? event.target : null;
				if (!list || !target || (target !== list && !list.contains(target))) {
					return;
				}
				const dragged = projectEntries().find(function(entry) {
					return entry.dataset.projectId === draggingProjectID;
				});
				if (!dragged) {
					return;
				}
				event.preventDefault();
				const before = rowBeforePointer(event.clientY);
				if (before) {
					list.insertBefore(dragged, before);
				} else {
					list.appendChild(dragged);
				}
				updateProjectControls();
			});

			document.addEventListener("drop", function(event) {
				if (!draggingProjectID) {
					return;
				}
				event.preventDefault();
				saveProjectOrder(currentProjectOrder());
				clearDragState();
			});

			document.addEventListener("dragend", function() {
				if (draggingProjectID) {
					clearDragState();
				}
			});

			document.addEventListener("click", function(event) {
				const reset = event.target instanceof Element ? event.target.closest("[data-dashboard-project-order-reset]") : null;
				if (reset) {
					event.preventDefault();
					clearProjectOrder();
					restoreDefaultOrder();
					updateProjectControls();
					return;
				}
				const button = event.target instanceof Element ? event.target.closest("[data-dashboard-project-move]") : null;
				if (button instanceof HTMLButtonElement) {
					event.preventDefault();
					if (!reorderAvailable() || button.disabled) {
						return;
					}
					const entry = projectEntryFor(button);
					if (entry) {
						moveProject(entry, button.dataset.dashboardProjectMove || "");
					}
				}
			});

			document.addEventListener("input", function(event) {
				const input = event.target instanceof Element ? event.target.closest("[data-dashboard-project-filter]") : null;
				if (input) {
					updateProjectControls();
				}
			});

			document.addEventListener("htmx:beforeSwap", function(event) {
				if (draggingProjectID && sidebarSwapTarget(event)) {
					event.preventDefault();
				}
			});

			document.addEventListener("htmx:afterSettle", function() {
				scheduleApplySavedProjectOrder();
			});

			window.addEventListener("storage", function(event) {
				if (event.key === storageKey) {
					scheduleApplySavedProjectOrder();
				}
			});

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", applySavedProjectOrder);
			} else {
				applySavedProjectOrder();
			}
		})();
	</script>
}

templ dashboardSidebar(data DashboardShellData) {
	@sidebar.Sidebar(sidebar.Props{
		ID:          "dashboard-sidebar",
		Collapsible: sidebar.CollapsibleIcon,
		Collapsed:   data.SidebarCollapsed,
		Class:       "dashboard-sidebar text-sidebar-foreground",
	}) {
		@sidebar.Header(sidebar.HeaderProps{Class: "flex-row items-center justify-between border-b border-sidebar-border group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:justify-center"}) {
			<a class="inline-flex min-h-8 min-w-0 shrink-0 items-center gap-2 text-sidebar-foreground hover:text-sidebar-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sidebar-ring group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden" href="/" aria-label="Detent dashboard">
				<span class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded bg-sidebar-accent font-semibold text-sidebar-accent-foreground">D</span>
				<span class="truncate text-sm font-semibold">Detent</span>
				if data.InstanceName != "" {
					<span class="max-w-[8rem] truncate rounded-full border border-sidebar-border bg-sidebar-accent px-2 py-0.5 font-mono text-xs font-medium text-sidebar-accent-foreground" aria-label="Instance name">{ data.InstanceName }</span>
				}
			</a>
			@sidebar.Trigger(sidebar.TriggerProps{
				Target: "dashboard-sidebar",
				Class:  "text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			})
		}
		@sidebar.Content(sidebar.ContentProps{
			ID:    "dashboard-sidebar-live",
			Class: "dashboard-sidebar-content",
			Attributes: templ.Attributes{
				"sse-swap": "sidebar",
				"hx-swap":  "morph:innerHTML",
			},
		}) {
			@DashboardSidebarContent(data)
		}
		@dashboardProjectOrderFooter()
	}
	@dashboardSidebarFilterScript()
	@dashboardSidebarActiveScript()
	@dashboardSidebarProjectOrderScript()
}

templ dashboardProjectOrderFooter() {
	@sidebar.Footer(sidebar.FooterProps{Class: "border-t border-sidebar-border group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden"}) {
		@button.Button(button.Props{
			Variant:   button.VariantGhost,
			Size:      button.SizeSm,
			FullWidth: true,
			Class:     "justify-start px-2 text-xs text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			Attributes: templ.Attributes{
				"data-dashboard-project-order-reset": true,
				"aria-label":                         "Reset project order",
			},
		}) {
			@icon.RotateCcw(icon.Props{Class: "size-3.5 shrink-0"})
			<span>Reset order</span>
		}
	}
}

templ DashboardSidebarContent(data DashboardShellData) {
	@sidebar.Group() {
		@sidebar.Menu() {
			@sidebar.MenuItem() {
				@sidebar.MenuButton(sidebar.MenuButtonProps{
					Href:       "/",
					IsActive:   sidebarFleetActive(data),
					Tooltip:    sidebarFleetTooltip(data),
					Attributes: sidebarAriaCurrent(sidebarFleetActive(data)),
				}) {
					@icon.LayoutDashboard(icon.Props{Class: "size-4 shrink-0"})
					<span>Fleet</span>
				}
			}
			if fleetKanbanNavVisible(data) {
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       "/kanban",
						IsActive:   fleetKanbanNavActive(data),
						Tooltip:    "Fleet Kanban",
						Attributes: fleetKanbanNavAttributes(data),
					}) {
						@icon.Kanban(icon.Props{Class: "size-4 shrink-0"})
						<span>Kanban</span>
					}
				}
			}
		}
		if sidebarFilterVisible(data) {
			<label class="grid gap-1 px-2 group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden">
				<span class="sr-only">{ sidebarProjectSearchLabel(data) }</span>
				<input id="dashboard-project-filter" name="project_filter" type="search" class="min-h-9 rounded-md border border-sidebar-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-sidebar-ring focus:outline-none focus:ring-2 focus:ring-sidebar-ring" placeholder="Filter projects" data-dashboard-project-filter/>
			</label>
		}
		@sidebar.Menu(sidebar.MenuProps{
			Class: "dashboard-sidebar-projects",
			Attributes: templ.Attributes{
				"data-dashboard-project-order-list": true,
			},
		}) {
			for _, item := range sidebarProjectItems(data) {
				@sidebar.MenuItem(sidebar.MenuItemProps{
					Class:      "dashboard-project-entry",
					Attributes: sidebarProjectItemAttributes(item),
				}) {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       item.Href,
						IsActive:   item.Active,
						Tooltip:    sidebarProjectTooltip(item),
						Class:      "dashboard-project-menu-button",
						Attributes: sidebarProjectButtonAttributes(item),
					}) {
						if sidebarProjectOrderAvailable(data) {
							<span class="dashboard-project-drag-handle group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden" data-dashboard-project-drag-handle aria-hidden="true">
								@icon.GripVertical(icon.Props{Class: "size-3.5"})
							</span>
						}
						<span class="inline-flex h-4 w-1.5 shrink-0 rounded-full border border-sidebar-border" aria-label={ item.Name + " project color" } title={ "Project color: " + item.Name } { projectColorAttributes(item.ProjectColor)... }></span>
						<span class={ "inline-flex size-2.5 shrink-0 rounded-full " + item.DotClass }></span>
						<span>{ item.Name }</span>
						@sidebar.MenuBadge(sidebar.MenuBadgeProps{
							Class: "font-mono " + item.BadgeClass,
							Attributes: templ.Attributes{
								"aria-label": item.RunningLabel,
								"title":      item.RunningLabel,
							},
						}) {
							{ item.CountLabel }
						}
					}
					if sidebarProjectOrderAvailable(data) {
						@dashboardProjectOrderControls(item)
					}
				}
			}
		}
	}
	if projectSidebarNavVisible(data) {
		@sidebar.Separator()
		@sidebar.Group(sidebar.GroupProps{
			Attributes: templ.Attributes{
				"aria-label": "Project views",
			},
		}) {
			@sidebar.GroupLabel() {
				<span>Project views</span>
			}
			@sidebar.Menu() {
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarOverviewPath(data),
						IsActive:   projectSidebarOverviewActive(data),
						Tooltip:    "Project overview",
						Attributes: projectSidebarViewAttributes(data, "overview"),
					}) {
						@icon.LayoutDashboard(icon.Props{Class: "size-4 shrink-0"})
						<span>Overview</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarKanbanPath(data),
						IsActive:   projectSidebarKanbanActive(data),
						Tooltip:    "Project Kanban",
						Attributes: projectSidebarViewAttributes(data, "kanban"),
					}) {
						@icon.Kanban(icon.Props{Class: "size-4 shrink-0"})
						<span>Kanban</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarRunsPath(data),
						IsActive:   projectSidebarRunsActive(data),
						Tooltip:    "Project runs",
						Attributes: projectSidebarViewAttributes(data, "runs"),
					}) {
						@icon.Activity(icon.Props{Class: "size-4 shrink-0"})
						<span>Runs</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarConfigurationPath(data),
						IsActive:   projectSidebarConfigurationActive(data),
						Tooltip:    "Project configuration",
						Attributes: projectSidebarViewAttributes(data, "configuration"),
					}) {
						@icon.SlidersHorizontal(icon.Props{Class: "size-4 shrink-0"})
						<span>Configuration</span>
					}
				}
				@sidebar.MenuItem() {
					@sidebar.MenuButton(sidebar.MenuButtonProps{
						Href:       projectSidebarDiagnosticsPath(data),
						IsActive:   projectSidebarDiagnosticsActive(data),
						Tooltip:    "Project diagnostics",
						Attributes: projectSidebarViewAttributes(data, "diagnostics"),
					}) {
						@icon.Gauge(icon.Props{Class: "size-4 shrink-0"})
						<span>Diagnostics</span>
					}
				}
			}
		}
	}
	@sidebar.Separator()
	@sidebar.Group() {
		@sidebar.Menu() {
			@sidebar.MenuItem() {
				@GitHubAPIHealthSidebarItem(data)
			}
			@sidebar.MenuItem() {
				@sidebar.MenuButton(sidebar.MenuButtonProps{
					Href:       sidebarReportsPath(data),
					IsActive:   sidebarStaticNavActive(data, "reports"),
					Tooltip:    "Reports",
					Attributes: sidebarStaticNavAttributes(data, "reports"),
				}) {
					@icon.ChartNoAxesCombined(icon.Props{Class: "size-4 shrink-0"})
					<span>Reports</span>
				}
			}
			@sidebar.MenuItem() {
				@sidebar.MenuButton(sidebar.MenuButtonProps{
					Href:       sidebarSettingsPath(data),
					IsActive:   sidebarStaticNavActive(data, "settings"),
					Tooltip:    "Settings",
					Attributes: sidebarStaticNavAttributes(data, "settings"),
				}) {
					@icon.Settings(icon.Props{Class: "size-4 shrink-0"})
					<span>Settings</span>
				}
			}
		}
	}
}

templ dashboardProjectOrderControls(item sidebarProjectItem) {
	<div class="dashboard-project-order-controls group-data-[tui-sidebar-state=collapsed]:group-data-[tui-sidebar-collapsible=icon]:hidden" data-dashboard-project-order-controls>
		@button.Button(button.Props{
			Variant: button.VariantGhost,
			Size:    button.SizeIcon,
			Class:   "size-6 text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			Attributes: templ.Attributes{
				"data-dashboard-project-move": "up",
				"data-project-id":             item.ID,
				"aria-label":                  "Move " + item.Name + " up",
			},
		}) {
			@icon.ArrowUp(icon.Props{Class: "size-3.5"})
		}
		@button.Button(button.Props{
			Variant: button.VariantGhost,
			Size:    button.SizeIcon,
			Class:   "size-6 text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground focus-visible:ring-sidebar-ring",
			Attributes: templ.Attributes{
				"data-dashboard-project-move": "down",
				"data-project-id":             item.ID,
				"aria-label":                  "Move " + item.Name + " down",
			},
		}) {
			@icon.ArrowDown(icon.Props{Class: "size-3.5"})
		}
	</div>
}

templ dashboardCharts(data DashboardData) {
	<section id="dashboard-charts" class="dashboard-chart-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label={ chartPanelTitle(data) } hx-preserve data-detent-charts data-chart-endpoint={ chartEndpoint(data) }>
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				<h2 class="text-base font-semibold text-foreground">{ chartPanelTitle(data) }</h2>
				<p class="text-sm text-muted-foreground">{ chartPanelDescription(data) }</p>
			</div>
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground">Chart.js</span>
		</div>
		<div class="mt-4 grid min-w-0 gap-3 lg:grid-cols-3">
			<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
				<div class="mb-2 flex items-center justify-between gap-3">
					<h3 class="truncate text-sm font-medium text-foreground">Running agents</h3>
				</div>
				<div class="h-56 min-w-0">
					<canvas id="running-agents-chart" data-chart="running-agents" aria-label="Running agents over time"></canvas>
				</div>
			</div>
			if isProjectDashboard(data) {
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Token spend</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="token-spend-chart" data-chart="token-spend" aria-label="Token spend trend"></canvas>
					</div>
				</div>
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Board flow</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="board-flow-chart" data-chart="board-flow" aria-label="Board state flow over time"></canvas>
					</div>
				</div>
			} else {
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Tokens/sec</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="tokens-per-second-chart" data-chart="tokens-per-second" aria-label="Tokens per second trend"></canvas>
					</div>
				</div>
				<div class="min-w-0 rounded-md border border-border bg-muted/60 p-3">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="truncate text-sm font-medium text-foreground">Completions</h3>
					</div>
					<div class="h-56 min-w-0">
						<canvas id="completions-chart" data-chart="completions" aria-label="Completions per project"></canvas>
					</div>
				</div>
			}
		</div>
	</section>
}

templ SnapshotView(data DashboardData) {
	if isProjectDashboard(data) {
		@ProjectOverviewSnapshot(data)
	} else {
		@FleetSnapshot(data)
	}
}

templ ProjectOverviewSnapshot(data DashboardData) {
	@dashboardHealth(data)
	@trackerDriftWarning(data.Snapshot)
	if data.ProjectPaused {
		<section class="rounded-md border border-warning bg-warning-soft p-4 text-warning shadow-sm" aria-label="Paused project">
			<div class="flex items-start gap-3">
				<span class="mt-1 h-2.5 w-2.5 rounded-full bg-warning"></span>
				<div class="min-w-0">
					<h2 class="text-sm font-semibold">{ projectDisplayName(data) } is paused.</h2>
					<p class="mt-1 text-sm text-warning">Detent will keep showing telemetry, but this project is not dispatching new work.</p>
				</div>
			</div>
		</section>
	}
	if !snapshotReady(data.Snapshot) {
		@snapshotReadiness(data.Snapshot)
	} else {
		@statStrip(data.Snapshot)
		@projectOverviewSummarySection(data)
	}
}

templ ProjectRunsSnapshot(data DashboardData) {
	if !snapshotReady(data.Snapshot) {
		@snapshotReadiness(data.Snapshot)
	} else {
		@statStrip(data.Snapshot)
		@agentActivityTimeline(data.Snapshot)
		@prPipelineSection(data.Snapshot)
		<section class="dashboard-body-grid grid min-w-0 items-start gap-4 lg:grid-cols-[minmax(0,1fr)] lg:gap-5">
			<div class="dashboard-primary-column grid min-w-0 content-start gap-4 lg:gap-5">
				@runningIssuesSection(data)
				<section class="dashboard-section-grid grid min-w-0 gap-4 xl:grid-cols-2">
					@retryQueueSection(data.Snapshot)
					@blockedSessionsSection(data.Snapshot)
				</section>
				@recentSessionsSection(data.Snapshot)
			</div>
		</section>
	}
}

templ ProjectDiagnosticsSnapshot(data DashboardData) {
	@dashboardHealth(data)
	@trackerDriftWarning(data.Snapshot)
	if !snapshotReady(data.Snapshot) && !diagnosticsSnapshotHasLoadedData(data.Snapshot) {
		@snapshotReadiness(data.Snapshot)
	} else {
		@diagnosticsOperationsSummary(data)
		@diagnosticsTabbedView(data)
	}
}

templ diagnosticsOperationsSummary(data DashboardData) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-3 shadow-sm sm:p-4" aria-label="Diagnostics operations summary">
		<div class="grid min-w-0 gap-2 md:grid-cols-5">
			for _, fact := range diagnosticsSummaryFacts(data) {
				<article class="min-w-0 rounded-md border border-border bg-muted/30 p-3">
					<div class="flex min-w-0 items-center justify-between gap-2">
						<span class="truncate text-xs font-medium uppercase text-muted-foreground">{ fact.Label }</span>
						<span class={ "h-2.5 w-2.5 shrink-0 rounded-full border " + fact.Class }></span>
					</div>
					<div class="mt-1 truncate text-sm font-semibold text-foreground">{ fact.Value }</div>
					<p class="mt-1 line-clamp-2 text-xs text-muted-foreground">{ fact.Detail }</p>
				</article>
			}
		</div>
	</section>
}

templ diagnosticsTabbedView(data DashboardData) {
	<section class="grid min-w-0 gap-4" aria-label="Diagnostics operations view" data-diagnostics-tabs data-diagnostics-storage-name={ diagnosticsStorageName(data) }>
		<div class="overflow-x-auto rounded-md border border-border bg-card p-1" role="tablist" aria-label="Diagnostics sections">
			<div class="flex min-w-max items-center gap-1">
				@diagnosticsTabButton("overview", "Overview", true)
				@diagnosticsTabButton("workflow-timing", "Workflow timing", false)
				@diagnosticsTabButton("active-work", "Active work", false)
				@diagnosticsTabButton("queues-blockers", "Queues & blockers", false)
				@diagnosticsTabButton("github-api", "GitHub/API", false)
				@diagnosticsTabButton("runtime-store", "Runtime store", false)
				@diagnosticsTabButton("raw-debug", "Raw/Debug", false)
			</div>
		</div>
		<div class="grid min-w-0">
			@diagnosticsTabPanel("overview", "Overview", true) {
				@diagnosticsOverviewTab(data)
			}
			@diagnosticsTabPanel("workflow-timing", "Workflow timing", false) {
				@diagnosticsWorkflowTimingTab(data)
			}
			@diagnosticsTabPanel("active-work", "Active work", false) {
				@diagnosticsActiveWorkTab(data)
			}
			@diagnosticsTabPanel("queues-blockers", "Queues & blockers", false) {
				@diagnosticsQueuesBlockersTab(data)
			}
			@diagnosticsTabPanel("github-api", "GitHub/API", false) {
				@diagnosticsGitHubAPITab(data)
			}
			@diagnosticsTabPanel("runtime-store", "Runtime store", false) {
				@diagnosticsRuntimeStoreTab(data)
			}
			@diagnosticsTabPanel("raw-debug", "Raw/Debug", false) {
				@diagnosticsRawDebugTab(data)
			}
		</div>
	</section>
}

templ diagnosticsTabButton(id string, label string, active bool) {
	<button id={ "diagnostics-tab-" + id } class="inline-flex h-9 shrink-0 items-center rounded-md px-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent data-[diagnostics-active=true]:bg-accent-soft data-[diagnostics-active=true]:text-accent" type="button" role="tab" aria-selected={ diagnosticsBool(active) } aria-controls={ "diagnostics-panel-" + id } tabindex={ diagnosticsTabIndex(active) } data-diagnostics-tab={ id } data-diagnostics-active={ diagnosticsBool(active) }>
		{ label }
	</button>
}

templ diagnosticsTabPanel(id string, label string, active bool) {
	<section id={ "diagnostics-panel-" + id } class="grid min-w-0 gap-4" role="tabpanel" aria-labelledby={ "diagnostics-tab-" + id } tabindex="0" data-diagnostics-panel={ id } hidden?={ !active }>
		{ children... }
	</section>
}

templ diagnosticsOverviewTab(data DashboardData) {
	<div class="grid min-w-0 gap-4 lg:grid-cols-[minmax(0,1fr)_20rem]">
		<div class="grid min-w-0 gap-4">
			@boardHealthSection(data.Snapshot)
			@cycleTimeSection(data.Snapshot.CycleTime)
		</div>
		<aside class="grid min-w-0 content-start gap-4">
			@diagnosticsBottleneckCard(data.Snapshot.WorkflowMetrics, data.Snapshot.Project)
			@throughputCard(data)
		</aside>
	</div>
}

templ diagnosticsBottleneckCard(report telemetry.WorkflowMetrics, project telemetry.Project) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Active bottleneck">
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0">
				<h2 class="text-base font-semibold text-foreground">Active bottleneck</h2>
				<p class="text-sm text-muted-foreground">{ workflowBottleneck(report).Detail }</p>
			</div>
			<span class="rounded-full bg-warning-soft px-2 py-1 font-mono text-xs font-semibold text-warning">{ workflowBottleneck(report).Value }</span>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 px-3 py-2">
			<div class="truncate text-sm font-semibold text-foreground">{ workflowBottleneck(report).Label }</div>
			if workflowBottleneck(report).Count != "" {
				<div class="mt-1 font-mono text-xs text-muted-foreground">{ workflowBottleneck(report).Count }</div>
			}
		</div>
		if workflowBottleneckDiagnosticPrompt(project, report) != "" {
			<div class="mt-3">
				@diagnosticPromptCopyButton(workflowBottleneckDiagnosticPrompt(project, report), "Copy diagnostic prompt", "Copy diagnostic prompt")
			</div>
		}
	</section>
}

templ diagnosticsWorkflowTimingTab(data DashboardData) {
	<div class="grid min-w-0 gap-4" data-preserve-scroll="diagnostics-workflow-timing">
		<div class="flex min-w-0 flex-wrap items-center justify-between gap-2 rounded-md border border-border bg-card px-3 py-2 text-sm">
			<span class="font-medium text-foreground">Query windows</span>
			<span class="font-mono text-muted-foreground">{ workflowMetricsWindowLabels(data.Snapshot.WorkflowMetrics) }</span>
		</div>
		@workflowMetricsSection(data.Snapshot.WorkflowMetrics, data.Snapshot.Project)
		@cycleTimeSection(data.Snapshot.CycleTime)
	</div>
}

templ diagnosticsActiveWorkTab(data DashboardData) {
	<div class="grid min-w-0 gap-4 lg:grid-cols-2">
		@diagnosticsRunningWorkersSection(data.Snapshot)
		@schedulerRuntimeSection(data.Snapshot)
	</div>
}

templ diagnosticsRunningWorkersSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Active workers">
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0">
				<h2 class="text-base font-semibold text-foreground">Active workers</h2>
				<p class="text-sm text-muted-foreground">Running worker identity, current step, heartbeat, and issue or PR context.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ formatCount(runningCount(snapshot)) }</span>
		</div>
		if len(snapshot.Running) == 0 {
			<div class="mt-4">
				@dashboardEmptyState("No active workers.", "Running worker rows will appear after Detent dispatches work.", "bg-accent")
			</div>
		} else {
			<div class="mt-4 grid gap-2">
				for _, row := range snapshot.Running {
					<article class="rounded-md border border-border bg-muted/30 p-3">
						<div class="flex min-w-0 items-start justify-between gap-3">
							<div class="min-w-0">
								<div class="truncate font-mono text-sm font-medium text-foreground">{ issueIdentifier(row.Issue) }</div>
								<div class="mt-1 line-clamp-2 text-sm text-muted-foreground">{ issueTitle(row.Issue) }</div>
							</div>
							if row.URL != "" {
								@issueOpenLink(row.URL, "Open issue "+issueIdentifier(row.Issue), true)
							}
						</div>
						<div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
							<div class="min-w-0">
								<span class="block text-xs font-medium uppercase text-muted-foreground">Worker host</span>
								<span class="block truncate font-mono text-foreground">{ chartText(row.WorkerHost, "n/a") }</span>
							</div>
							<div class="min-w-0">
								<span class="block text-xs font-medium uppercase text-muted-foreground">Last event</span>
								<span class="block truncate font-mono text-foreground">{ chartText(row.LastEvent, "n/a") }</span>
							</div>
							<div class="min-w-0">
								<span class="block text-xs font-medium uppercase text-muted-foreground">Heartbeat</span>
								if row.LastEventAt != nil {
									<span class="block truncate font-mono text-foreground">{ timeLabel(*row.LastEventAt) }</span>
								} else {
									<span class="block truncate font-mono text-foreground">n/a</span>
								}
							</div>
							<div class="min-w-0">
								<span class="block text-xs font-medium uppercase text-muted-foreground">Runtime</span>
								<span class="block truncate font-mono text-foreground">{ formatDuration(row.RuntimeSeconds) }</span>
							</div>
						</div>
					</article>
				}
			</div>
		}
	</section>
}

templ diagnosticsQueuesBlockersTab(data DashboardData) {
	<div class="grid min-w-0 gap-4 xl:grid-cols-2">
		@retryQueueSection(data.Snapshot)
		@blockedSessionsSection(data.Snapshot)
	</div>
}

templ diagnosticsGitHubAPITab(data DashboardData) {
	<div class="grid min-w-0 gap-4 lg:grid-cols-[minmax(0,1fr)_20rem] xl:grid-cols-[minmax(0,1fr)_22rem]">
		<div class="grid min-w-0 gap-4">
			@rateLimitsCard(data.Snapshot.RateLimits)
			@budgetCard(data.Snapshot)
		</div>
		<aside class="grid min-w-0 content-start gap-4">
			@graphQLBudgetCard(data)
			@restBudgetCard(data)
		</aside>
	</div>
}

templ diagnosticsRuntimeStoreTab(data DashboardData) {
	@runtimeStoreEvidenceSection(data.Snapshot.WorkflowMetrics)
}

templ diagnosticsRawDebugTab(data DashboardData) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Raw diagnostics">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				<h2 class="text-base font-semibold text-foreground">Raw/Debug</h2>
				<p class="text-sm text-muted-foreground">Low-level links and counters for deeper inspection.</p>
			</div>
		</div>
		<div class="mt-4 grid gap-2 sm:grid-cols-2">
			<a class="rounded-md border border-border bg-muted/30 px-3 py-2 text-sm font-medium text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href="/api/v1/state">Fleet state JSON</a>
			if projectStateAPIPath(data) != "" {
				<a class="rounded-md border border-border bg-muted/30 px-3 py-2 text-sm font-medium text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectStateAPIPath(data) }>Project state JSON</a>
			}
		</div>
		<div class="mt-4 grid gap-2 text-sm sm:grid-cols-3">
			<div class="rounded-md bg-muted/60 px-3 py-2">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Recent events</span>
				<span class="font-mono text-foreground">{ formatCount(len(data.Snapshot.Events)) }</span>
			</div>
			<div class="rounded-md bg-muted/60 px-3 py-2">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Work attempts</span>
				<span class="font-mono text-foreground">{ formatCount(len(data.Snapshot.WorkAttempts)) }</span>
			</div>
			<div class="rounded-md bg-muted/60 px-3 py-2">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Scheduler decisions</span>
				<span class="font-mono text-foreground">{ formatCount(len(data.Snapshot.SchedulerDecisions)) }</span>
			</div>
		</div>
	</section>
}

templ runtimeStoreEvidenceSection(report telemetry.WorkflowMetrics) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Runtime store">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				<h2 class="text-base font-semibold text-foreground">Runtime store</h2>
				<p class="text-sm text-muted-foreground">SQLite persistence evidence for workflow metrics and scheduler telemetry.</p>
			</div>
			<span class={ "inline-flex min-h-9 shrink-0 items-center rounded-full border px-3 py-1 text-sm font-medium " + runtimeStoreStatusClass(report.RuntimeStore) }>{ runtimeStoreStatusLabel(report.RuntimeStore) }</span>
		</div>
		<div class="mt-4 grid gap-3 lg:grid-cols-3">
			<div class="rounded-md bg-muted/60 px-3 py-2">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Database path</span>
				<span class="block truncate font-mono text-sm text-foreground">{ runtimeStorePathLabel(report.RuntimeStore) }</span>
			</div>
			<div class="rounded-md bg-muted/60 px-3 py-2">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Migration status</span>
				<span class="block truncate font-mono text-sm text-foreground">{ runtimeStoreMigrationLabel(report.RuntimeStore) }</span>
			</div>
			<div class="rounded-md bg-muted/60 px-3 py-2">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Newest event</span>
				<span class="block truncate font-mono text-sm text-foreground">{ runtimeWorkflowEventNewestLabel(report.RuntimeStore) }</span>
			</div>
		</div>
		<div class="mt-4 rounded-md border border-border bg-muted/30 p-3 text-sm text-muted-foreground">
			<strong class="text-foreground">workflow_phase_events:</strong>
			<span class="font-mono">{ runtimeWorkflowEventCountLabel(report.RuntimeStore) }</span>
			<span>Oldest event { runtimeWorkflowEventOldestLabel(report.RuntimeStore) }. Newest event { runtimeWorkflowEventNewestLabel(report.RuntimeStore) }.</span>
		</div>
		if report.RuntimeStore.Status == "healthy" && report.RuntimeStore.WorkflowPhaseEvents.RowCount == 0 {
			<div class="mt-4">
				@dashboardEmptyState("SQLite history is empty.", "Lane averages appear after Detent records lane exits. New state transitions will populate the current query windows.", "bg-accent")
			</div>
		}
		if len(runtimeStoreTableRows(report.RuntimeStore)) > 0 {
			<div class="mt-4 overflow-hidden rounded-md border border-border">
				<div class="overflow-x-auto" data-preserve-scroll="runtime-store-tables">
					<table class="dashboard-table w-full min-w-[38rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[18rem] px-3 py-3 font-medium">Table</th>
								<th class="w-[8rem] px-3 py-3 font-medium">Scope</th>
								<th class="px-3 py-3 text-right font-medium">Rows</th>
							</tr>
						</thead>
						<tbody>
							for _, row := range runtimeStoreTableRows(report.RuntimeStore) {
								<tr class="border-b border-border last:border-b-0">
									<td class="px-3 py-3 font-mono text-foreground">{ row.Name }</td>
									<td class="px-3 py-3 font-mono text-muted-foreground">{ row.Scope }</td>
									<td class="px-3 py-3 text-right font-mono text-muted-foreground">{ row.RowCount }</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ FleetSnapshot(data DashboardData) {
	@dashboardHealth(data)
	@trackerDriftWarning(data.Snapshot)
	if !snapshotReady(data.Snapshot) {
		@snapshotReadiness(data.Snapshot)
	} else {
		@agentActivityTimeline(data.Snapshot)
		@statStrip(data.Snapshot)
		@projectSmallMultiplesSection(data)
		@prPipelineSection(data.Snapshot)
		<section class="dashboard-body-grid grid min-w-0 items-start gap-4 lg:grid-cols-[minmax(0,1fr)_20rem] lg:gap-5 xl:grid-cols-[minmax(0,1fr)_22rem]">
			<div class="dashboard-primary-column grid min-w-0 content-start gap-4 lg:gap-5">
				@runningIssuesSection(data)
				<section class="dashboard-section-grid grid min-w-0 gap-4 xl:grid-cols-2">
					@retryQueueSection(data.Snapshot)
					@blockedSessionsSection(data.Snapshot)
				</section>
				@recentSessionsSection(data.Snapshot)
			</div>
			<aside class="dashboard-aside-column grid min-w-0 content-start gap-4 lg:gap-5">
				@throughputCard(data)
				@rateLimitsCard(data.Snapshot.RateLimits)
				@graphQLBudgetCard(data)
				@restBudgetCard(data)
				@tokenCard(data)
				@lifetimeCard(data.Snapshot.LifetimeTotals)
			</aside>
		</section>
		<section class="dashboard-analytics grid min-w-0 gap-4 lg:gap-5" aria-label="Dashboard analytics">
			@boardHealthSection(data.Snapshot)
			@schedulerRuntimeSection(data.Snapshot)
			@workflowMetricsSection(data.Snapshot.WorkflowMetrics, data.Snapshot.Project)
			@cycleTimeSection(data.Snapshot.CycleTime)
			@budgetCard(data.Snapshot)
		</section>
	}
}

templ projectOverviewSummarySection(data DashboardData) {
	<section class="grid min-w-0 gap-3 sm:grid-cols-2 xl:grid-cols-4" aria-label="Project overview links">
		for _, card := range projectOverviewCards(data) {
			@projectOverviewCardView(card)
		}
	</section>
}

templ projectOverviewCardView(card projectOverviewCard) {
	<a class="dashboard-card group grid min-w-0 gap-3 rounded-md border border-border bg-card p-4 shadow-sm transition-colors hover:border-accent hover:bg-muted/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.Href } aria-label={ card.Title }>
		<div class="flex min-w-0 items-start justify-between gap-3">
			<div class="inline-flex min-w-0 items-center gap-2">
				<span class="inline-flex size-8 shrink-0 items-center justify-center rounded-md bg-muted text-muted-foreground group-hover:text-accent">
					if card.ID == "kanban" {
						@icon.Kanban(icon.Props{Class: "size-4"})
					} else if card.ID == "runs" {
						@icon.Activity(icon.Props{Class: "size-4"})
					} else if card.ID == "diagnostics" {
						@icon.Gauge(icon.Props{Class: "size-4"})
					} else {
						@icon.ChartNoAxesCombined(icon.Props{Class: "size-4"})
					}
				</span>
				<span class="truncate text-sm font-semibold text-foreground">{ card.Title }</span>
			</div>
			<span class={ "mt-3 h-2.5 w-2.5 shrink-0 rounded-full " + card.DotClass }></span>
		</div>
		<div class="min-w-0">
			<div class="truncate font-mono text-2xl font-semibold text-foreground">{ card.Value }</div>
			<div class="mt-1 truncate text-sm text-muted-foreground">{ card.Detail }</div>
		</div>
	</a>
}

templ runningIssuesSection(data DashboardData) {
	<section id="running-issues" class="dashboard-panel scroll-mt-3 min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" tabindex="-1">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Running issues", helpRunning, "running-issues")
				<p class="text-sm text-muted-foreground">Active Codex sessions and their latest known activity.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ formatCount(runningCount(data.Snapshot)) }</span>
		</div>
		if len(data.Snapshot.Running) == 0 {
			<div class="mt-4">
				if runningCount(data.Snapshot) > 0 {
					@dashboardEmptyState("Running session details are unavailable.", "The summary count is live, but detailed agent rows have not arrived in this snapshot.", "bg-accent")
				} else {
					@dashboardEmptyState("No active issue sessions.", "New agent sessions will appear as Detent dispatches work.", "bg-accent")
				}
			</div>
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range data.Snapshot.Running {
					@runningIssueMobileCard(row, i, data.Snapshot.GeneratedAt)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="running-issues">
					<table class="dashboard-table w-full min-w-[92rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[30rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[9rem] px-3 py-3 font-medium">State</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Runtime / turns", helpAgeTurn, "running-table", "")
								</th>
								<th class="px-3 py-3 font-medium">
									@helpInlineLabel("Codex update", helpEvent, "running-table", "")
								</th>
								<th class="w-[9rem] px-3 py-3 font-medium">
									@helpInlineLabel("Diff", helpDiff, "running-table", "")
								</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Tokens", helpTokens, "running-table", "")
								</th>
								<th class="w-[9rem] px-3 py-3 font-medium">
									@helpInlineLabel("Session", helpSession, "running-table", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range data.Snapshot.Running {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top overflow-hidden" data-running-issue-cell>
										@issueCell(row.Issue, "running", i, true)
									</td>
									<td class="px-3 py-4 align-top">
										<span class="inline-flex rounded-full bg-accent-soft px-2 py-1 font-medium text-accent">{ issueState(row.Issue, "Running") }</span>
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground whitespace-nowrap">{ runningRuntime(row, data.Snapshot.GeneratedAt) }</td>
									<td class="px-3 py-4 align-top overflow-hidden" data-running-activity-cell>
										@runningActivityCell(row, "running")
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground whitespace-nowrap" data-running-diff-cell>{ formatDiffStat(row) }</td>
									<td class="px-3 py-4 align-top overflow-hidden" data-running-tokens-cell>
										<div class="grid min-w-0 gap-1 font-mono">
											<span class="font-medium text-foreground">{ formatTokens(row.Tokens) }</span>
											<span class="truncate text-xs text-muted-foreground">{ formatTokenBreakdown(row.Tokens) }</span>
										</div>
									</td>
									<td class="px-3 py-4 align-top">
										@sessionCopyButton(row.SessionID)
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ projectSmallMultiplesSection(data DashboardData) {
	if len(projectSmallMultipleCards(data)) > 0 {
		<section class="min-w-0" aria-label="Fleet grid">
			<div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
				<div class="min-w-0">
					@helpHeading2("Fleet grid", helpProjectMultiples, "project-small-multiples")
					<p class="text-sm text-muted-foreground">Live running, queue, blocked, and token signals across configured projects.</p>
				</div>
				<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-muted px-2 py-1 text-sm font-medium text-muted-foreground">{ formatCount(len(projectSmallMultipleCards(data))) }</span>
			</div>
			<div class={ projectSmallMultiplesGridClass(projectSmallMultipleCards(data)) }>
				for _, card := range projectSmallMultipleCards(data) {
					@projectSmallMultipleCardView(card)
				}
			</div>
		</section>
	}
}

templ projectSmallMultipleCardView(card projectSmallMultipleCard) {
	<article class="dashboard-card min-w-0 rounded-md border border-border bg-card p-3 shadow-sm transition-colors hover:border-accent" aria-label={ card.Name + " project" }>
		<div class="flex min-w-0 items-start justify-between gap-3">
			<div class="flex min-w-0 items-start gap-2">
				<span class="mt-0.5 h-8 w-1.5 shrink-0 rounded-full border border-border" aria-label={ card.Name + " project color" } title={ "Project color: " + card.Name } { projectColorAttributes(card.ProjectColor)... }></span>
				<div class="min-w-0">
					<a class="block truncate text-sm font-semibold text-foreground hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.Href }>{ card.Name }</a>
					<p class="mt-1 truncate font-mono text-xs text-muted-foreground">{ card.ActivityLabel }</p>
				</div>
			</div>
			<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 font-mono text-xs font-medium text-accent">{ card.ThroughputLabel }</span>
		</div>
		if card.ExternalURL != "" {
			<a class="mt-2 block truncate text-xs text-muted-foreground underline-offset-4 hover:text-accent hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.ExternalURL } target="_blank" rel="noopener noreferrer">{ card.ExternalURL }</a>
		}
		<div class="mt-3 grid grid-cols-4 gap-2 text-xs">
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Run</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.RunningLabel }</strong>
			</span>
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Queue</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.QueueLabel }</strong>
			</span>
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Blocked</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.BlockedLabel }</strong>
			</span>
			<span class="min-w-0 rounded-md bg-muted px-2 py-1.5">
				<span class="block text-muted-foreground">Sessions</span>
				<strong class="block truncate font-mono font-medium text-foreground">{ card.CompletedLabel }</strong>
			</span>
		</div>
		<div class="mt-3 grid min-w-0 gap-3 sm:grid-cols-3">
			<div class="grid min-w-0 gap-1">
				<div class="flex items-center justify-between gap-2 text-xs">
					<span class="text-muted-foreground">Throughput</span>
					<span class="font-mono text-muted-foreground">{ card.ThroughputLabel }</span>
				</div>
				@SparklineChart(card.ThroughputChart)
			</div>
			<div class="grid min-w-0 gap-1">
				<div class="flex items-center justify-between gap-2 text-xs">
					<span class="text-muted-foreground">Spend</span>
					<span class="font-mono text-muted-foreground">{ card.SpendLabel }</span>
				</div>
				@SparklineChart(card.SpendChart)
			</div>
			<div class="grid min-w-0 gap-1">
				<div class="flex items-center justify-between gap-2 text-xs">
					<span class="text-muted-foreground">Queue</span>
					<span class="font-mono text-muted-foreground">{ card.QueueLabel }</span>
				</div>
				@SparklineChart(card.QueueChart)
			</div>
		</div>
	</article>
}

templ projectKanbanSection(data DashboardData, board projectKanbanBoard) {
	if len(board.AllLanes) > 0 {
		<section id={ projectKanbanSectionID(data) } class="dashboard-panel project-kanban scroll-mt-3 min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label={ projectKanbanSectionLabel(data) } tabindex="-1" data-project-kanban-board data-project-kanban-visibility-key={ projectKanbanVisibilityKey(data, board) }>
			<div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
				<div class="min-w-0">
					<div class="inline-flex min-w-0 items-center gap-2">
						@icon.Kanban(icon.Props{Class: "size-5 shrink-0 text-accent"})
						@helpHeading2(projectKanbanSectionLabel(data), helpProjectKanban, projectKanbanSectionID(data))
					</div>
					<p class="text-sm text-muted-foreground">{ projectKanbanSectionDescription(data) }</p>
				</div>
				<div class="flex shrink-0 flex-wrap items-center gap-2">
					if projectKanbanActionsEnabled(data) {
						<span class="inline-flex min-h-8 items-center rounded-full border border-success bg-success-soft px-2.5 py-1 text-xs font-semibold text-success">Integration</span>
					} else {
						<span class="inline-flex min-h-8 items-center rounded-full border border-accent-soft bg-accent-soft px-2.5 py-1 text-xs font-semibold text-accent">Read-only</span>
					}
					if projectKanbanBoardLoaded(data) {
						if snapshotDegraded(data.Snapshot) {
							<span class="inline-flex min-h-8 items-center rounded-full border border-warning-soft bg-warning-soft px-2.5 py-1 text-xs font-semibold text-warning">Degraded</span>
						}
						<span class="inline-flex min-h-8 items-center rounded-full bg-muted px-2.5 py-1 font-mono text-xs font-medium text-muted-foreground" data-project-kanban-card-count-summary>{ projectKanbanCardCountSummary(board) }</span>
						@projectKanbanVisibilityDropdown(board, projectKanbanVisibilityKey(data, board))
					} else if snapshotDegraded(data.Snapshot) {
						<span class="inline-flex min-h-8 items-center rounded-full border border-danger-soft bg-danger-soft px-2.5 py-1 text-xs font-semibold text-danger">Degraded</span>
					} else {
						<span class="inline-flex min-h-8 items-center rounded-full border border-warning-soft bg-warning-soft px-2.5 py-1 text-xs font-semibold text-warning">Loading</span>
					}
				</div>
			</div>
			if projectKanbanReadOnlySetupNotice(data) {
				@projectKanbanReadOnlyNotice(data)
			}
			if projectKanbanFeedbackVisible(data) {
				<div id="kanban-feedback" role="status" aria-live="polite" class={ kanbanFeedbackClass(data.Kanban) }>{ kanbanFeedbackText(data.Kanban) }</div>
			}
			if projectKanbanBoardLoaded(data) {
				@projectKanbanHiddenPopulatedNotice(board)
			}
			if !snapshotReady(data.Snapshot) && !projectKanbanBoardLoaded(data) {
				<div class="mt-3">
					@snapshotReadiness(data.Snapshot)
				</div>
			}
			if !projectKanbanBoardLoaded(data) {
				<div class="project-kanban-lanes mt-3 flex min-w-0 max-w-full flex-nowrap items-start justify-start gap-3 overflow-x-auto pb-2" data-preserve-scroll="project-kanban-lanes">
					for _, lane := range board.AllLanes {
						@projectKanbanLoadingLaneView(lane)
					}
				</div>
			} else {
				<div class="project-kanban-lanes mt-3 flex min-w-0 max-w-full flex-nowrap items-start justify-start gap-3 overflow-x-auto pb-2" data-preserve-scroll="project-kanban-lanes">
					for _, lane := range board.AllLanes {
						@projectKanbanLaneView(data, lane)
					}
				</div>
			}
			if projectKanbanActionsEnabled(data) && snapshotReady(data.Snapshot) {
				@kanbanScript()
			}
		</section>
	}
}

templ projectKanbanHiddenPopulatedNotice(board projectKanbanBoard) {
	<div class="mt-3 rounded-md border border-warning-soft bg-warning-soft/60 px-3 py-2 text-sm text-warning" role="status" aria-live="polite" data-project-kanban-hidden-populated-alert hidden?={ board.HiddenCardCount == 0 }>
		<div class="flex min-w-0 flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
			<div class="flex min-w-0 items-start gap-2">
				@icon.CircleAlert(icon.Props{Class: "mt-0.5 size-4 shrink-0 text-warning"})
				<p class="min-w-0 text-warning" data-project-kanban-hidden-populated-summary>{ projectKanbanHiddenPopulatedSummary(board) }</p>
			</div>
			@button.Button(button.Props{
				Type:    button.TypeButton,
				Variant: button.VariantOutline,
				Size:    button.SizeSm,
				Class:   "shrink-0 border-warning bg-card text-warning hover:border-accent hover:text-accent",
				Attributes: templ.Attributes{
					"data-project-kanban-visibility-action": "populated",
				},
			}) {
				@icon.Eye(icon.Props{Class: "size-3.5 shrink-0"})
				<span>Show populated lanes</span>
			}
		</div>
	</div>
}

templ projectKanbanReadOnlyNotice(data DashboardData) {
	<div class="mt-3 grid min-w-0 gap-3 rounded-md border border-warning-soft bg-warning-soft/60 p-3 text-sm text-foreground">
		<div class="flex min-w-0 items-start gap-3">
			@icon.CircleAlert(icon.Props{Class: "mt-0.5 size-5 shrink-0 text-warning"})
			<div class="grid min-w-0 gap-2">
				<p class="font-medium text-foreground">This board is currently read-only.</p>
				<p class="text-muted-foreground">To move cards from Detent, enable Kanban integration in WORKFLOW.md under the existing server block.</p>
				<p class="text-muted-foreground">Run <code class="rounded-sm bg-card px-1 py-0.5 font-mono text-xs text-foreground">detent doctor --port 0</code> first and confirm status-label, issue-field, and ProjectV2 write checks pass.</p>
			</div>
		</div>
		<div class="grid min-w-0 gap-1.5">
			<label class="text-xs font-medium text-muted-foreground" for="project-kanban-integration-snippet">WORKFLOW.md</label>
			<textarea id="project-kanban-integration-snippet" class="min-h-24 w-full resize-none rounded-md border border-border bg-card px-3 py-2 font-mono text-xs text-foreground" readonly autocomplete="off" aria-label="Kanban integration config snippet">{ projectKanbanIntegrationSnippet() }</textarea>
		</div>
		if projectKanbanStatesConfigured(data) {
			<p class="text-xs text-muted-foreground">Add <code class="rounded-sm bg-card px-1 py-0.5 font-mono text-xs text-foreground">allowed_transitions</code> when you want broad manual status editing instead of conservative defaults.</p>
		}
	</div>
}

templ projectKanbanVisibilityDropdown(board projectKanbanBoard, visibilityKey string) {
	<details class="relative" data-project-kanban-visibility-menu data-preserve-details={ projectKanbanVisibilityDetailsID(visibilityKey) }>
		<summary class="inline-flex min-h-8 cursor-pointer list-none items-center gap-1.5 rounded-md border border-border bg-card px-2.5 py-1 text-xs font-medium text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent">
			@icon.Eye(icon.Props{Class: "size-3.5 shrink-0"})
			<span>Lane visibility</span>
			<span class="rounded-full bg-muted px-1.5 py-0.5 font-mono" data-project-kanban-visibility-count>{ projectKanbanVisibilityCountLabel(board) }</span>
		</summary>
		<div class="absolute right-0 z-50 mt-2 w-[18rem] rounded-md border border-border bg-popover p-2 text-popover-foreground shadow-sm">
			<div class="mb-2 flex items-center justify-between gap-2 border-b border-border pb-2">
				<div class="grid min-w-0 flex-1 grid-cols-2 gap-1">
					<button type="button" class="col-span-2 min-h-8 rounded-md bg-warning-soft px-2 py-1 text-xs font-medium text-warning hover:bg-accent-soft hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent disabled:pointer-events-none disabled:opacity-40" data-project-kanban-visibility-action="populated">Show populated lanes</button>
					<button type="button" class="min-h-8 rounded-md bg-muted px-2 py-1 text-xs font-medium text-muted-foreground hover:bg-accent-soft hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" data-project-kanban-visibility-action="all">All lanes</button>
					<button type="button" class="min-h-8 rounded-md bg-muted px-2 py-1 text-xs font-medium text-muted-foreground hover:bg-accent-soft hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" data-project-kanban-visibility-action="reset">Reset to defaults</button>
				</div>
				<button type="button" class="inline-flex size-8 shrink-0 items-center justify-center rounded-md text-muted-foreground hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" data-project-kanban-visibility-close aria-label="Close lane visibility">
					@icon.X(icon.Props{Class: "size-4"})
				</button>
			</div>
			<div class="grid gap-1">
				for _, lane := range board.AllLanes {
					<div class={ projectKanbanVisibilityRowClass(lane) } data-project-kanban-visibility-row data-project-kanban-visibility-lane={ lane.ID } data-project-kanban-visibility-card-count={ strconv.Itoa(len(lane.Cards)) } data-project-kanban-hidden-populated={ projectKanbanBool(projectKanbanLaneHiddenPopulated(lane)) }>
						<label class="flex min-h-7 cursor-pointer items-center gap-2">
							<input class="size-4 shrink-0 accent-accent" type="checkbox" name="visible_lane" value={ lane.ID } checked?={ lane.DefaultVisible } data-project-kanban-visibility-checkbox data-project-kanban-visibility-default={ projectKanbanBool(lane.DefaultVisible) } data-project-kanban-visibility-state="default" autocomplete="off"/>
							<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
							<span class="min-w-0 flex-1 truncate">{ lane.Title }</span>
							<span class="shrink-0 rounded-full bg-muted px-1.5 py-0.5 font-mono text-muted-foreground">{ lane.CountLabel }</span>
						</label>
						<div class="ml-6 flex min-w-0 items-center justify-between gap-1.5">
							<span class="min-w-0 truncate text-[11px] text-muted-foreground" data-project-kanban-visibility-status>{ projectKanbanVisibilityStatusLabel(lane) }</span>
							<button type="button" class="inline-flex size-6 shrink-0 items-center justify-center rounded-md text-muted-foreground hover:bg-card hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent disabled:pointer-events-none disabled:opacity-40" data-project-kanban-visibility-reset value={ lane.ID } aria-label={ "Reset " + lane.Title + " lane to default visibility" } title="Reset lane to default visibility" disabled>
								@icon.RotateCcw(icon.Props{Class: "size-3.5"})
							</button>
						</div>
					</div>
				}
			</div>
		</div>
	</details>
}

templ projectKanbanVisibilityScript() {
	<script>
		(function() {
			const storagePrefix = "detent.ui.projectKanban.visibleLanes.";
			const storageVersion = 4;
			const overrideDefault = "default";
			const overrideShow = "show";
			const overrideHide = "hide";

			function visibilityStorage() {
				try {
					return window.localStorage;
				} catch (error) {
					return null;
				}
			}

			function boards() {
				return Array.from(document.querySelectorAll("[data-project-kanban-board][data-project-kanban-visibility-key]"));
			}

			function storageKey(board) {
				return storagePrefix + (board.dataset.projectKanbanVisibilityKey || "default");
			}

			function boardLanes(board) {
				return Array.from(board.querySelectorAll("[data-project-kanban-lane]"));
			}

			function laneID(lane) {
				return lane.dataset.projectKanbanLane || "";
			}

			function laneDefaultVisible(lane) {
				return lane.dataset.projectKanbanLaneDefaultVisible === "true";
			}

			function laneCardCount(lane) {
				const parsed = Number.parseInt(lane.dataset.projectKanbanLaneCardCount || "0", 10);
				if (!Number.isFinite(parsed) || parsed < 0) {
					return 0;
				}
				return parsed;
			}

			function laneTitle(lane) {
				return lane.dataset.projectKanbanLaneTitle || "lane";
			}

			function formatNumber(value) {
				return new Intl.NumberFormat("en-US").format(value);
			}

			function cardCountLabel(count, singular, plural) {
				return formatNumber(count) + " " + (count === 1 ? singular : plural);
			}

			function emptyOverrides() {
				return { show: new Set(), hide: new Set() };
			}

			function laneIDSet(ids) {
				if (!Array.isArray(ids)) {
					return new Set();
				}
				return new Set(ids.filter(function(id) {
					return typeof id === "string" && id.trim() !== "";
				}));
			}

			function defaultLaneIDs(board) {
				const ids = new Set();
				boardLanes(board).forEach(function(lane) {
					const id = laneID(lane);
					if (id && laneDefaultVisible(lane)) {
						ids.add(id);
					}
				});
				return ids;
			}

			function laneByID(board, id) {
				return boardLanes(board).find(function(lane) {
					return laneID(lane) === id;
				}) || null;
			}

			function normalizedVisibilityOverrides(showIDs, hideIDs) {
				const overrides = emptyOverrides();
				laneIDSet(showIDs).forEach(function(id) {
					overrides.show.add(id);
				});
				laneIDSet(hideIDs).forEach(function(id) {
					if (!overrides.show.has(id)) {
						overrides.hide.add(id);
					}
				});
				return overrides;
			}

			function legacyVisibilityOverrides(board, parsed) {
				const overrides = emptyOverrides();
				if (!parsed || !Array.isArray(parsed.lanes)) {
					return overrides;
				}
				const defaults = defaultLaneIDs(board);
				laneIDSet(parsed.lanes).forEach(function(id) {
					if (!defaults.has(id)) {
						overrides.show.add(id);
					}
				});
				return overrides;
			}

			function saveVisibilityOverrides(board, overrides) {
				const store = visibilityStorage();
				if (!store) {
					return;
				}
				const show = Array.from(overrides.show).filter(Boolean).sort();
				const hide = Array.from(overrides.hide).filter(function(id) {
					return Boolean(id) && !overrides.show.has(id);
				}).sort();
				if (show.length === 0 && hide.length === 0) {
					store.removeItem(storageKey(board));
					return;
				}
				store.setItem(storageKey(board), JSON.stringify({ v: storageVersion, show: show, hide: hide }));
			}

			function resetVisibilityOverrides(board) {
				const store = visibilityStorage();
				if (store) {
					store.removeItem(storageKey(board));
				}
			}

			function storedVisibilityOverrides(board) {
				const store = visibilityStorage();
				if (!store) {
					return emptyOverrides();
				}
				const raw = store.getItem(storageKey(board));
				if (!raw) {
					return emptyOverrides();
				}
				let parsed = null;
				try {
					parsed = JSON.parse(raw);
				} catch (error) {
					resetVisibilityOverrides(board);
					return emptyOverrides();
				}
				if (!parsed) {
					return emptyOverrides();
				}
				if (parsed.v === storageVersion) {
					return normalizedVisibilityOverrides(parsed.show, parsed.hide);
				}
				if (parsed.v === 3 || parsed.v === 2 || parsed.v === 1) {
					const migrated = legacyVisibilityOverrides(board, parsed);
					saveVisibilityOverrides(board, migrated);
					return migrated;
				}
				resetVisibilityOverrides(board);
				return emptyOverrides();
			}

			function visibilityOverrides(board) {
				return storedVisibilityOverrides(board);
			}

			function laneOverrideState(lane, overrides) {
				const id = laneID(lane);
				if (overrides.show.has(id)) {
					return overrideShow;
				}
				if (overrides.hide.has(id)) {
					return overrideHide;
				}
				return overrideDefault;
			}

			function effectiveLaneVisibility(lane, overrides) {
				const state = laneOverrideState(lane, overrides);
				if (state === overrideShow) {
					return { state: state, visible: true };
				}
				if (state === overrideHide) {
					return { state: state, visible: false };
				}
				return { state: state, visible: laneDefaultVisible(lane) };
			}

			function checkboxLaneID(checkbox) {
				return checkbox.value || "";
			}

			function visibilityStateBaseLabel(state, lane) {
				if (state === overrideShow) {
					return "Forced visible";
				}
				if (state === overrideHide) {
					return "Forced hidden";
				}
				return laneDefaultVisible(lane) ? "Default visible" : "Default hidden";
			}

			function visibilityStateLabel(state, lane, visible) {
				const label = visibilityStateBaseLabel(state, lane);
				if (!visible && laneCardCount(lane) > 0) {
					return label + " with " + cardCountLabel(laneCardCount(lane), "hidden card", "hidden cards");
				}
				return label;
			}

			function visibilityStateTitle(state, lane, visible) {
				let title = "";
				if (state === overrideShow) {
					title = "Forced visible; reset to follow the board default.";
				} else if (state === overrideHide) {
					title = "Forced hidden; reset to follow the board default.";
				} else {
					title = laneDefaultVisible(lane) ? "Default-visible lane; no saved override." : "Default-hidden lane; no saved override.";
				}
				if (!visible && laneCardCount(lane) > 0) {
					return title + " " + cardCountLabel(laneCardCount(lane), "card is", "cards are") + " hidden while this lane is off.";
				}
				return title;
			}

			function visibilityRow(board, id) {
				return Array.from(board.querySelectorAll("[data-project-kanban-visibility-row]")).find(function(row) {
					return row instanceof HTMLElement && row.dataset.projectKanbanVisibilityLane === id;
				}) || null;
			}

			function updatePinButton(button, visible, state, title) {
				button.dataset.projectKanbanPinActive = visible ? "true" : "false";
				button.dataset.projectKanbanVisibilityState = state;
				button.setAttribute("aria-pressed", visible ? "true" : "false");
				button.setAttribute("aria-label", (visible ? "Hide " : "Show ") + title + " lane");
				button.title = visible ? "Hide lane" : "Show lane";
				button.querySelectorAll("[data-project-kanban-pin-icon]").forEach(function(icon) {
					if (!(icon instanceof HTMLElement)) {
						return;
					}
					icon.hidden = icon.dataset.projectKanbanPinIcon !== (visible ? "pinned" : "unpinned");
				});
			}

			function applyVisibilityState(board, lane, state, visible) {
				const id = laneID(lane);
				lane.dataset.projectKanbanLaneVisible = visible ? "true" : "false";
				lane.dataset.projectKanbanLanePinned = state === overrideShow ? "true" : "false";
				lane.dataset.projectKanbanLaneVisibilityState = state;
				lane.querySelectorAll("[data-project-kanban-pin-toggle]").forEach(function(button) {
					if (button instanceof HTMLButtonElement) {
						updatePinButton(button, visible, state, laneTitle(lane));
					}
				});
				const row = visibilityRow(board, id);
				if (!(row instanceof HTMLElement)) {
					return;
				}
				row.dataset.projectKanbanVisibilityState = state;
				row.dataset.projectKanbanVisibilityEffective = visible ? "visible" : "hidden";
				const hiddenPopulated = !visible && laneCardCount(lane) > 0;
				row.dataset.projectKanbanHiddenPopulated = hiddenPopulated ? "true" : "false";
				row.classList.toggle("border-warning-soft", hiddenPopulated);
				row.classList.toggle("bg-warning-soft/40", hiddenPopulated);
				row.classList.toggle("border-transparent", !hiddenPopulated);
				const label = visibilityStateLabel(state, lane, visible);
				const title = visibilityStateTitle(state, lane, visible);
				const status = row.querySelector("[data-project-kanban-visibility-status]");
				if (status) {
					status.textContent = label;
					status.setAttribute("title", title);
				}
				const reset = row.querySelector("[data-project-kanban-visibility-reset]");
				if (reset instanceof HTMLButtonElement) {
					const disabled = state === overrideDefault;
					reset.disabled = disabled;
					reset.setAttribute("aria-disabled", disabled ? "true" : "false");
				}
			}

			function hiddenLaneSummary(lanes) {
				if (lanes.length === 0) {
					return "All populated lanes are visible.";
				}
				if (lanes.length === 1) {
					const lane = lanes[0];
					return cardCountLabel(lane.count, "hidden card", "hidden cards") + " in " + lane.title + ".";
				}
				const total = lanes.reduce(function(sum, lane) {
					return sum + lane.count;
				}, 0);
				const labels = lanes.map(function(lane) {
					return lane.title + " (" + formatNumber(lane.count) + ")";
				}).join(", ");
				return cardCountLabel(total, "hidden card", "hidden cards") + " across " + cardCountLabel(lanes.length, "lane", "lanes") + ": " + labels + ".";
			}

			function updateBoardHiddenSummary(board, visibleCardCount, totalCardCount, hiddenLanes) {
				const hiddenCardCount = hiddenLanes.reduce(function(sum, lane) {
					return sum + lane.count;
				}, 0);
				const count = board.querySelector("[data-project-kanban-card-count-summary]");
				if (count) {
					count.textContent = hiddenCardCount > 0
						? formatNumber(visibleCardCount) + " visible / " + formatNumber(totalCardCount) + " total cards"
						: formatNumber(totalCardCount) + " cards";
				}
				const alert = board.querySelector("[data-project-kanban-hidden-populated-alert]");
				if (alert instanceof HTMLElement) {
					alert.hidden = hiddenCardCount === 0;
				}
				const summary = board.querySelector("[data-project-kanban-hidden-populated-summary]");
				if (summary) {
					summary.textContent = hiddenLaneSummary(hiddenLanes);
				}
				board.querySelectorAll("[data-project-kanban-visibility-action='populated']").forEach(function(button) {
					if (!(button instanceof HTMLButtonElement)) {
						return;
					}
					const disabled = hiddenCardCount === 0;
					button.disabled = disabled;
					button.setAttribute("aria-disabled", disabled ? "true" : "false");
				});
			}

			function applyBoard(board) {
				const overrides = visibilityOverrides(board);
				let visibleCount = 0;
				let visibleCardCount = 0;
				let totalCardCount = 0;
				const hiddenLanes = [];
				const lanes = boardLanes(board);
				lanes.forEach(function(lane) {
					const effective = effectiveLaneVisibility(lane, overrides);
					applyVisibilityState(board, lane, effective.state, effective.visible);
					const cardCount = laneCardCount(lane);
					totalCardCount += cardCount;
					if (effective.visible) {
						visibleCount += 1;
						visibleCardCount += cardCount;
					} else if (cardCount > 0) {
						hiddenLanes.push({ title: laneTitle(lane), count: cardCount });
					}
				});
				board.querySelectorAll("[data-project-kanban-visibility-checkbox]").forEach(function(input) {
					if (!(input instanceof HTMLInputElement)) {
						return;
					}
					const lane = laneByID(board, checkboxLaneID(input));
					if (!lane) {
						return;
					}
					const effective = effectiveLaneVisibility(lane, overrides);
					input.checked = effective.visible;
					input.disabled = false;
					input.setAttribute("aria-disabled", "false");
					input.dataset.projectKanbanVisibilityState = effective.state;
					input.dataset.projectKanbanVisibilityEffective = effective.visible ? "visible" : "hidden";
					input.setAttribute("aria-label", (effective.visible ? "Hide " : "Show ") + laneTitle(lane) + " lane");
					input.title = visibilityStateTitle(effective.state, lane, effective.visible);
				});
				const count = board.querySelector("[data-project-kanban-visibility-count]");
				if (count) {
					count.textContent = visibleCount + "/" + lanes.length;
				}
				updateBoardHiddenSummary(board, visibleCardCount, totalCardCount, hiddenLanes);
			}

			function applyBoards() {
				boards().forEach(applyBoard);
			}

			function setLaneOverride(board, id, state) {
				const overrides = visibilityOverrides(board);
				overrides.show.delete(id);
				overrides.hide.delete(id);
				if (state === overrideShow) {
					overrides.show.add(id);
				}
				if (state === overrideHide) {
					overrides.hide.add(id);
				}
				saveVisibilityOverrides(board, overrides);
				applyBoard(board);
			}

			function laneOverrideForVisibility(lane, visible) {
				if (visible === laneDefaultVisible(lane)) {
					return overrideDefault;
				}
				return visible ? overrideShow : overrideHide;
			}

			function updateCheckbox(checkbox) {
				const board = checkbox.closest("[data-project-kanban-board]");
				if (!board) {
					return;
				}
				const id = checkboxLaneID(checkbox);
				const lane = laneByID(board, id);
				if (!id || !lane) {
					return;
				}
				setLaneOverride(board, id, laneOverrideForVisibility(lane, checkbox.checked));
			}

			function toggleLanePin(button) {
				const lane = button.closest("[data-project-kanban-lane]");
				const board = button.closest("[data-project-kanban-board]");
				if (!lane || !board) {
					return;
				}
				const id = laneID(lane);
				if (!id) {
					return;
				}
				const effective = effectiveLaneVisibility(lane, visibilityOverrides(board));
				setLaneOverride(board, id, laneOverrideForVisibility(lane, !effective.visible));
			}

			function resetLaneOverride(button) {
				const board = button.closest("[data-project-kanban-board]");
				const row = button.closest("[data-project-kanban-visibility-row]");
				const id = button.value || (row instanceof HTMLElement ? row.dataset.projectKanbanVisibilityLane : "");
				if (!board || !id) {
					return;
				}
				setLaneOverride(board, id, overrideDefault);
			}

			function updateAction(button) {
				const board = button.closest("[data-project-kanban-board]");
				if (!board) {
					return;
				}
				if (button.dataset.projectKanbanVisibilityAction === "all") {
					const overrides = emptyOverrides();
					boardLanes(board).forEach(function(lane) {
						const id = laneID(lane);
						if (id && !laneDefaultVisible(lane)) {
							overrides.show.add(id);
						}
					});
					saveVisibilityOverrides(board, overrides);
				}
				if (button.dataset.projectKanbanVisibilityAction === "populated") {
					const overrides = visibilityOverrides(board);
					boardLanes(board).forEach(function(lane) {
						const id = laneID(lane);
						if (!id || laneCardCount(lane) === 0) {
							return;
						}
						overrides.hide.delete(id);
						if (laneDefaultVisible(lane)) {
							overrides.show.delete(id);
						} else {
							overrides.show.add(id);
						}
					});
					saveVisibilityOverrides(board, overrides);
				}
				if (button.dataset.projectKanbanVisibilityAction === "reset") {
					resetVisibilityOverrides(board);
				}
				applyBoard(board);
			}

			function visibilitySnapshotTarget(event) {
				const detailTarget = event.detail && event.detail.target;
				const target = detailTarget instanceof Element ? detailTarget : event.target;
				if (!(target instanceof Element)) {
					return null;
				}
				if (target.id === "snapshot") {
					return target;
				}
				return target.closest("#snapshot");
			}

			function snapshotHasOpenPreservedDetails(target) {
				return Boolean(target && target.querySelector("details[data-preserve-details][open]"));
			}

			function visibilityMenus() {
				return Array.from(document.querySelectorAll("[data-project-kanban-visibility-menu]"));
			}

			function closeVisibilityMenu(menu) {
				if (menu instanceof HTMLDetailsElement) {
					menu.open = false;
				}
			}

			function closeVisibilityMenusExcept(activeMenu) {
				visibilityMenus().forEach(function(menu) {
					if (menu !== activeMenu) {
						closeVisibilityMenu(menu);
					}
				});
			}

			document.addEventListener("change", function(event) {
				const input = event.target instanceof Element ? event.target.closest("[data-project-kanban-visibility-checkbox]") : null;
				if (input instanceof HTMLInputElement) {
					updateCheckbox(input);
				}
			});

			document.addEventListener("click", function(event) {
				const target = event.target instanceof Element ? event.target : null;
				const close = target ? target.closest("[data-project-kanban-visibility-close]") : null;
				if (close instanceof HTMLButtonElement) {
					event.preventDefault();
					closeVisibilityMenu(close.closest("[data-project-kanban-visibility-menu]"));
					return;
				}
				const pin = target ? target.closest("[data-project-kanban-pin-toggle]") : null;
				if (pin instanceof HTMLButtonElement) {
					event.preventDefault();
					toggleLanePin(pin);
					return;
				}
				const reset = target ? target.closest("[data-project-kanban-visibility-reset]") : null;
				if (reset instanceof HTMLButtonElement) {
					event.preventDefault();
					resetLaneOverride(reset);
					return;
				}
				const button = target ? target.closest("[data-project-kanban-visibility-action]") : null;
				if (button instanceof HTMLButtonElement) {
					event.preventDefault();
					updateAction(button);
					return;
				}
				const menu = target ? target.closest("[data-project-kanban-visibility-menu]") : null;
				if (!menu) {
					closeVisibilityMenusExcept(null);
				}
			});

			document.addEventListener("keydown", function(event) {
				if (event.key === "Escape") {
					closeVisibilityMenusExcept(null);
				}
			});

			document.addEventListener("toggle", function(event) {
				const menu = event.target instanceof Element ? event.target.closest("[data-project-kanban-visibility-menu]") : null;
				if (menu instanceof HTMLDetailsElement && menu.open) {
					closeVisibilityMenusExcept(menu);
				}
			}, true);

			document.addEventListener("htmx:beforeSwap", function(event) {
				const target = visibilitySnapshotTarget(event);
				if (snapshotHasOpenPreservedDetails(target)) {
					event.preventDefault();
				}
			});

			document.addEventListener("htmx:sseBeforeMessage", function(event) {
				const target = visibilitySnapshotTarget(event);
				if (snapshotHasOpenPreservedDetails(target)) {
					event.preventDefault();
				}
			});

			document.addEventListener("htmx:afterSwap", applyBoards);
			document.addEventListener("htmx:afterSettle", applyBoards);
			window.addEventListener("storage", function(event) {
				if (event.key && event.key.indexOf(storagePrefix) === 0) {
					applyBoards();
				}
			});

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", applyBoards);
			} else {
				applyBoards();
			}
		})();
	</script>
}

templ projectKanbanLaneView(data DashboardData, lane projectKanbanLane) {
	<section class={ projectKanbanLaneClass(lane) } aria-label={ lane.Title + " lane" } data-project-kanban-lane={ lane.ID } data-project-kanban-lane-title={ lane.Title } { projectKanbanLaneAttributesForData(data, lane)... }>
		<div class="flex min-h-7 w-full min-w-0 max-w-full items-center gap-1.5 overflow-hidden">
			<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
			<h3 class="min-w-0 shrink truncate text-xs font-semibold text-foreground">{ lane.Title } ({ lane.CountLabel })</h3>
			<button type="button" class="inline-flex size-6 flex-none items-center justify-center rounded-md border border-transparent text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent aria-pressed:border-accent-soft aria-pressed:bg-accent-soft aria-pressed:text-accent" data-project-kanban-pin-toggle data-project-kanban-pin-active="false" aria-pressed="false" aria-label={ "Pin " + lane.Title + " lane" } title="Pin lane">
				<span data-project-kanban-pin-icon="unpinned">
					@icon.PinOff(icon.Props{Class: "size-3.5"})
				</span>
				<span data-project-kanban-pin-icon="pinned" hidden>
					@icon.Pin(icon.Props{Class: "size-3.5"})
				</span>
			</button>
		</div>
		if len(lane.Cards) == 0 {
			<div class="mt-2 min-w-0 max-w-full overflow-hidden">
				@dashboardEmptyState("No issues in this state.", "This configured state stays hidden unless this lane is pinned visible.", lane.DotClass)
			</div>
		} else {
			<div class="project-kanban-lane-scroll mt-2 grid auto-rows-max min-w-0 max-w-full max-h-[32rem] gap-1.5 overflow-x-hidden overflow-y-auto pr-1" data-preserve-scroll={ "project-kanban-" + lane.ID }>
				for _, card := range lane.Cards {
					@projectKanbanCardView(data, card)
				}
			</div>
		}
	</section>
}

templ projectKanbanLoadingLaneView(lane projectKanbanLane) {
	<section class={ projectKanbanLaneClass(lane) } aria-label={ lane.Title + " lane" } data-project-kanban-lane={ lane.ID } data-project-kanban-lane-title={ lane.Title } data-project-kanban-lane-empty="true" data-project-kanban-lane-default-visible="true" data-project-kanban-lane-card-count="0" data-project-kanban-lane-pinned="false" data-project-kanban-lane-visible="true" data-project-kanban-lane-visibility-state="default">
		<div class="flex min-h-7 w-full min-w-0 max-w-full items-center gap-1.5 overflow-hidden">
			<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
			<h3 class="min-w-0 shrink truncate text-xs font-semibold text-foreground">{ lane.Title } ({ lane.CountLabel })</h3>
		</div>
		<div class="mt-3 grid gap-2" aria-hidden="true">
			<div class="h-16 rounded-md border border-dashed border-border bg-card/70"></div>
			<div class="h-12 rounded-md border border-dashed border-border bg-card/50"></div>
		</div>
	</section>
}

templ projectKanbanCardView(data DashboardData, card projectKanbanCard) {
	<article class="project-kanban-card project-kanban-card-compact w-full min-w-0 max-w-full overflow-hidden rounded-md border border-border bg-card p-1.5 shadow-sm transition-colors hover:border-accent" aria-label={ "Kanban card " + card.IssueNumber + " " + card.Title } { projectKanbanCardAttributes(data, card)... }>
		<div class="grid w-full min-w-0 max-w-full gap-1 overflow-hidden">
			<div class="flex w-full min-w-0 max-w-full items-center justify-between gap-1.5 overflow-hidden">
				<div class="flex min-w-0 flex-1 basis-0 items-center gap-1.5 overflow-hidden">
					if card.ProjectID != "" {
						<span class="h-5 w-1.5 shrink-0 rounded-full border border-border" aria-label={ "Project " + card.ProjectID + " color marker" } title={ "Project " + card.ProjectID } { projectColorAttributes(card.ProjectColor)... }></span>
					}
					if card.URL != "" {
						<a class="shrink-0 rounded-sm font-mono text-xs font-semibold text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer" aria-label={ "Open issue " + card.IssueNumber + ": " + card.Title }>{ card.IssueNumber }</a>
					} else {
						<span class="shrink-0 font-mono text-xs font-semibold text-accent">{ card.IssueNumber }</span>
					}
				</div>
				<div class="flex min-w-0 max-w-full flex-1 basis-0 items-center justify-end gap-1 overflow-hidden">
					<span class="inline-flex h-5 min-w-0 max-w-[6rem] items-center truncate rounded-sm bg-muted px-1.5 py-0.5 font-mono text-[11px] text-muted-foreground" title={ card.Identifier }>{ card.Stage }</span>
					@projectKanbanPullRequestSignal(card)
				</div>
			</div>
			if card.URL != "" {
				<a class="block w-full min-w-0 max-w-full overflow-hidden rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer" aria-label={ "Open issue " + card.IssueNumber + ": " + card.Title }>
					<span class="line-clamp-2 break-words text-[13px] font-normal leading-snug text-foreground">{ card.Title }</span>
				</a>
			} else {
				<span class="line-clamp-2 break-words text-[13px] font-normal leading-snug text-foreground">{ card.Title }</span>
			}
		</div>
		<div class="mt-1 flex min-w-0 max-w-full flex-wrap items-center gap-1 text-[11px]">
			if card.ProjectID != "" {
				<a class="inline-flex h-4 min-w-0 max-w-full items-center truncate rounded-sm border border-border bg-muted px-1 py-0 font-mono font-medium text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ projectKanbanPath(card.ProjectID) } title={ "Project " + card.ProjectID } aria-label={ "Open " + card.ProjectID + " Kanban" }>
					<span>{ card.ProjectID }</span>
				</a>
			}
			for _, chip := range projectKanbanCompactChips(card) {
				@projectKanbanCompactChipView(chip)
			}
		</div>
		if projectKanbanCardActionsVisible(data, card) {
			@projectKanbanActionButtons(data, card)
		}
		@projectKanbanCardDetails(data, card)
	</article>
}

templ projectKanbanPullRequestSignal(card projectKanbanCard) {
	if card.HasPullRequest {
		if card.PRURL != "" {
			<a class="inline-flex h-5 min-w-0 max-w-[5.5rem] items-center truncate rounded-sm bg-accent-soft px-1.5 py-0.5 font-mono text-[11px] font-medium text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.PRURL } target="_blank" rel="noopener noreferrer" aria-label={ "Open " + card.PullRequestLabel }>{ card.PullRequestLabel }</a>
		} else {
			<span class="inline-flex h-5 min-w-0 max-w-[5.5rem] items-center truncate rounded-sm bg-accent-soft px-1.5 py-0.5 font-mono text-[11px] font-medium text-accent">{ card.PullRequestLabel }</span>
		}
	} else {
		<span class="inline-flex h-5 min-w-0 max-w-[5.5rem] items-center truncate rounded-sm border border-border bg-muted px-1.5 py-0.5 text-[11px] font-medium text-muted-foreground">No PR</span>
	}
}

templ projectKanbanCompactChipView(chip projectKanbanCompactChip) {
	<span class={ "inline-flex h-4 min-w-0 max-w-full items-center truncate rounded-sm border px-1 py-0 font-medium " + chip.Class } title={ chip.Title }>{ chip.Label }</span>
}

templ projectKanbanCardDetails(data DashboardData, card projectKanbanCard) {
	<details class="group mt-1 min-w-0 max-w-full overflow-hidden border-t border-border pt-1" data-kanban-card-details data-preserve-details={ projectKanbanControlID("project-kanban-details", card) }>
		<summary class="flex min-h-6 min-w-0 max-w-full cursor-pointer list-none items-center justify-between gap-2 overflow-hidden rounded-sm px-1 py-0.5 text-xs font-medium text-muted-foreground hover:bg-muted/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" aria-label={ "Show details for " + card.IssueNumber }>
			<span class="inline-flex min-w-0 flex-1 basis-0 items-center gap-1.5">
				@icon.ListPlus(icon.Props{Class: "size-3.5 shrink-0"})
				<span class="truncate">Details</span>
			</span>
			@icon.ChevronDown(icon.Props{Class: "size-3.5 shrink-0"})
		</summary>
		<div class="mt-2 grid min-w-0 max-w-full gap-2 text-xs" data-kanban-card-expanded>
			<div class="grid min-w-0 max-w-full gap-1.5 overflow-hidden rounded-md bg-muted/40 p-2">
				@projectKanbanDetailRow("Status", card.Stage, card.Identifier)
				@projectKanbanDetailRow("Time in stage", card.TimeInStage, card.TimeInStageTitle)
				if card.MergeLaneStatus != "" {
					@projectKanbanDetailRow("Merge lane", card.MergeLaneStatus, card.MergeLaneDetail)
				}
				if card.ProjectID != "" {
					@projectKanbanDetailRow("Project", card.ProjectID, card.ProjectID)
				}
				@projectKanbanDetailLink("Issue", card.Identifier, card.URL)
				if card.HasPullRequest {
					@projectKanbanDetailLink("Pull request", card.PullRequestLabel, card.PRURL)
					if card.MergeableState != "" {
						@projectKanbanDetailRow("Merge state", card.MergeableState, "GitHub mergeStateStatus")
					}
					if card.ConflictReason != "" {
						@projectKanbanDetailRow("Conflict", card.ConflictReason, card.ConflictReason)
					}
					@projectKanbanDetailRow("CI", card.CIStatus, "Continuous integration status")
					@projectKanbanDetailRow("Codex review", card.CodexReviewState, "Codex review state")
				} else {
					@projectKanbanDetailRow("Pull request", card.PullRequestLabel, "")
				}
				if card.WaitDetail != "" {
					@projectKanbanDetailRow("Waits", card.WaitDetail, card.WaitDetail)
				}
			</div>
			if len(card.Labels) > 0 || len(card.Assignees) > 0 || len(card.Blockers) > 0 || len(card.ClearedBlockers) > 0 {
				<div class="grid min-w-0 max-w-full gap-2">
					if len(card.Labels) > 0 {
						@projectKanbanPillRow("Labels", card.Labels)
					}
					if len(card.Assignees) > 0 {
						@projectKanbanPillRow("Assignees", card.Assignees)
					}
					if len(card.Blockers) > 0 {
						@projectKanbanPillRow("Blockers", card.Blockers)
					}
					if len(card.ClearedBlockers) > 0 {
						@projectKanbanPillRow("Cleared blockers", card.ClearedBlockers)
					}
				</div>
			}
			if projectKanbanMoveDisabledText(data, card) != "" && projectKanbanCardIntegrationEnabled(data, card) {
				<div class="min-w-0 max-w-full overflow-hidden break-words rounded-md border border-border bg-muted/60 px-3 py-2 text-sm text-muted-foreground">{ projectKanbanMoveDisabledText(data, card) }</div>
			}
		</div>
	</details>
}

templ projectKanbanDetailRow(label string, value string, title string) {
	if value != "" {
		<div class="flex min-w-0 max-w-full items-center justify-between gap-2 overflow-hidden">
			<span class="shrink-0 text-muted-foreground">{ label }</span>
			<span class="min-w-0 truncate font-mono font-medium text-foreground" title={ title }>{ value }</span>
		</div>
	}
}

templ projectKanbanDetailLink(label string, value string, href string) {
	if value != "" {
		<div class="flex min-w-0 max-w-full items-center justify-between gap-2 overflow-hidden">
			<span class="shrink-0 text-muted-foreground">{ label }</span>
			if href != "" {
				<a class="min-w-0 truncate font-mono font-medium text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ href } target="_blank" rel="noopener noreferrer">{ value }</a>
			} else {
				<span class="min-w-0 truncate font-mono font-medium text-foreground">{ value }</span>
			}
		</div>
	}
}

templ projectKanbanPillRow(label string, values []string) {
	<div class="grid min-w-0 max-w-full gap-1">
		<span class="text-xs font-medium text-muted-foreground">{ label }</span>
		<div class="flex min-w-0 max-w-full flex-wrap gap-1.5 overflow-hidden">
			for _, value := range values {
				<span class="inline-flex min-w-0 max-w-full truncate rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ value }>{ value }</span>
			}
		</div>
	</div>
}

templ projectKanbanActionButtons(data DashboardData, card projectKanbanCard) {
	<div class="mt-3 flex min-w-0 max-w-full flex-wrap items-center gap-1.5" aria-label="Kanban actions">
		if projectKanbanCardCanMove(data, card) {
			@projectKanbanMoveDialogTrigger(data, card)
			if projectKanbanDragDropEnabled(data) {
				@projectKanbanDragMoveForm(data, card)
			}
		}
		if isProjectDashboard(data) && kanbanIntegrationEnabled(data) {
			if projectKanbanCardCanRemove(data, card) {
				@projectKanbanRemoveForm(data, card)
			}
			@projectKanbanCommentDialogTriggers(data, card)
		}
	</div>
}

templ projectKanbanMoveDialogTrigger(data DashboardData, card projectKanbanCard) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     projectKanbanMoveDialogPath(data, card),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": "Move " + card.IssueNumber,
				"title":      "Move card",
			},
		}) {
			@icon.MoveRight(icon.Props{Class: "size-4"})
			<span class="sr-only">Move</span>
		}
	}
}

templ projectKanbanDragMoveForm(data DashboardData, card projectKanbanCard) {
	<form class="hidden" hx-post="/api/v1/kanban/move" hx-target="#kanban-feedback" hx-swap="outerHTML" data-kanban-drag-move-form>
		<input type="hidden" name="kanban_drag" value="true"/>
		<input type="hidden" name="kanban_board" value={ projectKanbanBoardScope(data) }/>
		<input type="hidden" name="project_id" value={ projectKanbanCardProjectID(data, card) }/>
		<input type="hidden" name="issue_id" value={ card.IssueID }/>
		<input type="hidden" name="identifier" value={ card.Identifier }/>
		<input type="hidden" name="title" value={ card.Title }/>
		<input type="hidden" name="current_state" value={ card.Stage }/>
		<input type="hidden" name="target_state" value="" data-kanban-drag-target-state/>
		if card.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(card.PRNumber) }/>
		}
	</form>
}

templ projectKanbanRemoveForm(data DashboardData, card projectKanbanCard) {
	<form class="inline-flex" hx-post="/api/v1/kanban/remove" hx-target="#kanban-feedback" hx-swap="outerHTML" hx-confirm="Remove this item from project?">
		<input type="hidden" name="project_id" value={ projectKanbanCardProjectID(data, card) }/>
		<input type="hidden" name="issue_id" value={ card.IssueID }/>
		<input type="hidden" name="current_state" value={ card.Stage }/>
		if card.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(card.PRNumber) }/>
		}
		@button.Button(button.Props{
			Type:    button.TypeSubmit,
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-danger-soft bg-card text-danger hover:border-danger hover:bg-danger-soft hover:text-danger focus-visible:ring-danger",
			Attributes: templ.Attributes{
				"aria-label": "Remove " + card.IssueNumber + " from project",
				"title":      "Remove from project",
			},
		}) {
			@icon.FolderMinus(icon.Props{Class: "size-4"})
			<span class="sr-only">Remove from project</span>
		}
	</form>
}

templ projectKanbanCommentDialogTriggers(data DashboardData, card projectKanbanCard) {
	if card.IssueID != "" {
		@projectKanbanCommentDialogTrigger(data, card, "issue", "Comment on issue", "Issue comment")
	}
	if card.PRNumber > 0 && card.PRRepository != "" {
		@projectKanbanCommentDialogTrigger(data, card, "pr", "Comment on PR", "PR comment")
	}
}

templ projectKanbanCommentDialogTrigger(data DashboardData, card projectKanbanCard, target string, title string, label string) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     projectKanbanCommentDialogPath(data, card, target),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": title + " " + card.IssueNumber,
				"title":      label,
			},
		}) {
			if target == "pr" {
				@icon.GitPullRequest(icon.Props{Class: "size-4"})
			} else {
				@icon.MessageSquarePlus(icon.Props{Class: "size-4"})
			}
			<span class="sr-only">{ label }</span>
		}
	}
}

templ throughputCard(data DashboardData) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Token throughput", helpThroughput, "throughput-card")
			<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 font-mono text-xs font-medium text-accent">{ throughputRate(data.Snapshot) }</span>
		</div>
		<div class="mt-5 grid gap-2">
			<div class="break-all font-mono text-2xl font-semibold text-foreground sm:text-3xl">{ throughputRate(data.Snapshot) }</div>
			<div class="text-sm text-muted-foreground">{ throughputWindowLabel(data.Snapshot) }</div>
		</div>
		<div class="mt-5">
			if len(throughputTrendPoints(data.Snapshot)) == 0 {
				@dashboardEmptyState("No throughput data yet.", "Rolling token samples will appear after activity is recorded.", "bg-accent")
			} else {
				@LineAreaChart(throughputTrendChart(data))
			}
		</div>
	</section>
}

templ lifetimeCard(totals telemetry.LifetimeTotals) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Lifetime totals", helpLifetimeTotals, "lifetime-card")
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ lifetimeStatus(totals) }</span>
		</div>
		if !totals.Available {
			<div class="mt-4">
				@dashboardEmptyState("Lifetime totals unavailable.", lifetimeDegradedReason(totals), "bg-muted-foreground")
			</div>
		} else {
			<div class="mt-5 grid gap-3 text-sm">
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Tokens</span>
					<strong class="font-mono font-medium text-foreground">{ formatInt(totals.TotalTokens) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Input / output</span>
					<strong class="font-mono font-medium text-foreground">{ formatInt(totals.InputTokens) } / { formatInt(totals.OutputTokens) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Sessions</span>
					<strong class="font-mono font-medium text-foreground">{ lifetimeSessions(totals) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Runtime</span>
					<strong class="font-mono font-medium text-foreground">{ lifetimeRuntime(totals) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					<span class="text-muted-foreground">Runs</span>
					<strong class="font-mono font-medium text-foreground">{ lifetimeRuns(totals) }</strong>
				</div>
			</div>
		}
	</section>
}

templ LiveTick(timestamp time.Time) {
	<span class="font-mono">Updated { timestamp.UTC().Format("15:04:05 UTC") }</span>
}

templ trackerDriftWarning(snapshot telemetry.Snapshot) {
	if trackerDriftVisible(snapshot) {
		<section class="rounded-md border border-warning bg-warning-soft p-4 text-warning shadow-sm" aria-label="Tracker status drift">
			<div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
				<div class="min-w-0">
					<div class="flex min-w-0 items-center gap-2">
						@icon.CircleAlert(icon.Props{Class: "size-4 shrink-0"})
						<h2 class="truncate text-sm font-semibold">Tracker status drift</h2>
						<span class="shrink-0 rounded-full bg-card/70 px-2 py-0.5 font-mono text-xs font-medium text-warning">{ trackerDriftTotalLabel(snapshot) }</span>
					</div>
					<p class="mt-1 text-sm text-warning">Open GitHub issues need status-label cleanup before the label-backed board is fully reconciled.</p>
				</div>
				<div class="grid min-w-0 gap-3 lg:min-w-[26rem] lg:max-w-2xl lg:grid-cols-2">
					for _, row := range trackerDriftRows(snapshot) {
						<div class="min-w-0 rounded-md border border-warning-soft bg-card/70 p-3">
							<div class="flex min-w-0 items-center justify-between gap-3">
								<h3 class="truncate text-sm font-semibold text-foreground">{ row.Title }</h3>
								<span class="shrink-0 rounded-full bg-warning-soft px-2 py-0.5 font-mono text-xs font-medium text-warning">{ row.CountLabel }</span>
							</div>
							<p class="mt-1 text-xs text-muted-foreground">{ row.Detail }</p>
							<ul class="mt-3 grid gap-2">
								for _, issue := range row.Issues {
									<li class="min-w-0 text-xs">
										<a class="inline-flex max-w-full items-center gap-1.5 font-medium text-accent hover:underline" href={ issue.URL } target="_blank" rel="noopener noreferrer">
											<span class="shrink-0 font-mono">{ issue.Number }</span>
											<span class="truncate">{ issue.Title }</span>
										</a>
										if issue.State != "" || issue.Labels != "" {
											<div class="mt-1 flex min-w-0 flex-wrap gap-1.5 text-[0.7rem] text-muted-foreground">
												if issue.State != "" {
													<span class="rounded-sm bg-muted px-1.5 py-0.5">State { issue.State }</span>
												}
												if issue.Labels != "" {
													<span class="min-w-0 truncate rounded-sm bg-muted px-1.5 py-0.5" title={ issue.Labels }>{ issue.Labels }</span>
												}
											</div>
										}
									</li>
								}
							</ul>
						</div>
					}
				</div>
			</div>
		</section>
	}
}

templ dashboardHealth(data DashboardData) {
	<section id="dashboard-diagnostics" class="scroll-mt-3 flex flex-wrap items-center gap-2 rounded-md border border-border bg-card p-3 shadow-sm" aria-label="Dashboard health" tabindex="-1">
		<span class={ "inline-flex min-h-8 items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold " + runtimeStatusClass(data.Snapshot) } aria-label="Runtime status">
			<span class="h-2 w-2 rounded-full bg-current"></span>
			<span>{ runtimeStatusLabel(data.Snapshot) }</span>
		</span>
		<span class={ "inline-flex min-h-8 items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold " + statsStatusClass(data.Snapshot) } aria-label="Stats status" title={ statsStatusTitle(data.Snapshot) }>
			<span class="h-2 w-2 rounded-full bg-current"></span>
			<span>{ statsStatusLabel(data.Snapshot) }</span>
		</span>
		<span class="inline-flex min-h-8 max-w-full items-center gap-2 rounded-full border border-border bg-muted px-3 py-1 text-xs font-semibold text-muted-foreground sm:max-w-[24rem]" aria-label="Instance identity" title={ instanceLabel(data.Snapshot) }>
			<span>Instance</span>
			<span class="truncate font-medium text-foreground">{ instanceLabel(data.Snapshot) }</span>
		</span>
		<span class={ "inline-flex min-h-8 max-w-full items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold sm:max-w-[32rem] " + dashboardScopeClass(data) } aria-label="Dashboard scope" title={ dashboardScopeLabel(data) }>
			<span>Scope</span>
			<span class="truncate">{ dashboardScopeLabel(data) }</span>
		</span>
	</section>
}

templ snapshotReadiness(snapshot telemetry.Snapshot) {
	<section
		class={ snapshotReadinessClass(snapshot) }
		aria-label="Snapshot readiness"
		if snapshotDegraded(snapshot) && !snapshotHasPriorTrackerSnapshot(snapshot) {
			role="alert"
		} else {
			role="status"
		}
	>
		<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
			<div class="flex min-w-0 items-start gap-3">
				<span class={ "mt-1 h-2.5 w-2.5 shrink-0 rounded-full " + snapshotReadinessDotClass(snapshot) }></span>
				<div class="min-w-0">
					<h2 class="text-sm font-semibold">{ snapshotReadinessTitle(snapshot) }</h2>
					<p class={ "mt-1 text-sm " + snapshotReadinessDetailClass(snapshot) }>{ snapshotReadinessDetail(snapshot) }</p>
				</div>
			</div>
			if manualRefreshVisible(snapshot) {
				<div class="flex min-w-0 flex-col gap-2 sm:max-w-sm sm:items-end">
					<form class="flex justify-start sm:justify-end" hx-post="/api/v1/refresh" hx-target="#manual-refresh-status" hx-swap="outerHTML">
						@button.Button(button.Props{
							Type:    button.TypeSubmit,
							Variant: button.VariantOutline,
							Size:    button.SizeSm,
							Class:   "border-warning bg-card text-warning hover:border-accent hover:text-accent",
							Attributes: templ.Attributes{
								"aria-label": "Force tracker refresh",
							},
						}) {
							@icon.RefreshCw(icon.Props{Class: "size-3.5 shrink-0"})
							<span>Force refresh</span>
						}
					</form>
					@ManualRefreshFeedback(snapshot.Refresh.Manual)
				</div>
			}
		</div>
	</section>
}

templ ManualRefreshFeedback(attempt *telemetry.RefreshAttempt) {
	@ManualRefreshFeedbackWithID("manual-refresh-status", attempt)
}

templ ManualRefreshFeedbackWithID(id string, attempt *telemetry.RefreshAttempt) {
	<div id={ id } role="status" aria-live="polite" class="min-w-0">
		if manualRefreshStatusVisible(attempt) {
			<div class={ manualRefreshStatusClass(attempt) }>
				<div class="font-semibold">{ manualRefreshStatusLabel(attempt) }</div>
				if manualRefreshStatusDetail(attempt) != "" {
					<div class="mt-1 break-words opacity-90">{ manualRefreshStatusDetail(attempt) }</div>
				}
			</div>
		}
	</div>
}

templ metricCard(label string, term helpTerm, value string, detail string, borderClass string, dotClass string) {
	<article class={ "dashboard-metric-card min-w-0 rounded-md border border-border border-t-2 bg-card p-3 shadow-sm transition-colors hover:bg-muted/40 sm:p-4 " + borderClass }>
		<div class="flex items-start justify-between gap-3">
			<div class="grid min-w-0 gap-1">
				@helpInlineLabel(label, term, "dashboard", "text-sm font-medium text-muted-foreground")
				<span class="text-xs text-muted-foreground">{ detail }</span>
			</div>
			<span class={ "h-2.5 w-2.5 shrink-0 rounded-full " + dotClass }></span>
		</div>
		<div class="mt-4 break-all font-mono text-2xl font-semibold text-foreground sm:text-3xl">{ value }</div>
	</article>
}

templ statStrip(snapshot telemetry.Snapshot) {
	<section class="dashboard-stat-strip grid min-w-0 gap-2 rounded-md border border-border bg-card p-2 shadow-sm sm:grid-cols-2 lg:grid-cols-6" aria-label="Dashboard statistics">
		@statStripItem("Running", helpRunning, formatCount(runningCount(snapshot)), "Active issue sessions", "bg-accent")
		@statStripItem("Queue", helpQueue, formatCount(queueCount(snapshot)), "Waiting or retrying", "bg-warning")
		@statStripItem("Blocked", helpBlocked, formatCount(blockedCount(snapshot)), "Needs operator action", "bg-danger")
		@statStripItem("Completed", helpCompleted, formatCount(completedCount(snapshot)), "Finished sessions", "bg-success")
		@statStripItem("tps", helpThroughput, throughputRate(snapshot), "Rolling tokens/sec", "bg-accent")
		@statStripItem("Uptime", helpRuntime, runtimeLabel(snapshot), "Aggregate agent uptime", "bg-success")
	</section>
}

templ statStripItem(label string, term helpTerm, value string, detail string, dotClass string) {
	<div class="min-w-0 rounded-md bg-muted/60 px-3 py-2">
		<div class="flex min-w-0 items-center justify-between gap-2">
			@helpInlineLabel(label, term, "dashboard-stat-strip", "truncate text-xs font-medium uppercase text-muted-foreground")
			<span class={ "h-2 w-2 shrink-0 rounded-full " + dotClass }></span>
		</div>
		<div class="mt-1 truncate font-mono text-lg font-semibold text-foreground">{ value }</div>
		<div class="truncate text-xs text-muted-foreground">{ detail }</div>
	</div>
}

templ dashboardEmptyState(title string, detail string, dotClass string) {
	<div class="dashboard-empty-state min-w-0 max-w-full overflow-hidden rounded-md border border-dashed border-border bg-muted/60 px-3 py-3 text-left">
		<div class="flex min-w-0 items-start gap-3">
			<span class={ "mt-1.5 h-2 w-2 shrink-0 rounded-full " + dotClass }></span>
			<div class="min-w-0 flex-1">
				<p class="break-words text-sm font-medium text-foreground">{ title }</p>
				if detail != "" {
					<p class="mt-1 break-words text-sm text-muted-foreground">{ detail }</p>
				}
			</div>
		</div>
	</div>
}

templ prPipelineSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Pull request pipeline">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("PR pipeline", helpPRPipeline, "pr-pipeline")
				<p class="text-sm text-muted-foreground">Live merge-train lanes for pull requests moving from review to integration.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ prPipelineTotalLabel(snapshot) }</span>
		</div>
		@prPipelineMergeSummaryView(prPipelineMergeSummary(snapshot))
		<div class="dashboard-section-grid mt-4 grid min-w-0 gap-3 lg:grid-cols-3">
			for _, lane := range prPipelineLanes(snapshot) {
				@prPipelineLaneView(lane)
			}
		</div>
	</section>
}

templ prPipelineMergeSummaryView(summary prPipelineMergeMetrics) {
	if summary.Available {
		<div class="mt-4 grid min-w-0 gap-2 sm:grid-cols-2 xl:grid-cols-7">
			<div class={ "min-w-0 rounded-md border px-3 py-2 " + prPipelineMergeSummaryClass(summary.ActiveWarning) }>
				<span class="block text-xs font-medium uppercase">Active</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.ActiveElapsed }</span>
			</div>
			<div class={ "min-w-0 rounded-md border px-3 py-2 " + prPipelineMergeSummaryClass(summary.QueueWarning) }>
				<span class="block text-xs font-medium uppercase">Queued</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.QueueWait }</span>
			</div>
			<div class="min-w-0 rounded-md border border-border bg-card px-3 py-2 text-foreground">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Recent</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.RecentCount }</span>
			</div>
			<div class="min-w-0 rounded-md border border-border bg-card px-3 py-2 text-foreground">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Active p50</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.ActiveP50 }</span>
			</div>
			<div class="min-w-0 rounded-md border border-border bg-card px-3 py-2 text-foreground">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Active p90</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.ActiveP90 }</span>
			</div>
			<div class="min-w-0 rounded-md border border-border bg-card px-3 py-2 text-foreground">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Total p50</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.TotalP50 }</span>
			</div>
			<div class="min-w-0 rounded-md border border-border bg-card px-3 py-2 text-foreground">
				<span class="block text-xs font-medium uppercase text-muted-foreground">Total p90</span>
				<span class="mt-1 block truncate font-mono text-sm font-semibold">{ summary.TotalP90 }</span>
			</div>
		</div>
	}
}

templ prPipelineLaneView(lane prPipelineLane) {
	<section class="pr-pipeline-lane min-w-0 rounded-md border border-border bg-muted/60 p-3" aria-label={ lane.Title + " lane" }>
		<div class="flex min-h-9 items-center justify-between gap-3">
			<div class="inline-flex min-w-0 items-center gap-2">
				<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
				<h3 class="truncate text-sm font-semibold text-foreground">{ lane.Title }</h3>
			</div>
			<span class="shrink-0 rounded-full bg-card px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ lane.CountLabel }</span>
		</div>
		if len(lane.Cards) == 0 {
			<div class="mt-3">
				@dashboardEmptyState(lane.EmptyTitle, lane.EmptyDetail, lane.DotClass)
			</div>
		} else {
			<div class="pr-pipeline-lane-scroll mt-3 grid auto-rows-max max-h-[24rem] gap-2 overflow-y-auto pb-1 pr-1" data-preserve-scroll={ "pr-pipeline-" + lane.ID }>
				for _, card := range lane.Cards {
					@prPipelineCardView(card)
				}
			</div>
		}
	</section>
}

templ prPipelineCardView(card prPipelineCard) {
	<article class="pr-pipeline-card min-w-0 rounded-md border border-border bg-card p-3 shadow-sm" data-pr-pipeline-identity={ card.Identity.Label }>
		<div class="flex min-w-0 items-start justify-between gap-3">
			<div class="min-w-0 flex-1 basis-0">
				if card.URL != "" {
					<a class="block min-w-0 max-w-full overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer" aria-label={ "Open " + card.Identity.Label }>
						@issueIdentityLine(card.Identity, true)
						<span class="mt-1 line-clamp-2 break-words text-sm font-medium text-foreground">{ card.Title }</span>
					</a>
				} else {
					@issueIdentityLine(card.Identity, true)
					<span class="mt-1 line-clamp-2 break-words text-sm font-medium text-foreground">{ card.Title }</span>
				}
				if card.ProjectID != "" {
					<span class="mt-2 inline-flex max-w-full overflow-hidden rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ "Project " + card.ProjectID }>
						<span class="min-w-0 truncate">{ card.ProjectID }</span>
					</span>
				}
			</div>
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ card.Identifier }>{ card.Stage }</span>
		</div>
		<div class="mt-3 grid gap-2 text-xs">
			<div class="flex flex-wrap gap-2">
				if card.MergeLaneStatus != "" {
					<span class={ "inline-flex min-h-7 items-center rounded-full border px-2 py-1 font-medium " + card.MergeLaneClass } title={ card.MergeLaneDetail }>{ card.MergeLaneStatus }</span>
				}
				<span class={ "inline-flex min-h-7 items-center rounded-full border px-2 py-1 font-medium " + card.CIClass }>CI { card.CIStatus }</span>
				<span class={ "inline-flex min-h-7 items-center rounded-full border px-2 py-1 font-medium " + card.CodexReviewClass }>Codex { card.CodexReviewState }</span>
			</div>
			if card.MergeLaneStatus != "" {
				<div class="flex min-h-7 items-center justify-between gap-3 rounded-md bg-muted/60 px-2 py-1">
					<span class="text-muted-foreground">Merge lane</span>
					<span class="min-w-0 truncate font-mono font-medium text-foreground" title={ card.MergeLaneDetail }>{ card.MergeLaneDetail }</span>
				</div>
			}
			<div class="flex min-h-7 items-center justify-between gap-3 rounded-md bg-muted/60 px-2 py-1">
				<span class="text-muted-foreground">Time in stage</span>
				<span class="font-mono font-medium text-foreground" title={ card.TimeInStageTitle }>{ card.TimeInStage }</span>
			</div>
			if card.WaitDetail != "" {
				<div class="flex min-h-7 items-center justify-between gap-3 rounded-md bg-muted/60 px-2 py-1">
					<span class="text-muted-foreground">Waits</span>
					<span class="min-w-0 truncate font-mono font-medium text-foreground" title={ card.WaitDetail }>{ card.WaitDetail }</span>
				</div>
			}
		</div>
	</article>
}

templ kanbanBoardSection(data DashboardData) {
	if len(kanbanLanes(data)) > 0 {
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Kanban board" data-kanban-board>
			<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
				<div class="min-w-0">
					<h2 class="text-base font-semibold text-foreground">Kanban board</h2>
				</div>
				<span class="inline-flex min-h-9 shrink-0 items-center justify-center rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ data.Kanban.Mode }</span>
			</div>
			if kanbanIntegrationEnabled(data) {
				<div id="kanban-feedback" role="status" aria-live="polite" class={ kanbanFeedbackClass(data.Kanban) }>{ kanbanFeedbackText(data.Kanban) }</div>
			}
			<div class="mt-4 grid min-w-0 max-w-full gap-3 overflow-x-hidden lg:grid-cols-3">
				for _, lane := range kanbanLanes(data) {
					@kanbanLaneView(data, lane)
				}
			</div>
			if kanbanIntegrationEnabled(data) {
				@kanbanScript()
			}
		</section>
	}
}

templ kanbanLaneView(data DashboardData, lane kanbanLane) {
	<section class="min-w-0 max-w-full overflow-hidden rounded-md border border-border bg-muted/60 p-3" aria-label={ lane.State + " Kanban lane" } { kanbanLaneAttributes(data, lane)... }>
		<div class="flex min-h-9 min-w-0 max-w-full items-center justify-between gap-3 overflow-hidden">
			<div class="inline-flex min-w-0 flex-1 basis-0 items-center gap-2 overflow-hidden">
				<span class={ "h-2 w-2 shrink-0 rounded-full " + lane.DotClass }></span>
				<h3 class="min-w-0 truncate text-sm font-semibold text-foreground">{ lane.State }</h3>
			</div>
			<span class="shrink-0 rounded-full bg-card px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ lane.CountLabel }</span>
		</div>
		if len(lane.Cards) == 0 {
			<div class="mt-3 min-w-0 max-w-full overflow-hidden">
				@dashboardEmptyState("No cards in this state.", "", lane.DotClass)
			</div>
		} else {
			<div class="mt-3 grid auto-rows-max min-w-0 max-w-full max-h-[28rem] gap-2 overflow-x-hidden overflow-y-auto pr-1" data-preserve-scroll={ "kanban-" + lane.State }>
				for _, card := range lane.Cards {
					@kanbanCardView(data, card)
				}
			</div>
		}
	</section>
}

templ kanbanCardView(data DashboardData, card kanbanCard) {
	<article class="min-w-0 max-w-full overflow-hidden rounded-md border border-border bg-card p-3 shadow-sm" { kanbanCardAttributes(data, card)... }>
		<div class="flex min-w-0 max-w-full items-start justify-between gap-3 overflow-hidden">
			<div class="min-w-0 flex-1 basis-0 overflow-hidden">
				if card.URL != "" {
					<a class="block min-w-0 max-w-full overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.URL } target="_blank" rel="noopener noreferrer">
						<span class="block min-w-0 truncate font-mono text-xs font-semibold text-accent">{ card.Identifier }</span>
						<span class="mt-1 line-clamp-2 break-words text-sm font-medium text-foreground">{ card.Title }</span>
					</a>
				} else {
					<span class="block min-w-0 truncate font-mono text-xs font-semibold text-accent">{ card.Identifier }</span>
					<span class="mt-1 line-clamp-2 break-words text-sm font-medium text-foreground">{ card.Title }</span>
				}
			</div>
			<span class="min-w-0 max-w-[7rem] shrink-0 truncate rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ card.State }</span>
		</div>
		if card.ProjectID != "" || card.PRNumber > 0 {
			<div class="mt-2 flex min-w-0 max-w-full flex-wrap gap-2 overflow-hidden">
				if card.ProjectID != "" {
					<span class="inline-flex min-w-0 max-w-full items-center gap-1.5 overflow-hidden rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ "Project " + card.ProjectID }>
						<span class="h-3 w-1.5 shrink-0 rounded-full border border-border" aria-label={ "Project " + card.ProjectID + " color marker" } { projectColorAttributes(card.ProjectColor)... }></span>
						<span class="min-w-0 truncate">{ card.ProjectID }</span>
					</span>
				}
				if card.PRNumber > 0 {
					if card.PRURL != "" {
						<a class="inline-flex min-w-0 max-w-full truncate rounded-full bg-accent-soft px-2 py-1 font-mono text-xs text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ card.PRURL } target="_blank" rel="noopener noreferrer">PR #{ strconv.Itoa(card.PRNumber) }</a>
					} else {
						<span class="inline-flex min-w-0 max-w-full truncate rounded-full bg-accent-soft px-2 py-1 font-mono text-xs text-accent">PR #{ strconv.Itoa(card.PRNumber) }</span>
					}
				}
			</div>
		}
		if kanbanMoveDisabledText(data, card) != "" {
			<div class="mt-3 min-w-0 max-w-full overflow-hidden break-words rounded-md border border-border bg-muted/60 px-3 py-2 text-sm text-muted-foreground">{ kanbanMoveDisabledText(data, card) }</div>
		}
		if kanbanIntegrationEnabled(data) {
			@kanbanActionButtons(data, card)
		}
	</article>
}

templ kanbanActionButtons(data DashboardData, card kanbanCard) {
	<div class="mt-3 flex min-w-0 max-w-full flex-wrap items-center gap-1.5" aria-label="Kanban actions">
		if kanbanCardCanMove(data, card) {
			@kanbanMoveDialogTrigger(data, card)
			@kanbanDragMoveForm(data, card)
		}
		if kanbanCardCanRemove(data, card) {
			@kanbanRemoveForm(data, card)
		}
		@kanbanCommentDialogTriggers(data, card)
	</div>
}

templ kanbanMoveDialogTrigger(data DashboardData, card kanbanCard) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     kanbanMoveDialogPath(data, card),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": "Move " + card.Identifier,
				"title":      "Move card",
			},
		}) {
			@icon.MoveRight(icon.Props{Class: "size-4"})
			<span class="sr-only">Move</span>
		}
	}
}

templ kanbanDragMoveForm(data DashboardData, card kanbanCard) {
	<form class="hidden" hx-post="/api/v1/kanban/move" hx-target="#kanban-feedback" hx-swap="outerHTML" data-kanban-drag-move-form>
		<input type="hidden" name="kanban_drag" value="true"/>
		<input type="hidden" name="project_id" value={ kanbanProjectID(data) }/>
		<input type="hidden" name="issue_id" value={ card.IssueID }/>
		<input type="hidden" name="identifier" value={ card.Identifier }/>
		<input type="hidden" name="title" value={ card.Title }/>
		<input type="hidden" name="current_state" value={ card.State }/>
		<input type="hidden" name="target_state" value="" data-kanban-drag-target-state/>
		if card.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(card.PRNumber) }/>
		}
	</form>
}

templ kanbanRemoveForm(data DashboardData, card kanbanCard) {
	<form class="inline-flex" hx-post="/api/v1/kanban/remove" hx-target="#kanban-feedback" hx-swap="outerHTML" hx-confirm="Remove this item from project?">
		<input type="hidden" name="project_id" value={ kanbanProjectID(data) }/>
		<input type="hidden" name="issue_id" value={ card.IssueID }/>
		<input type="hidden" name="current_state" value={ card.State }/>
		if card.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(card.PRNumber) }/>
		}
		@button.Button(button.Props{
			Type:    button.TypeSubmit,
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-danger-soft bg-card text-danger hover:border-danger hover:bg-danger-soft hover:text-danger focus-visible:ring-danger",
			Attributes: templ.Attributes{
				"aria-label": "Remove " + card.Identifier + " from project",
				"title":      "Remove from project",
			},
		}) {
			@icon.FolderMinus(icon.Props{Class: "size-4"})
			<span class="sr-only">Remove from project</span>
		}
	</form>
}

templ kanbanCommentDialogTriggers(data DashboardData, card kanbanCard) {
	if card.IssueID != "" {
		@kanbanCommentDialogTrigger(data, card, "issue", "Comment on issue", "Issue comment")
	}
	if card.PRNumber > 0 && card.PRRepository != "" {
		@kanbanCommentDialogTrigger(data, card, "pr", "Comment on PR", "PR comment")
	}
}

templ kanbanCommentDialogTrigger(data DashboardData, card kanbanCard, target string, title string, label string) {
	@dialog.Trigger(dialog.TriggerProps{For: kanbanActionDialogID}) {
		@button.Button(button.Props{
			Size:    button.SizeIcon,
			Variant: button.VariantGhost,
			Class:   "size-8 border border-border bg-card text-muted-foreground hover:text-accent",
			Attributes: templ.Attributes{
				"hx-get":     kanbanCommentDialogPath(data, card, target),
				"hx-target":  kanbanDialogTargetSelector(),
				"hx-swap":    "innerHTML",
				"aria-label": title + " " + card.Identifier,
				"title":      label,
			},
		}) {
			if target == "pr" {
				@icon.GitPullRequest(icon.Props{Class: "size-4"})
			} else {
				@icon.MessageSquarePlus(icon.Props{Class: "size-4"})
			}
			<span class="sr-only">{ label }</span>
		}
	}
}

templ KanbanMoveDialogContent(data KanbanMoveDialogData) {
	@dialog.Header() {
		@dialog.Title() {
			Move card
		}
		@dialog.Description() {
			{ kanbanDialogCardLabel(data.Identifier, data.Title) }
		}
	}
	@kanbanDialogError(data.Error)
	<form class="grid gap-4" hx-post="/api/v1/kanban/move" hx-target="#kanban-feedback" hx-swap="outerHTML">
		<input type="hidden" name="kanban_dialog" value="true"/>
		<input type="hidden" name="kanban_board" value={ data.Board }/>
		<input type="hidden" name="project_id" value={ data.ProjectID }/>
		<input type="hidden" name="issue_id" value={ data.IssueID }/>
		<input type="hidden" name="current_state" value={ data.CurrentState }/>
		<input type="hidden" name="identifier" value={ data.Identifier }/>
		<input type="hidden" name="title" value={ data.Title }/>
		if data.PRNumber > 0 {
			<input type="hidden" name="pr_number" value={ strconv.Itoa(data.PRNumber) }/>
		}
		<div class="grid gap-2">
			<label class="text-sm font-medium text-foreground" for="kanban-dialog-target-state">Target state</label>
			<select id="kanban-dialog-target-state" name="target_state" class="min-h-10 w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent" data-kanban-status-menu>
				for _, state := range data.States {
					<option value={ state } selected?={ normalizeDashboardState(state) == normalizeDashboardState(kanbanMoveDialogTargetState(data)) }>{ state }</option>
				}
			</select>
		</div>
		@dialog.Footer() {
			@dialog.Close() {
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Type:    button.TypeButton,
				}) {
					Cancel
				}
			}
			@button.Button(button.Props{Type: button.TypeSubmit}) {
				@icon.MoveRight(icon.Props{Class: "size-4"})
				Move
			}
		}
	</form>
}

templ KanbanCommentDialogContent(data KanbanCommentDialogData) {
	@dialog.Header() {
		@dialog.Title() {
			Comment on { kanbanCommentTargetLabel(data.Target) }
		}
		@dialog.Description() {
			{ kanbanDialogCardLabel(data.Identifier, data.Title) }
		}
	}
	@kanbanDialogError(data.Error)
	<form class="grid gap-4" hx-post="/api/v1/kanban/comment" hx-target="#kanban-feedback" hx-swap="outerHTML">
		<input type="hidden" name="kanban_dialog" value="true"/>
		<input type="hidden" name="project_id" value={ data.ProjectID }/>
		<input type="hidden" name="target" value={ data.Target }/>
		<input type="hidden" name="identifier" value={ data.Identifier }/>
		<input type="hidden" name="title" value={ data.Title }/>
		if data.Target == "issue" {
			<input type="hidden" name="issue_id" value={ data.IssueID }/>
		}
		if data.Target == "pr" {
			<input type="hidden" name="pr_repository" value={ data.PRRepository }/>
			<input type="hidden" name="pr_number" value={ strconv.Itoa(data.PRNumber) }/>
		}
		<div class="grid gap-2">
			<label class="text-sm font-medium text-foreground" for="kanban-dialog-comment-body">Comment</label>
			<textarea id="kanban-dialog-comment-body" name="body" rows="5" class="min-h-32 w-full resize-y rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent" placeholder={ kanbanCommentTargetLabel(data.Target) + " comment" }>{ data.Body }</textarea>
		</div>
		@dialog.Footer() {
			@dialog.Close() {
				@button.Button(button.Props{
					Variant: button.VariantOutline,
					Type:    button.TypeButton,
				}) {
					Cancel
				}
			}
			@button.Button(button.Props{Type: button.TypeSubmit}) {
				@icon.MessageSquarePlus(icon.Props{Class: "size-4"})
				Comment
			}
		}
	</form>
}

templ KanbanDialogErrorContent(message string) {
	@dialog.Header() {
		@dialog.Title() {
			Kanban action unavailable
		}
	}
	@kanbanDialogError(message)
	@dialog.Footer() {
		@dialog.Close() {
			@button.Button(button.Props{Variant: button.VariantOutline}) {
				Close
			}
		}
	}
}

templ kanbanDialogError(message string) {
	if message != "" {
		<div role="alert" class="rounded-md border border-danger bg-danger-soft px-3 py-2 text-sm text-danger">{ message }</div>
	}
}

templ kanbanScript() {
	<script>
		(function() {
			if (window.__detentKanbanDragHandlersRegistered) {
				return;
			}
			window.__detentKanbanDragHandlersRegistered = true;

			let draggedIssueID = "";
			let dropped = false;
			let blockedDrop = false;

			function feedback(message) {
				const target = document.getElementById("kanban-feedback");
				if (target) {
					target.textContent = message;
				}
			}

			function draggedCard() {
				if (!draggedIssueID || !window.CSS || typeof CSS.escape !== "function") {
					return null;
				}
				return document.querySelector("[data-kanban-card][data-kanban-issue-id='" + CSS.escape(draggedIssueID) + "']");
			}

			function markedDraggedCard() {
				return document.querySelector("[data-kanban-card][data-kanban-dragging='true']");
			}

			function activeDragIssueID(event) {
				if (draggedIssueID) {
					return draggedIssueID;
				}
				const markedCard = markedDraggedCard();
				if (markedCard instanceof HTMLElement && markedCard.dataset.kanbanIssueId) {
					return markedCard.dataset.kanbanIssueId;
				}
				if (!event.dataTransfer || typeof event.dataTransfer.getData !== "function") {
					return "";
				}
				return event.dataTransfer.getData("text/plain") || "";
			}

			function allowedTargetKeys(card) {
				if (!(card instanceof HTMLElement)) {
					return [];
				}
				return (card.dataset.kanbanAllowedTargets || "").split(/\s+/).filter(Boolean);
			}

			function laneAllowed(card, lane) {
				if (!(lane instanceof HTMLElement)) {
					return false;
				}
				const key = lane.dataset.kanbanDropKey || "";
				return key !== "" && allowedTargetKeys(card).includes(key);
			}

			function dragImageOffset(position, start, size) {
				if (position <= 0 || size <= 0) {
					return Math.max(0, size / 2);
				}
				return Math.min(Math.max(position - start, 0), size);
			}

			function setCardDragImage(event, card) {
				if (!event.dataTransfer) {
					return;
				}
				const rect = card.getBoundingClientRect();
				const offsetX = dragImageOffset(event.clientX, rect.left, rect.width);
				const offsetY = dragImageOffset(event.clientY, rect.top, rect.height);
				event.dataTransfer.setDragImage(card, Math.round(offsetX), Math.round(offsetY));
			}

			function setDropTargetState(card) {
				document.querySelectorAll("[data-kanban-drop-state]").forEach(function(lane) {
					if (!(lane instanceof HTMLElement)) {
						return;
					}
					if (lane.dataset.kanbanDropWasVisible === undefined) {
						lane.dataset.kanbanDropWasVisible = lane.dataset.projectKanbanLaneVisible || "";
					}
					const allowed = laneAllowed(card, lane);
					lane.dataset.projectKanbanLaneVisible = "true";
					lane.dataset.kanbanDropAllowed = allowed ? "true" : "false";
					lane.setAttribute("aria-disabled", allowed ? "false" : "true");
				});
			}

			function clearDropTargetState() {
				document.querySelectorAll("[data-kanban-drop-state]").forEach(function(lane) {
					if (!(lane instanceof HTMLElement)) {
						return;
					}
					if (lane.dataset.kanbanDropWasVisible !== undefined) {
						if (lane.dataset.kanbanDropWasVisible === "") {
							delete lane.dataset.projectKanbanLaneVisible;
						} else {
							lane.dataset.projectKanbanLaneVisible = lane.dataset.kanbanDropWasVisible;
						}
						delete lane.dataset.kanbanDropWasVisible;
					}
					delete lane.dataset.kanbanDropAllowed;
					lane.removeAttribute("aria-disabled");
				});
				document.querySelectorAll("[data-kanban-card][data-kanban-dragging='true']").forEach(function(card) {
					if (card instanceof HTMLElement) {
						delete card.dataset.kanbanDragging;
					}
				});
			}

			function closeActionDialog() {
				if (window.tui && window.tui.dialog) {
					window.tui.dialog.close("kanban-action-dialog");
				}
				const content = document.getElementById("kanban-dialog-content");
				if (content) {
					content.replaceChildren();
				}
			}

			document.addEventListener("dragstart", function(event) {
				const card = event.target instanceof Element ? event.target.closest("[data-kanban-card]") : null;
				if (!card || card.getAttribute("draggable") !== "true") {
					return;
				}
				draggedIssueID = card.dataset.kanbanIssueId || "";
				dropped = false;
				blockedDrop = false;
				if (!draggedIssueID) {
					event.preventDefault();
					return;
				}
				card.dataset.kanbanDragging = "true";
				if (event.dataTransfer) {
					event.dataTransfer.effectAllowed = "move";
					event.dataTransfer.setData("text/plain", draggedIssueID);
				}
				setCardDragImage(event, card);
				setDropTargetState(card);
				feedback("Moving " + (card.dataset.kanbanCurrentState || "card") + ".");
			});

			document.addEventListener("dragover", function(event) {
				const issueID = activeDragIssueID(event);
				if (!issueID) {
					return;
				}
				draggedIssueID = issueID;
				const lane = event.target instanceof Element ? event.target.closest("[data-kanban-drop-state]") : null;
				if (!lane) {
					return;
				}
				const allowed = laneAllowed(draggedCard(), lane);
				if (event.dataTransfer) {
					event.dataTransfer.dropEffect = allowed ? "move" : "none";
				}
				if (allowed) {
					event.preventDefault();
					blockedDrop = false;
					return;
				}
				blockedDrop = true;
				feedback("Move blocked by transition policy.");
			});

			document.addEventListener("drop", function(event) {
				const issueID = activeDragIssueID(event);
				if (!issueID) {
					return;
				}
				draggedIssueID = issueID;
				const lane = event.target instanceof Element ? event.target.closest("[data-kanban-drop-state]") : null;
				if (!lane) {
					return;
				}
				event.preventDefault();
				const card = draggedCard();
				if (!laneAllowed(card, lane)) {
					feedback("Move blocked by transition policy.");
					dropped = true;
					return;
				}
				const form = card ? card.querySelector("[data-kanban-drag-move-form]") : null;
				const targetState = form ? form.querySelector("[data-kanban-drag-target-state]") : null;
				if (!(form instanceof HTMLFormElement) || !(targetState instanceof HTMLInputElement)) {
					feedback("Move cancelled.");
					return;
				}
				targetState.value = lane.dataset.kanbanDropState || "";
				dropped = true;
				form.requestSubmit();
			});

			document.addEventListener("dragend", function() {
				if (draggedIssueID && !dropped && !blockedDrop) {
					feedback("Move cancelled.");
				}
				draggedIssueID = "";
				dropped = false;
				blockedDrop = false;
				clearDropTargetState();
			});

			document.body.addEventListener("kanbanActionSucceeded", closeActionDialog);
			document.body.addEventListener("htmx:responseError", function(event) {
				const form = event.detail && event.detail.elt;
				if (!(form instanceof HTMLFormElement) || !form.matches("[data-kanban-drag-move-form]")) {
					return;
				}
				const response = event.detail.xhr ? event.detail.xhr.responseText : "";
				const target = document.getElementById("kanban-feedback");
				if (target && response) {
					target.outerHTML = response;
					return;
				}
				feedback("Move failed.");
			});
		})();
	</script>
}

templ runningIssueMobileCard(row telemetry.Running, rowIndex int, generatedAt time.Time) {
	<article class="dashboard-card min-w-0 max-w-full overflow-hidden rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "running-mobile", rowIndex, true)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">State</span>
				<span class="rounded-full bg-accent-soft px-2 py-1 font-medium text-accent">{ issueState(row.Issue, "Running") }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Runtime / turns", helpAgeTurn, "running-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ runningRuntime(row, generatedAt) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Diff", helpDiff, "running-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ formatDiffStat(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Tokens", helpTokens, "running-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ formatTokens(row.Tokens) }</span>
			</div>
		</div>
		<div class="mt-3">
			@runningActivityCell(row, "running-mobile")
		</div>
		<div class="mt-3">
			@sessionCopyButton(row.SessionID)
		</div>
	</article>
}

templ runningActivityCell(row telemetry.Running, prefix string) {
	<details
		class="running-activity group min-w-0 max-w-full overflow-hidden"
		data-preserve-details={ runningActivityID(prefix, row) }
		data-running-activity
	>
		<summary
			class="running-activity-trigger -m-2 flex w-full min-w-0 max-w-full cursor-pointer list-none items-start justify-between gap-2 overflow-hidden rounded-md p-2 text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
			aria-controls={ runningActivityDetailsID(prefix, row) }
			data-running-activity-trigger
		>
			<span class="grid min-w-0 flex-1 basis-0 gap-1 overflow-hidden">
				<span class="line-clamp-2 break-words text-foreground">{ lastCodexUpdate(row) }</span>
				<span class="truncate font-mono text-xs text-muted-foreground">{ lastCodexMeta(row) }</span>
			</span>
			@icon.ChevronDown(icon.Props{Class: "running-activity-chevron mt-0.5 size-3.5 shrink-0 text-muted-foreground"})
		</summary>
		@runningActivityDetails(row, prefix)
	</details>
}

templ runningActivityDetails(row telemetry.Running, prefix string) {
	<div
		id={ runningActivityDetailsID(prefix, row) }
		class="running-activity-panel mt-3 grid min-w-0 max-w-full gap-2 overflow-hidden text-xs"
		data-running-activity-details
	>
		<div class="grid min-w-0 max-w-full gap-1.5 overflow-hidden rounded-md bg-muted/40 p-2">
			<span class="text-xs font-medium uppercase text-muted-foreground">Latest message</span>
			<p class="whitespace-pre-wrap break-words text-sm text-foreground">{ lastCodexUpdate(row) }</p>
			<p class="font-mono text-xs text-muted-foreground">{ lastCodexMeta(row) }</p>
		</div>
		<div class="grid min-w-0 max-w-full gap-2 overflow-hidden">
			<span class="text-xs font-medium uppercase text-muted-foreground">Recent activity</span>
			if len(runningActivityRows(row)) == 0 {
				<p class="rounded-md border border-dashed border-border bg-muted/40 px-3 py-3 text-sm text-muted-foreground">No activity recorded.</p>
			} else {
				<ol class="grid min-w-0 max-w-full gap-2 overflow-hidden">
					for _, activity := range runningActivityRows(row) {
						<li class="min-w-0 max-w-full overflow-hidden rounded-md bg-muted/40 px-3 py-2">
							<div class="flex flex-wrap items-center justify-between gap-2">
								<span class="font-mono text-xs text-muted-foreground">{ activity.At }</span>
								<span class="font-mono text-xs font-medium text-accent">{ activity.Event }</span>
							</div>
							<p class="mt-1 whitespace-pre-wrap break-words text-sm text-foreground">{ activity.Message }</p>
						</li>
					}
				</ol>
			}
		</div>
	</div>
}

templ boardHealthSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Board health">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Board health", helpBoardHealth, "board-health")
				<p class="text-sm text-muted-foreground">Current issue state distribution and completed session history from the latest snapshot.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ boardStateTotalLabel(snapshot) }</span>
		</div>
		<div class="mt-5 grid min-w-0 gap-5 lg:grid-cols-[minmax(0,1fr)_20rem]">
			<div class="min-w-0">
				<div class="flex items-center justify-between gap-3">
					@helpHeading3("Current issue states", helpStateDistribution, "board-health")
					<span class="font-mono text-xs text-muted-foreground">{ boardStateTotalLabel(snapshot) } issues</span>
				</div>
				if len(boardStateRows(snapshot)) == 0 {
					<div class="mt-3">
						@dashboardEmptyState("No board states recorded.", "Project state distribution will appear after the next tracker snapshot.", "bg-accent")
					</div>
				} else {
					<div class="mt-3">
						@TimelineChart(boardDistributionChart(snapshot))
					</div>
					<div class="mt-4 grid gap-2 sm:grid-cols-2">
						for _, row := range boardStateRows(snapshot) {
							<div class="flex min-w-0 items-center justify-between gap-3 rounded-md bg-muted/60 px-3 py-2">
								<span class="inline-flex min-w-0 items-center gap-2">
									<span class={ "h-2 w-2 shrink-0 rounded-full " + row.DotClass }></span>
									<span class="truncate text-sm font-medium text-foreground">{ row.State }</span>
								</span>
								<span class="shrink-0 font-mono text-sm text-muted-foreground">{ row.CountLabel } / { row.Percent }</span>
							</div>
						}
					</div>
				}
			</div>
			<div class="min-w-0">
				<div class="flex items-center justify-between gap-3">
					@helpHeading3("Session completions", helpCumulativeFlow, "board-health")
					<span class="font-mono text-xs text-muted-foreground">{ boardProgressCount(snapshot) } sessions</span>
				</div>
				if len(telemetry.BoardProgressPoints(snapshot)) == 0 {
					<div class="mt-3">
						@dashboardEmptyState("No completed session history yet.", "Session completion progress appears after completed session samples arrive.", "bg-success")
					</div>
				} else {
					<div class="mt-3">
						@LineAreaChart(boardProgressChart(snapshot))
					</div>
				}
			</div>
		</div>
	</section>
}

templ cycleTimeSection(report telemetry.CycleTimeReport) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Cycle time">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Cycle time", helpCycleTime, "cycle-time")
				<p class="text-sm text-muted-foreground">Completed issue durations from local run history.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-success-soft px-2 py-1 text-sm font-medium text-success">{ cycleTimeCountLabel(report) }</span>
		</div>
		if !report.Available && report.DegradedReason != "" {
			<div class="mt-4">
				@dashboardEmptyState("Cycle-time data unavailable.", cycleTimeUnavailableDetail(report), "bg-muted-foreground")
			</div>
		} else if len(report.Buckets) == 0 {
			<div class="mt-4">
				@dashboardEmptyState("No completed issues yet.", "Cycle-time histogram appears after completed issue history is recorded.", "bg-success")
			</div>
		} else {
			<div class="mt-5 grid min-w-0 gap-5 lg:grid-cols-[minmax(0,1fr)_18rem]">
				<div class="min-w-0">
					<div class="flex items-center justify-between gap-3">
						@helpHeading3("Histogram", helpCycleTime, "cycle-time")
						<span class="font-mono text-xs text-muted-foreground">{ cycleTimeCountLabel(report) }</span>
					</div>
					<div class="mt-3">
						@MiniBarChart(cycleTimeHistogramChart(report))
					</div>
				</div>
				<div class="grid min-w-0 content-start gap-3">
					<div class="rounded-md bg-muted/60 px-3 py-2">
						<span class="block text-xs font-medium uppercase text-muted-foreground">Average</span>
						<strong class="font-mono text-lg font-semibold text-foreground">{ cycleTimeAverageLabel(report) }</strong>
					</div>
					<div class="grid gap-2">
						for _, row := range cycleTimeBucketRows(report) {
							<div class="flex min-w-0 items-center justify-between gap-3 rounded-md bg-muted/60 px-3 py-2 text-sm">
								<span class="truncate font-medium text-foreground">{ row.Label }</span>
								<span class="shrink-0 font-mono text-muted-foreground">{ row.Count }</span>
							</div>
						}
					</div>
				</div>
			</div>
		}
	</section>
}

templ workflowMetricsSection(report telemetry.WorkflowMetrics, project telemetry.Project) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Workflow metrics">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Workflow metrics", helpWorkflowMetrics, "workflow-metrics")
				<p class="text-sm text-muted-foreground">Lane timing, observable sub-phases, oldest cards, and the active bottleneck from local runtime telemetry.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ workflowMetricsSummaryLabel(report) }</span>
		</div>
		if !workflowMetricsAvailable(report) {
			<div class="mt-4">
				@dashboardEmptyState("Workflow metrics unavailable.", workflowMetricsUnavailableDetail(report), "bg-muted-foreground")
			</div>
		} else if len(workflowLaneMetricRows(report, project)) == 0 && len(workflowOldestCardRows(report)) == 0 {
			<div class="mt-4">
				@dashboardEmptyState(workflowMetricsEmptyHistoryTitle(report), workflowMetricsEmptyHistoryDetail(report), "bg-accent")
			</div>
		} else {
			<div class="mt-5 grid min-w-0 gap-5 xl:grid-cols-[minmax(0,1fr)_20rem]">
				<div class="grid min-w-0 gap-5">
					<div class="grid min-w-0 gap-5 xl:grid-cols-2">
						<div class="min-w-0">
							<div class="flex items-center justify-between gap-3">
								@helpHeading3("Average lane trend", helpWorkflowMetrics, "workflow-metrics")
								if len(workflowLaneTrendCards(report)) > 0 {
									<span class="font-mono text-xs text-muted-foreground">{ workflowLaneTrendCards(report)[0].Window }</span>
								}
							</div>
							if len(workflowLaneTrendCards(report)) == 0 {
								<div class="mt-3">
									@dashboardEmptyState("No lane trend samples.", "Completed lane exits will populate per-lane average charts here.", "bg-accent")
								</div>
							} else {
								<div class="mt-3 grid gap-2 sm:grid-cols-2">
									for _, card := range workflowLaneTrendCards(report) {
										<div class="grid min-w-0 gap-2 rounded-md bg-muted/60 px-3 py-3">
											<div class="flex min-w-0 items-center justify-between gap-3">
												<span class="truncate text-sm font-medium text-foreground">{ card.Lane }</span>
												<span class="shrink-0 font-mono text-xs text-muted-foreground">{ card.Summary }</span>
											</div>
											if card.HasData {
												@LineAreaChart(card.Chart)
											} else {
												<div class="flex h-24 items-center justify-center rounded-md border border-border bg-card/60 px-3 text-center text-xs text-muted-foreground">No samples</div>
											}
										</div>
									}
								</div>
							}
						</div>
						<div class="min-w-0">
							<div class="flex items-center justify-between gap-3">
								@helpHeading3("Flow efficiency", helpWorkflowMetrics, "workflow-metrics")
								if len(workflowLaneFlowRows(report)) > 0 {
									<span class="font-mono text-xs text-muted-foreground">{ workflowLaneFlowRows(report)[0].Window }</span>
								}
							</div>
							if len(workflowLaneFlowRows(report)) == 0 {
								<div class="mt-3">
									@dashboardEmptyState("No flow-efficiency samples.", "Active and wait splits appear after lane exits overlap observable work phases.", "bg-accent")
								</div>
							} else {
								<div class="mt-3 grid gap-2">
									<div class="flex items-center justify-end gap-3 text-xs text-muted-foreground">
										<span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-accent"></span>Active</span>
										<span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-warning"></span>Wait</span>
									</div>
									for _, row := range workflowLaneFlowRows(report) {
										<div class="grid gap-2 rounded-md bg-muted/60 px-3 py-2 text-sm">
											<div class="flex min-w-0 items-center justify-between gap-3">
												<span class="truncate font-medium text-foreground">{ row.Lane }</span>
												<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 font-mono text-xs font-semibold text-accent">{ row.ActivePercent }</span>
											</div>
											if row.HasData {
												<div class="h-2 overflow-hidden rounded-full bg-border" role="img" aria-label={ row.Lane + " active versus wait time" }>
													<div class="flex h-full">
														<span class="h-full bg-accent" style={ row.ActiveStyle } title={ row.ActiveSegmentTitle } aria-label={ row.ActiveSegmentTitle }></span>
														<span class="h-full bg-warning" style={ row.WaitStyle } title={ row.WaitSegmentTitle } aria-label={ row.WaitSegmentTitle }></span>
													</div>
												</div>
												<div class="grid grid-cols-3 gap-2 font-mono text-xs text-muted-foreground">
													<span>{ row.Active } active</span>
													<span>{ row.Wait } wait</span>
													<span class="text-right">{ row.Total } total</span>
												</div>
											} else {
												<div class="flex h-10 items-center rounded-md border border-border bg-card/60 px-3 text-xs text-muted-foreground">No samples</div>
											}
										</div>
									}
								</div>
							}
						</div>
					</div>
					<div class="min-w-0">
						<div class="flex items-center justify-between gap-3">
							@helpHeading3("Lane trends", helpWorkflowMetrics, "workflow-metrics")
							<span class="font-mono text-xs text-muted-foreground">24h / 7d / 30d</span>
						</div>
						if len(workflowLaneMetricRows(report, project)) == 0 {
							<div class="mt-3">
								@dashboardEmptyState("No lane duration aggregates.", "Completed lane exits will populate p50 and p90 timing here.", "bg-accent")
							</div>
						} else {
							<div class="mt-3 overflow-hidden rounded-md border border-border">
								<div class="max-h-72 overflow-auto" data-preserve-scroll="workflow-lanes">
									<table class="min-w-full text-left text-sm">
										<thead class="sticky top-0 bg-muted text-xs uppercase text-muted-foreground">
											<tr>
												<th class="px-3 py-2 font-medium">Window</th>
												<th class="px-3 py-2 font-medium">Lane</th>
												<th class="px-3 py-2 font-medium">Comparison</th>
												<th class="px-3 py-2 font-medium">Trend</th>
												<th class="px-3 py-2 text-right font-medium">Delta</th>
												<th class="px-3 py-2 text-right font-medium">Count</th>
												<th class="px-3 py-2 text-right font-medium">Avg</th>
												<th class="px-3 py-2 text-right font-medium">P50</th>
												<th class="px-3 py-2 text-right font-medium">P90</th>
												<th class="px-3 py-2 text-right font-medium">P95</th>
												<th class="px-3 py-2 text-right font-medium">Action</th>
											</tr>
										</thead>
										<tbody class="divide-y divide-border">
											for _, row := range workflowLaneMetricRows(report, project) {
												<tr class={ row.RowClass }>
													<td class="px-3 py-2 font-mono text-xs text-muted-foreground">{ row.Window }</td>
													<td class="px-3 py-2 font-medium text-foreground">
														<div class="flex min-w-0 items-center gap-2">
															<span class="truncate">{ row.Lane }</span>
															if row.Bottleneck {
																<span class="shrink-0 rounded-full bg-warning-soft px-2 py-1 text-xs font-semibold text-warning">Bottleneck</span>
															}
														</div>
													</td>
													<td class="px-3 py-2 font-mono text-xs text-muted-foreground">{ row.Comparison }</td>
													<td class="px-3 py-2"><span class={ row.TrendClass }>{ row.Trend }</span></td>
													<td class="px-3 py-2 text-right font-mono text-muted-foreground">{ row.Delta }</td>
													<td class="px-3 py-2 text-right font-mono text-muted-foreground">{ row.Count }</td>
													<td class="px-3 py-2 text-right font-mono text-muted-foreground">{ row.Average }</td>
													<td class="px-3 py-2 text-right font-mono text-foreground">{ row.P50 }</td>
													<td class="px-3 py-2 text-right font-mono text-foreground">{ row.P90 }</td>
													<td class="px-3 py-2 text-right font-mono text-muted-foreground">{ row.P95 }</td>
													<td class="px-3 py-2 text-right">
														if row.Prompt != "" {
															@diagnosticPromptCopyButton(row.Prompt, "Copy prompt", "Copy diagnostic prompt for "+row.Lane)
														}
													</td>
												</tr>
											}
										</tbody>
									</table>
								</div>
							</div>
						}
					</div>
					<div class="min-w-0">
						<div class="flex items-center justify-between gap-3">
							@helpHeading3("Observable sub-phases", helpWorkflowMetrics, "workflow-metrics")
							<span class="font-mono text-xs text-muted-foreground">AI / checks / CI / backoff</span>
						</div>
						if len(workflowSubphaseMetricRows(report)) == 0 {
							<div class="mt-3">
								@dashboardEmptyState("No sub-phase aggregates yet.", "AI sessions, local checks, CI, merge queue, and rate-limit events appear as Detent observes them.", "bg-accent")
							</div>
						} else {
							<div class="mt-3 grid gap-2 sm:grid-cols-2">
								for _, row := range workflowSubphaseMetricRows(report) {
									<div class="grid gap-1 rounded-md bg-muted/60 px-3 py-2 text-sm">
										<div class="flex min-w-0 items-center justify-between gap-3">
											<span class="truncate font-medium text-foreground">{ row.Phase }</span>
											<span class="font-mono text-xs text-muted-foreground">{ row.Window }</span>
										</div>
										<div class="grid grid-cols-3 gap-2 font-mono text-xs text-muted-foreground">
											<span>{ row.Count } runs</span>
											<span>{ row.Total }</span>
											<span>{ row.Mean } avg</span>
										</div>
										<span class="truncate text-xs text-muted-foreground">{ row.Detail }</span>
									</div>
								}
							</div>
						}
					</div>
				</div>
				<aside class="grid min-w-0 content-start gap-4">
					<div class="rounded-md bg-muted/60 px-3 py-3">
						<span class="block text-xs font-medium uppercase text-muted-foreground">Active bottleneck</span>
						<strong class="mt-1 block text-lg font-semibold text-foreground">{ workflowBottleneck(report).Label }</strong>
						<span class="mt-1 block font-mono text-sm text-muted-foreground">{ workflowBottleneck(report).Value }</span>
						<p class="mt-2 text-sm text-muted-foreground">{ workflowBottleneck(report).Detail }</p>
						if workflowBottleneck(report).Count != "" {
							<span class="mt-2 inline-block font-mono text-xs text-muted-foreground">{ workflowBottleneck(report).Count }</span>
						}
						if workflowBottleneckDiagnosticPrompt(project, report) != "" {
							<div class="mt-3">
								@diagnosticPromptCopyButton(workflowBottleneckDiagnosticPrompt(project, report), "Copy diagnostic prompt", "Copy diagnostic prompt")
							</div>
						}
					</div>
					<div class="min-w-0">
						<div class="flex items-center justify-between gap-3">
							@helpHeading3("Oldest cards", helpWorkflowMetrics, "workflow-metrics")
							<span class="font-mono text-xs text-muted-foreground">{ strconv.Itoa(len(workflowOldestCardRows(report))) }</span>
						</div>
						if len(workflowOldestCardRows(report)) == 0 {
							<div class="mt-3">
								@dashboardEmptyState("No live card ages.", "Visible cards will appear after the next tracker snapshot.", "bg-accent")
							</div>
						} else {
							<div class="mt-3 grid gap-2">
								for _, row := range workflowOldestCardRows(report) {
									<div class="grid gap-1 rounded-md bg-muted/60 px-3 py-2 text-sm">
										<div class="flex min-w-0 items-start gap-2">
											<div class="min-w-0 flex-1">
												<span class="block truncate font-medium text-foreground">{ row.Identifier }</span>
												<span class="block truncate text-xs text-muted-foreground">{ row.Title }</span>
											</div>
											if row.URL != "" {
												@issueOpenLink(row.URL, "Open issue "+row.Identifier, true)
											}
										</div>
										<div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-muted-foreground">
											<span>{ row.State }</span>
											if row.ProjectID != "" {
												<span>{ row.ProjectID }</span>
											}
											<span>{ row.Age }</span>
											<span>{ row.Key }</span>
										</div>
									</div>
								}
							</div>
						}
					</div>
				</aside>
			</div>
		}
	</section>
}

templ agentActivityTimeline(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="Agent activity timeline">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Agent activity", helpAgentActivity, "agent-activity")
				<p class="text-sm text-muted-foreground">Live timeline of running and recently completed Codex sessions.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ formatCount(len(agentTimelineRows(snapshot))) }</span>
		</div>
		if len(agentTimelineRows(snapshot)) == 0 {
			if runningCount(snapshot)+completedCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Agent timeline details are unavailable.", "Summary counts are live, but session timing rows have not arrived in this snapshot.", "bg-accent")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No agent activity recorded.", "Running and completed session timelines will appear here.", "bg-accent")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for _, row := range agentTimelineRows(snapshot) {
					@agentActivityMobileCard(row)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="dashboard-agent-scroll max-h-[32rem] overflow-x-auto overflow-y-auto" data-preserve-scroll="agent-activity">
					<div class="min-w-[78rem]">
						<div class="grid grid-cols-[25rem_minmax(0,1fr)_12rem] gap-3 border-b border-border bg-muted/70 px-3 py-3 text-xs font-medium uppercase text-muted-foreground">
							<span>Agent</span>
							<span>Lifespan</span>
							<span class="text-right">State / runtime</span>
						</div>
						for _, row := range agentTimelineRows(snapshot) {
							<div class="agent-activity-table-row grid min-h-14 grid-cols-[25rem_minmax(0,1fr)_12rem] items-center gap-3 border-b border-border px-3 py-3 last:border-b-0" data-agent-identity={ row.Identity.Label }>
								<div class="flex min-w-0 items-start gap-2">
									<div class="min-w-0 flex-1">
										@issueIdentityLine(row.Identity, false)
										<span class="line-clamp-2 break-words text-sm text-muted-foreground">{ row.Title }</span>
									</div>
									@agentTimelineActions(row)
								</div>
								<div class="grid gap-1">
									<div class="flex items-center justify-between gap-3 font-mono text-xs text-muted-foreground">
										<span>{ row.StartedAt }</span>
										<span>{ row.EndedAt }</span>
									</div>
									<div class="relative h-9 overflow-hidden rounded-md bg-muted" role="group" aria-label={ row.Identifier + " lifespan" }>
										for _, segment := range row.Segments {
											<span class={ "absolute bottom-1 top-1 min-w-1.5 rounded " + segment.Class } style={ segment.Style } title={ segment.Title } aria-label={ segment.Title }>
												<span class="sr-only">{ segment.Title }</span>
											</span>
										}
									</div>
								</div>
								<div class="grid justify-items-end gap-1">
									<span class="rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ row.State }</span>
									<span class="font-mono text-xs text-muted-foreground">{ row.Duration }</span>
								</div>
							</div>
						}
					</div>
				</div>
			</div>
		}
	</section>
}

templ agentActivityMobileCard(row agentTimelineRow) {
	<article class="dashboard-card min-w-0 max-w-full overflow-hidden rounded-md border border-border bg-card p-3 shadow-sm" data-agent-identity={ row.Identity.Label }>
		<div class="flex items-start justify-between gap-3">
			<div class="min-w-0 flex-1">
				@issueIdentityLine(row.Identity, false)
				<span class="line-clamp-2 break-words text-sm text-muted-foreground">{ row.Title }</span>
			</div>
			<div class="flex shrink-0 items-start gap-1">
				@agentTimelineActions(row)
				<span class="rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ row.State }</span>
			</div>
		</div>
		<div class="mt-3 grid gap-1">
			<div class="flex items-center justify-between gap-3 font-mono text-xs text-muted-foreground">
				<span>{ row.StartedAt }</span>
				<span>{ row.EndedAt }</span>
			</div>
			<div class="relative h-9 overflow-hidden rounded-md bg-muted" role="group" aria-label={ row.Identifier + " lifespan" }>
				for _, segment := range row.Segments {
					<span class={ "absolute bottom-1 top-1 min-w-1.5 rounded " + segment.Class } style={ segment.Style } title={ segment.Title } aria-label={ segment.Title }>
						<span class="sr-only">{ segment.Title }</span>
					</span>
				}
			</div>
		</div>
		<div class="mt-3 font-mono text-xs text-muted-foreground">{ row.Duration }</div>
	</article>
}

templ agentTimelineActions(row agentTimelineRow) {
	if row.IssueURL != "" || row.PullRequestURL != "" {
		<div class="flex shrink-0 items-center gap-1">
			if row.IssueURL != "" {
				@issueOpenLink(row.IssueURL, "Open issue "+row.Identifier, true)
			}
			if row.PullRequestURL != "" {
				@pullRequestOpenLink(row.PullRequestURL, pullRequestOpenLabelForNumber(row.PullRequestNumber), true)
			}
		</div>
	}
}

templ retryQueueSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Retry queue", helpBackoffQueue, "retry-queue")
				<p class="text-sm text-muted-foreground">Issues waiting for the next retry window.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-warning-soft px-2 py-1 text-sm font-medium text-warning">{ formatCount(queueCount(snapshot)) }</span>
		</div>
		if len(snapshot.Queue) == 0 {
			if queueCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Retry queue details are unavailable.", "The queue count is live, but retry rows have not arrived in this snapshot.", "bg-warning")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No issues are currently backing off.", "Retrying work will appear here with its next due time.", "bg-warning")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range snapshot.Queue {
					@retryQueueMobileCard(row, i)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="retry-queue">
					<table class="dashboard-table w-full min-w-[54rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[7rem] px-3 py-3 font-medium">Attempt</th>
								<th class="w-[13rem] px-3 py-3 font-medium">Due time</th>
								<th class="px-3 py-3 font-medium">
									@helpInlineLabel("Error", helpEvent, "retry-table", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range snapshot.Queue {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top">
										@issueCell(row.Issue, "retry", i, true)
									</td>
									<td class="px-3 py-4 align-top font-mono text-foreground">{ formatInt(int64(row.Attempt)) }</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ queuedDueLabel(row) }</td>
									<td class="px-3 py-4 align-top text-muted-foreground">
										<span class="line-clamp-3">{ rowError(row.Error) }</span>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ schedulerRuntimeSection(snapshot telemetry.Snapshot) {
	<section id="scheduler-runtime" class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Scheduler runtime", helpWorkflowMetrics, "scheduler-runtime")
				<p class="text-sm text-muted-foreground">Durable attempts, leases, and recent scheduling decisions.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-accent-soft px-2 py-1 text-sm font-medium text-accent">{ schedulerRuntimeCount(snapshot) }</span>
		</div>
		if len(schedulerWorkAttemptRows(snapshot)) == 0 && len(schedulerDecisionRows(snapshot)) == 0 {
			<div class="mt-4">
				@dashboardEmptyState("No scheduler runtime records yet.", "Attempts and candidate decisions appear after the scheduler reconciles work.", "bg-accent")
			</div>
		} else {
			<div class="mt-4 grid gap-4 xl:grid-cols-2">
				<div class="min-w-0">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="text-sm font-medium text-foreground">Work attempts</h3>
						<span class="font-mono text-xs text-muted-foreground">{ formatCount(len(schedulerWorkAttemptRows(snapshot))) }</span>
					</div>
					if len(schedulerWorkAttemptRows(snapshot)) == 0 {
						@dashboardEmptyState("No work attempts recorded.", "Active and recovered leases will appear here.", "bg-accent")
					} else {
						<div class="grid gap-2">
							for _, row := range schedulerWorkAttemptRows(snapshot) {
								<article class="rounded-md border border-border bg-muted/30 p-3">
									<div class="flex min-w-0 items-start justify-between gap-3">
										<div class="min-w-0">
											<div class="truncate font-mono text-sm font-medium text-foreground">{ workAttemptIssueLabel(row) }</div>
											<div class="mt-1 truncate text-xs text-muted-foreground">{ workAttemptWorkerLabel(row) }</div>
										</div>
										<span class={ workAttemptStatusClass(row) }>{ workAttemptStatusLabel(row) }</span>
									</div>
									<div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Phase</span>
											<span class="block truncate font-mono text-foreground">{ workAttemptPhaseLabel(row) }</span>
										</div>
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Wait</span>
											<span class="block truncate font-mono text-foreground">{ workAttemptWaitLabel(row) }</span>
										</div>
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Lease</span>
											<span class="block truncate font-mono text-foreground">{ workAttemptLeaseLabel(row, snapshot.GeneratedAt) }</span>
										</div>
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Next</span>
											<span class="block truncate font-mono text-foreground">{ workAttemptNextActionLabel(row) }</span>
										</div>
									</div>
								</article>
							}
						</div>
					}
				</div>
				<div class="min-w-0">
					<div class="mb-2 flex items-center justify-between gap-3">
						<h3 class="text-sm font-medium text-foreground">Candidate decisions</h3>
						<span class="font-mono text-xs text-muted-foreground">{ formatCount(len(schedulerDecisionRows(snapshot))) }</span>
					</div>
					if len(schedulerDecisionRows(snapshot)) == 0 {
						@dashboardEmptyState("No candidate decisions recorded.", "Selected and skipped candidates will appear here.", "bg-warning")
					} else {
						<div class="grid gap-2">
							for _, row := range schedulerDecisionRows(snapshot) {
								<article class="rounded-md border border-border bg-muted/30 p-3">
									<div class="flex min-w-0 items-start justify-between gap-3">
										<div class="min-w-0">
											<div class="truncate font-mono text-sm font-medium text-foreground">{ schedulerDecisionIssueLabel(row) }</div>
											<div class="mt-1 truncate text-xs text-muted-foreground">{ schedulerDecisionLaneLabel(row) }</div>
										</div>
										<span class={ schedulerDecisionStatusClass(row) }>{ schedulerDecisionStatusLabel(row) }</span>
									</div>
									<div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Reason</span>
											<span class="block truncate font-mono text-foreground">{ schedulerDecisionReasonLabel(row) }</span>
										</div>
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Wait</span>
											<span class="block truncate font-mono text-foreground">{ schedulerDecisionWaitLabel(row) }</span>
										</div>
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">Queue</span>
											<span class="block truncate font-mono text-foreground">{ schedulerDecisionQueueLabel(row) }</span>
										</div>
										<div class="min-w-0">
											<span class="block text-xs font-medium uppercase text-muted-foreground">At</span>
											<span class="block truncate font-mono text-foreground">{ schedulerDecisionTimeLabel(row) }</span>
										</div>
									</div>
								</article>
							}
						</div>
					}
				</div>
			</div>
		}
	</section>
}

templ retryQueueMobileCard(row telemetry.Queued, rowIndex int) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "retry-mobile", rowIndex, true)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Attempt</span>
				<span class="font-mono text-foreground">{ formatInt(int64(row.Attempt)) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Due time</span>
				<span class="font-mono text-foreground">{ queuedDueLabel(row) }</span>
			</div>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 p-3 text-sm text-muted-foreground">
			<span class="line-clamp-4">{ rowError(row.Error) }</span>
		</div>
	</article>
}

templ blockedSessionsSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Blocked sessions", helpBlocked, "blocked-sessions")
				<p class="text-sm text-muted-foreground">Issues paused because Codex requested operator input or approval.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-danger-soft px-2 py-1 text-sm font-medium text-danger">{ formatCount(blockedCount(snapshot)) }</span>
		</div>
		if len(snapshot.Blocked) == 0 {
			if blockedCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Blocked session details are unavailable.", "The blocked count is live, but detailed rows have not arrived in this snapshot.", "bg-danger")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No blocked sessions.", "Operator requests and approval waits will appear here.", "bg-danger")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range snapshot.Blocked {
					@blockedSessionMobileCard(row, i)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="blocked-sessions">
					<table class="dashboard-table w-full min-w-[68rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[9rem] px-3 py-3 font-medium">State</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Session", helpSession, "blocked-table", "")
								</th>
								<th class="w-[13rem] px-3 py-3 font-medium">Blocked time</th>
								<th class="px-3 py-3 font-medium">
									@helpInlineLabel("Last update", helpEvent, "blocked-table", "")
								</th>
								<th class="w-[14rem] px-3 py-3 font-medium">
									@helpInlineLabel("Error", helpEvent, "blocked-table-error", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range snapshot.Blocked {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top">
										@issueCell(row.Issue, "blocked", i, true)
									</td>
									<td class="px-3 py-4 align-top">
										<span class="inline-flex rounded-full bg-danger-soft px-2 py-1 font-medium text-danger">{ issueState(row.Issue, "Blocked") }</span>
									</td>
									<td class="px-3 py-4 align-top">
										@sessionCopyButton(row.SessionID)
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ blockedAtLabel(row) }</td>
									<td class="px-3 py-4 align-top">
										<div class="grid gap-1">
											<span class="line-clamp-2 text-foreground">{ blockedLastUpdate(row) }</span>
											<span class="font-mono text-xs text-muted-foreground">{ blockedLastUpdateMeta(row) }</span>
										</div>
									</td>
									<td class="px-3 py-4 align-top text-muted-foreground">
										<span class="line-clamp-3">{ rowError(row.Error) }</span>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ blockedSessionMobileCard(row telemetry.Blocked, rowIndex int) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "blocked-mobile", rowIndex, true)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">State</span>
				<span class="rounded-full bg-danger-soft px-2 py-1 font-medium text-danger">{ issueState(row.Issue, "Blocked") }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Blocked time</span>
				<span class="font-mono text-foreground">{ blockedAtLabel(row) }</span>
			</div>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 p-3">
			<span class="line-clamp-3 text-sm text-foreground">{ blockedLastUpdate(row) }</span>
			<span class="mt-1 block font-mono text-xs text-muted-foreground">{ blockedLastUpdateMeta(row) }</span>
		</div>
		<div class="mt-3 rounded-md bg-muted/60 p-3 text-sm text-muted-foreground">
			<span class="line-clamp-4">{ rowError(row.Error) }</span>
		</div>
		<div class="mt-3">
			@sessionCopyButton(row.SessionID)
		</div>
	</article>
}

templ recentSessionsSection(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				@helpHeading2("Recent sessions", helpRecentSessions, "recent-sessions")
				<p class="text-sm text-muted-foreground">Last completed Codex sessions across Detent runs.</p>
			</div>
			<span class="inline-flex min-h-9 min-w-9 shrink-0 items-center justify-center rounded-full bg-success-soft px-2 py-1 text-sm font-medium text-success">{ formatCount(completedCount(snapshot)) }</span>
		</div>
		if len(snapshot.Completed) == 0 {
			if completedCount(snapshot) > 0 {
				<div class="mt-4">
					@dashboardEmptyState("Completed session details are unavailable.", "The completed count is live, but session rows have not arrived in this snapshot.", "bg-success")
				</div>
			} else {
				<div class="mt-4">
					@dashboardEmptyState("No completed sessions recorded.", "Finished Codex sessions will appear here after work completes.", "bg-success")
				</div>
			}
		} else {
			<div class="mt-4 grid gap-3 sm:hidden">
				for i, row := range snapshot.Completed {
					@recentSessionMobileCard(row, i)
				}
			</div>
			<div class="mt-4 hidden overflow-hidden rounded-md border border-border sm:block">
				<div class="overflow-x-auto" data-preserve-scroll="recent-sessions">
					<table class="dashboard-table w-full min-w-[74rem] table-fixed border-collapse text-sm">
						<thead class="bg-muted/70">
							<tr class="border-b border-border text-left text-xs font-medium uppercase text-muted-foreground">
								<th class="w-[24rem] px-3 py-3 font-medium">Issue</th>
								<th class="w-[13rem] px-3 py-3 font-medium">Completed</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Runtime / turns", helpAgeTurn, "recent-table", "")
								</th>
								<th class="w-[10rem] px-3 py-3 font-medium">
									@helpInlineLabel("Tokens", helpTokens, "recent-table", "")
								</th>
								<th class="w-[10rem] px-3 py-3 font-medium">Final state</th>
								<th class="w-[11rem] px-3 py-3 font-medium">Model</th>
								<th class="w-[11rem] px-3 py-3 font-medium">
									@helpInlineLabel("Session", helpSession, "recent-table", "")
								</th>
							</tr>
						</thead>
						<tbody>
							for i, row := range snapshot.Completed {
								<tr class="border-b border-border transition-colors last:border-b-0 hover:bg-muted/50">
									<td class="px-3 py-4 align-top">
										@issueCell(row.Issue, "recent", i, false)
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ completedAtLabel(row) }</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ completedRuntime(row) }</td>
									<td class="px-3 py-4 align-top">
										<div class="grid gap-1 font-mono">
											<span class="font-medium text-foreground">{ formatTokens(row.Tokens) }</span>
											<span class="text-xs text-muted-foreground">{ formatTokenBreakdown(row.Tokens) }</span>
										</div>
									</td>
									<td class="px-3 py-4 align-top">
										<span class="inline-flex rounded-full bg-success-soft px-2 py-1 font-medium text-success">{ completedState(row) }</span>
									</td>
									<td class="px-3 py-4 align-top font-mono text-muted-foreground">{ completedModel(row) }</td>
									<td class="px-3 py-4 align-top">
										@sessionCopyButton(row.SessionID)
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		}
	</section>
}

templ recentSessionMobileCard(row telemetry.Completed, rowIndex int) {
	<article class="dashboard-card rounded-md border border-border bg-card p-3 shadow-sm">
		@issueCell(row.Issue, "recent-mobile", rowIndex, false)
		<div class="mt-3 grid gap-2 text-sm">
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Completed</span>
				<span class="font-mono text-foreground">{ completedAtLabel(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Runtime / turns", helpAgeTurn, "recent-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ completedRuntime(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				@helpInlineLabel("Tokens", helpTokens, "recent-mobile", "text-muted-foreground")
				<span class="font-mono text-foreground">{ formatTokens(row.Tokens) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Final state</span>
				<span class="rounded-full bg-success-soft px-2 py-1 font-medium text-success">{ completedState(row) }</span>
			</div>
			<div class="flex min-h-10 items-center justify-between gap-3">
				<span class="text-muted-foreground">Model</span>
				<span class="font-mono text-foreground">{ completedModel(row) }</span>
			</div>
		</div>
		<div class="mt-3">
			@sessionCopyButton(row.SessionID)
		</div>
	</article>
}

templ issueIdentityLine(identity issueIdentityView, accent bool) {
	<span class="flex min-w-0 max-w-full flex-wrap items-center gap-1.5 font-mono text-xs leading-5" data-primary-identity={ identity.Label }>
		if identity.Repository != "" {
			<span class={ "min-w-0 break-all font-semibold " + identityRepositoryClass(accent) } title={ identity.Repository } data-identity-repository>{ identity.Repository }</span>
		}
		if identity.IssueNumber != "" {
			<span class={ "shrink-0 rounded-sm border px-1.5 py-0.5 font-semibold " + identityIssueBadgeClass(accent) } data-identity-issue>{ identity.IssueNumber }</span>
		}
		if identity.PullRequestLabel != "" {
			<span class={ "shrink-0 rounded-sm border px-1.5 py-0.5 font-semibold " + identityPullRequestBadgeClass(accent) } data-identity-pr>{ identity.PullRequestLabel }</span>
		}
	</span>
}

templ issueCell(issue telemetry.Issue, prefix string, rowIndex int, jsonDetails bool) {
	<div class="grid min-w-0 max-w-full gap-2 overflow-hidden" data-popover data-issue-identifier={ issueIdentifier(issue) } data-issue-identity={ issueIdentity(issue).Label }>
		<div class="flex min-w-0 items-start gap-2">
			<button
				type="button"
				class="min-w-0 flex-1 basis-0 overflow-hidden text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
				aria-describedby={ issuePopoverID(prefix, rowIndex) }
				aria-expanded="false"
				data-popover-trigger
			>
				@issueIdentityLine(issueIdentity(issue), false)
				<span class="line-clamp-2 break-words text-muted-foreground">{ issueTitle(issue) }</span>
			</button>
			<div class="flex shrink-0 flex-wrap items-start justify-end gap-1.5">
				if issueProjectLabel(issue) != "" {
					<span class="inline-flex max-w-[9rem] overflow-hidden rounded-full bg-muted px-2 py-1 font-mono text-xs text-muted-foreground" title={ "Project " + issueProjectLabel(issue) }>
						<span class="min-w-0 truncate">{ issueProjectLabel(issue) }</span>
					</span>
				}
				if issueURL(issue) != "" {
					@issueCopyButton(issueURL(issue))
					@issueOpenLink(issueURL(issue), issueOpenLabel(issue), false)
				}
				if pullRequestURL(issue) != "" {
					@pullRequestOpenLink(pullRequestURL(issue), pullRequestOpenLabel(issue), false)
				}
			</div>
		</div>
		if issueDescriptionPreview(issue) != "" {
			<p class="line-clamp-2 text-xs text-muted-foreground">{ issueDescriptionPreview(issue) }</p>
		}
		if issueClaimSummary(issue) != "" {
			<p class="line-clamp-2 font-mono text-xs text-muted-foreground">{ issueClaimSummary(issue) }</p>
		}
		if jsonDetails && issueDetailURL(issue) != "" {
			<a class="w-fit text-xs font-medium text-accent underline-offset-4 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent" href={ issueDetailURL(issue) }>JSON details</a>
		}
		<div
			id={ issuePopoverID(prefix, rowIndex) }
			class="popover-panel issue-popover-panel max-w-sm text-foreground"
			role="tooltip"
			aria-hidden="true"
			data-popover-panel
			data-popover-width="320"
		>
			<p class="font-medium text-foreground">{ issueTitle(issue) }</p>
			if issueDescriptionPreview(issue) != "" {
				<p class="mt-1 text-muted-foreground">{ issueDescriptionPreview(issue) }</p>
			}
		</div>
	</div>
}

templ issueOpenLink(url string, label string, compact bool) {
	<a class={ issueActionClass(compact) } href={ url } target="_blank" rel="noopener noreferrer" title={ label } aria-label={ label }>
		@icon.ExternalLink(icon.Props{Class: issueActionIconClass(compact)})
		<span class="sr-only">{ label }</span>
	</a>
}

templ pullRequestOpenLink(url string, label string, compact bool) {
	<a class={ issueActionClass(compact) } href={ url } target="_blank" rel="noopener noreferrer" title={ label } aria-label={ label }>
		@icon.GitPullRequest(icon.Props{Class: issueActionIconClass(compact)})
		<span class="sr-only">{ label }</span>
	</a>
}

templ issueCopyButton(value string) {
	<button
		type="button"
		class="issue-copy issue-external inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-border bg-card text-muted-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
		data-label="Copy issue URL"
		data-copy={ value }
		title={ "Copy " + value }
		onclick="navigator.clipboard.writeText(this.dataset.copy); const label = this.querySelector('[data-copy-label]'); label.textContent = 'Copied'; clearTimeout(this._copyTimer); this._copyTimer = setTimeout(() => { label.textContent = this.dataset.label }, 1200);"
	>
		@icon.Copy(icon.Props{Class: "size-4"})
		<span class="sr-only" data-copy-label>Copy issue URL</span>
	</button>
}

templ diagnosticPromptCopyButton(value string, label string, title string) {
	<button
		type="button"
		class="inline-flex min-h-9 max-w-full items-center gap-2 rounded-md border border-border bg-card px-2.5 py-1.5 text-xs font-medium text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
		data-label={ label }
		data-copy={ value }
		title={ title }
		aria-label={ title }
		onclick="const done = () => { const label = this.querySelector('[data-copy-label]'); label.textContent = 'Copied'; clearTimeout(this._copyTimer); this._copyTimer = setTimeout(() => { label.textContent = this.dataset.label }, 1200); }; if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(this.dataset.copy).then(done, done); } else { done(); }"
	>
		@icon.ClipboardCopy(icon.Props{Class: "size-3.5 shrink-0"})
		<span class="truncate" data-copy-label>{ label }</span>
	</button>
}

templ sessionCopyButton(sessionID string) {
	if sessionID == "" {
		<span class="font-mono text-muted-foreground">n/a</span>
	} else {
		<button
			type="button"
			class="inline-flex min-h-10 max-w-full items-center gap-2 rounded-md border border-border bg-muted px-3 py-2 font-mono text-xs text-foreground hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
			data-label={ sessionLabel(sessionID) }
			data-copy={ sessionID }
			title={ "Copy " + sessionID }
			onclick="navigator.clipboard.writeText(this.dataset.copy); const label = this.querySelector('[data-copy-label]'); label.textContent = 'Copied'; clearTimeout(this._copyTimer); this._copyTimer = setTimeout(() => { label.textContent = this.dataset.label }, 1200);"
		>
			<span class="truncate" data-copy-label>{ sessionLabel(sessionID) }</span>
			<svg class="shrink-0" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
				<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
			</svg>
		</button>
	}
}

templ budgetCard(snapshot telemetry.Snapshot) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Budget", helpBudget, "budget-card")
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">{ budgetStatus(snapshot.Budget) }</span>
		</div>
		<div class="mt-5 grid gap-4 text-sm">
			<div class="grid gap-2">
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Spend today", helpCurrentSpend, "budget-current-spend", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ budgetSpendTodayLabel(snapshot.Budget) }</strong>
				</div>
				<div class="h-2 overflow-hidden rounded-full bg-muted" aria-label="Daily budget usage">
					<div class="h-full rounded-full bg-accent transition-all" style={ budgetDailyUsageStyle(snapshot.Budget) }></div>
				</div>
			</div>
			if !budgetBurnDownView(snapshot).Available {
				@dashboardEmptyState(budgetBurnDownView(snapshot).EmptyTitle, budgetBurnDownView(snapshot).EmptyDetail, "bg-accent")
			} else {
				<div class="grid gap-3">
					<div class="flex items-center justify-between gap-4">
						@helpInlineLabel("Cost burn-down", helpProjectedSpend, "budget-burn-down", "font-medium text-muted-foreground")
						<span class="font-mono text-xs text-muted-foreground">{ budgetBurnDownView(snapshot).PeriodLabel }</span>
					</div>
					@BudgetProjectionChart(budgetBurnDownView(snapshot).Chart)
					<div class="grid grid-cols-3 gap-2 font-mono text-xs text-muted-foreground">
						<span>Spend { budgetBurnDownView(snapshot).CurrentLabel }</span>
						<span>Cap { budgetBurnDownView(snapshot).CapLabel }</span>
						<span>Projected { budgetBurnDownView(snapshot).ProjectionLabel }</span>
					</div>
				</div>
			}
			if len(budgetHistoryBars(snapshot.Budget)) == 0 {
				@dashboardEmptyState("No budget history yet.", "Spend bars will appear after daily budget samples are recorded.", "bg-accent")
			} else {
				<div class="grid gap-2">
					<div class="flex items-center justify-between gap-4">
						@helpInlineLabel("Budget history", helpBudgetHistory, "budget-history", "font-medium text-muted-foreground")
						<span class="font-mono text-xs text-muted-foreground">{ budgetHistoryCount(snapshot.Budget) }</span>
					</div>
					<div class="grid h-12 grid-cols-7 items-end gap-1 rounded-md border border-border bg-muted px-2 py-2" aria-label="Spend over the last seven days">
						for _, bar := range budgetHistoryBars(snapshot.Budget) {
							<span class="block min-h-1 rounded-t bg-accent opacity-80" style={ bar.Style } title={ bar.Title }>
								<span class="sr-only">{ bar.Title }</span>
							</span>
						}
					</div>
				</div>
			}
			<div class="grid gap-3 border-t border-border pt-3">
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Projected", helpProjectedSpend, "budget-projected", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ budgetBurnDownView(snapshot).ProjectionLabel }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Daily cap", helpDailyCap, "budget-daily-cap", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ optionalUSD(snapshot.Budget.PerDayMaxUSD) }</strong>
				</div>
				<div class="flex items-center justify-between gap-4">
					@helpInlineLabel("Issue cap", helpIssueCap, "budget-issue-cap", "text-muted-foreground")
					<strong class="font-mono font-medium text-foreground">{ optionalUSD(snapshot.Budget.PerIssueMaxUSD) }</strong>
				</div>
			</div>
		</div>
	</section>
}

templ rateLimitsCard(limits *RateLimits) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Rate limits", helpRateLimits, "rate-limits-card")
			<span class="shrink-0 rounded-full bg-accent-soft px-2 py-1 text-xs font-medium text-accent">{ rateLimitName(limits) }</span>
		</div>
		if len(rateLimitRows(limits)) == 0 {
			<div class="mt-4">
				@dashboardEmptyState("No rate-limit snapshot.", "Limits will appear after Codex or the tracker reports quota data.", "bg-accent")
			</div>
		} else {
			<div class="mt-5 grid gap-4">
				for _, row := range rateLimitRows(limits) {
					<div class="grid gap-2">
						<div class="flex items-center justify-between gap-3">
							@helpInlineLabel(row.Name, rateLimitHelpTerm(row.Name), "rate-limit-"+helpIDPart(row.Name), "font-medium text-foreground")
							<span class="font-mono text-sm text-muted-foreground">{ row.Reset }</span>
						</div>
						<div class="h-2 overflow-hidden rounded-full bg-muted">
							<div class="h-full rounded-full bg-accent transition-all" style={ percentStyle(row.UsedPercent) }></div>
						</div>
						<div class="grid grid-cols-3 gap-2 font-mono text-xs text-muted-foreground">
							<span>{ row.Remaining }</span>
							<span>{ row.Used }</span>
							<span>{ row.Limit }</span>
						</div>
					</div>
				}
			</div>
		}
	</section>
}

templ graphQLBudgetCard(data DashboardData) {
	if hasGraphQLBudget(data.Snapshot.RateLimits) {
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="GraphQL budget">
			<div class="flex items-start justify-between gap-3">
				@helpHeading2("GraphQL budget", helpRateLimits, "graphql-budget-card")
				<span class="shrink-0 rounded-full bg-warning-soft px-2 py-1 font-mono text-xs font-medium text-warning">{ graphQLBudgetCycleCost(data.Snapshot.RateLimits) }</span>
			</div>
			<div class="mt-5 grid gap-3">
				<div class="grid grid-cols-2 gap-3 text-sm">
					<div class="grid gap-1">
						<span class="text-muted-foreground">Remaining</span>
						<strong class="break-all font-mono text-base font-semibold text-foreground">{ graphQLBudgetRemaining(data.Snapshot.RateLimits) }</strong>
					</div>
					<div class="grid gap-1">
						<span class="text-muted-foreground">Reset</span>
						<strong class="font-mono text-base font-semibold text-foreground">{ graphQLBudgetReset(data.Snapshot.RateLimits, data.Snapshot.GeneratedAt) }</strong>
						<span class="font-mono text-xs text-muted-foreground">{ graphQLBudgetResetAt(data.Snapshot.RateLimits) }</span>
					</div>
				</div>
				<div class="flex items-center justify-between gap-3 border-t border-border pt-3 text-sm">
					<span class="text-muted-foreground">Cycle queries</span>
					<strong class="font-mono font-medium text-foreground">{ graphQLBudgetQueryCount(data.Snapshot.RateLimits) }</strong>
				</div>
				if len(graphQLBudgetContributorRows(data.Snapshot.RateLimits)) == 0 {
					@dashboardEmptyState("No GraphQL query costs this cycle.", "Query contributors will appear after the GitHub connector reports rateLimit cost.", "bg-warning")
				} else {
					<div class="grid gap-2 border-t border-border pt-3">
						for _, row := range graphQLBudgetContributorRows(data.Snapshot.RateLimits) {
							<div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-1 text-sm">
								<span class="truncate font-mono font-medium text-foreground">{ row.QueryType }</span>
								<span class="font-mono text-muted-foreground">{ row.Cost }</span>
								<span class="font-mono text-xs text-muted-foreground">{ row.Count }</span>
								<span class="text-right font-mono text-xs text-muted-foreground">{ row.Percent }</span>
							</div>
						}
					</div>
				}
			</div>
		</section>
	}
}

templ restBudgetCard(data DashboardData) {
	if hasRESTBudget(data.Snapshot.RateLimits) {
		<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5" aria-label="REST budget">
			<div class="flex items-start justify-between gap-3">
				@helpHeading2("REST budget", helpRateLimits, "rest-budget-card")
				<span class="shrink-0 rounded-full bg-warning-soft px-2 py-1 font-mono text-xs font-medium text-warning">{ restBudgetRequestCount(data.Snapshot.RateLimits) }</span>
			</div>
			<div class="mt-5 grid gap-3">
				<div class="grid grid-cols-2 gap-3 text-sm">
					<div class="grid gap-1">
						<span class="text-muted-foreground">Remaining</span>
						<strong class="break-all font-mono text-base font-semibold text-foreground">{ restBudgetRemaining(data.Snapshot.RateLimits) }</strong>
					</div>
					<div class="grid gap-1">
						<span class="text-muted-foreground">Reset</span>
						<strong class="font-mono text-base font-semibold text-foreground">{ restBudgetReset(data.Snapshot.RateLimits, data.Snapshot.GeneratedAt) }</strong>
						<span class="font-mono text-xs text-muted-foreground">{ restBudgetResetAt(data.Snapshot.RateLimits) }</span>
					</div>
				</div>
				if len(restBudgetContributorRows(data.Snapshot.RateLimits)) == 0 {
					@dashboardEmptyState("No REST requests this cycle.", "REST contributors will appear after GitHub REST endpoints are called.", "bg-warning")
				} else {
					<div class="grid gap-2 border-t border-border pt-3">
						for _, row := range restBudgetContributorRows(data.Snapshot.RateLimits) {
							<div class="grid grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-1 text-sm">
								<span class="truncate font-mono font-medium text-foreground">{ row.EndpointFamily }</span>
								<span class="font-mono text-muted-foreground">{ row.Count }</span>
								<span class="font-mono text-xs text-muted-foreground">{ row.Remaining }</span>
								<span class="text-right font-mono text-xs text-muted-foreground">{ row.Status }</span>
							</div>
						}
					</div>
				}
			</div>
		</section>
	}
}

templ tokenCard(data DashboardData) {
	<section class="dashboard-panel min-w-0 rounded-md border border-border bg-card p-4 shadow-sm sm:p-5">
		<div class="flex items-start justify-between gap-3">
			@helpHeading2("Tokens", helpTokens, "tokens-card")
			<span class="shrink-0 rounded-full bg-muted px-2 py-1 font-mono text-xs font-medium text-muted-foreground">{ tokenRate(data.Snapshot) }</span>
		</div>
		<div class="mt-5 grid gap-2">
			<div class="break-all font-mono text-2xl font-semibold text-foreground sm:text-3xl">{ formatTokens(data.Snapshot.Tokens) }</div>
			<div class="font-mono text-sm text-muted-foreground">{ formatTokenBreakdown(data.Snapshot.Tokens) }</div>
		</div>
		<div class="mt-5">
			<div class="mb-2 flex items-center justify-between gap-3 text-sm">
				@helpInlineLabel("Token trend", helpTokenTrend, "tokens-card", "font-medium text-muted-foreground")
				<span class="font-mono text-xs text-muted-foreground">{ formatDuration(data.Snapshot.Tokens.RuntimeSeconds) }</span>
			</div>
			if len(tokenTrendPoints(data.Snapshot)) == 0 {
				@dashboardEmptyState("No token trend yet.", "Input and output token samples will appear after active sessions report usage.", "bg-accent")
			} else {
				@SplitSeriesChart(tokenTrendChart(data.Snapshot))
				<div class="mt-3 flex flex-wrap items-center gap-4 text-xs font-medium text-muted-foreground">
					<span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-accent"></span>Input</span>
					<span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-success"></span>Output</span>
				</div>
			}
		</div>
	</section>
}
